@model EchoConsole.Web.Models.Alerts.AlertsIndexViewModel

@{
    ViewData["Title"] = "ALERTS AND REPORTS";
    ViewData["TitleI18nKey"] = "alerts_page_title";
}

<div class="min-h-screen bg-[#070B12] text-slate-100">
    <div class="mx-auto max-w-[1600px] px-6 py-6">
        <div class="mb-6 flex flex-col gap-4 rounded-2xl border border-cyan-500/20 bg-slate-950/70 p-6 shadow-[0_0_40px_rgba(0,255,255,0.05)] backdrop-blur md:flex-row md:items-center md:justify-between">
            <div>
                <p class="font-display text-xs uppercase tracking-[0.35em] text-cyan-400" data-i18n="alerts_module_badge">
                    Module 5
                </p>
                <h1 class="mt-2 font-display text-3xl uppercase tracking-[0.18em] text-white md:text-4xl" data-i18n="alerts_hero_title">
                    SYSTEM ALERTS CENTER
                </h1>
                <p class="mt-3 max-w-3xl text-sm text-slate-400 md:text-base" data-i18n="alerts_hero_subtitle">
                    Centralized monitoring of automatic alerts generated by anomalies and critical telemetry events.
                </p>
            </div>

            <div class="rounded-2xl border border-cyan-500/20 bg-slate-900/80 px-5 py-4">
                <div class="font-display text-xs uppercase tracking-[0.25em] text-slate-500" data-i18n="alerts_total_label">
                    Total Alerts
                </div>
                <div class="mt-2 font-display text-3xl uppercase tracking-[0.08em] text-cyan-300">
                    @Model.TotalCount.ToString("N0")
                </div>
            </div>
        </div>

        <div class="mb-6 rounded-2xl border border-cyan-500/20 bg-slate-950/70 p-5 shadow-[0_0_30px_rgba(0,255,255,0.04)] backdrop-blur">
            <form method="get" asp-controller="Alerts" asp-action="Index" class="grid gap-4 md:grid-cols-[1fr_1fr_auto_auto]">
                <div>
                    <label for="severity" class="mb-2 block font-display text-xs uppercase tracking-[0.25em] text-slate-400" data-i18n="alerts_filter_severity">
                        Severity
                    </label>
                    <select id="severity"
                            name="severity"
                            class="w-full rounded-xl border border-cyan-500/20 bg-slate-900/80 px-4 py-3 text-sm text-slate-100 outline-none transition focus:border-cyan-400/40 focus:ring-2 focus:ring-cyan-400/10">
                        <option value="" selected="@(string.IsNullOrWhiteSpace(Model.SeverityFilter))" data-i18n="alerts_filter_all_severities">All Severities</option>
                        <option value="Info" selected="@(Model.SeverityFilter == "Info")" data-i18n="alert_severity_info">Info</option>
                        <option value="Warning" selected="@(Model.SeverityFilter == "Warning")" data-i18n="alert_severity_warning">Warning</option>
                        <option value="Critical" selected="@(Model.SeverityFilter == "Critical")" data-i18n="alert_severity_critical">Critical</option>
                        <option value="Fatal" selected="@(Model.SeverityFilter == "Fatal")" data-i18n="alert_severity_fatal">Fatal</option>
                    </select>
                </div>

                <div>
                    <label for="isResolved" class="mb-2 block font-display text-xs uppercase tracking-[0.25em] text-slate-400" data-i18n="alerts_filter_status">
                        Status
                    </label>
                    <select id="isResolved"
                            name="isResolved"
                            class="w-full rounded-xl border border-cyan-500/20 bg-slate-900/80 px-4 py-3 text-sm text-slate-100 outline-none transition focus:border-cyan-400/40 focus:ring-2 focus:ring-cyan-400/10">
                        <option value="" selected="@(Model.IsResolvedFilter is null)" data-i18n="alerts_filter_all_statuses">All Statuses</option>
                        <option value="false" selected="@(Model.IsResolvedFilter == false)" data-i18n="alerts_status_open">Open</option>
                        <option value="true" selected="@(Model.IsResolvedFilter == true)" data-i18n="alerts_status_resolved">Resolved</option>
                    </select>
                </div>

                <div class="flex items-end gap-3">
                    <button type="submit"
                            class="rounded-xl border border-cyan-400/25 bg-cyan-500/10 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-cyan-200 transition hover:bg-cyan-500/15"
                            data-i18n="alerts_filter_button">
                        Filter
                    </button>

                    <a asp-controller="Alerts"
                       asp-action="Index"
                       class="rounded-xl border border-slate-700 bg-slate-900/70 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-slate-300 transition hover:border-cyan-400/20 hover:text-white"
                       data-i18n="alerts_reset_button">
                        Reset
                    </a>
                </div>
            </form>
        </div>

        <div class="rounded-2xl border border-cyan-500/20 bg-slate-950/70 p-6 shadow-[0_0_40px_rgba(0,255,255,0.05)] backdrop-blur">
            <div class="mb-5 flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
                <div>
                    <p class="font-display text-xs uppercase tracking-[0.35em] text-cyan-400" data-i18n="alerts_table_badge">
                        Alert Registry
                    </p>
                    <h2 class="mt-2 font-display text-2xl uppercase tracking-[0.14em] text-white" data-i18n="alerts_table_title">
                        REGISTERED ALERTS
                    </h2>
                </div>

                <div class="text-sm text-slate-400">
                    <span data-i18n="alerts_results_label">Results:</span>
                    <span class="font-semibold text-cyan-300">@Model.TotalCount.ToString("N0")</span>
                </div>
            </div>

            <div class="overflow-hidden rounded-2xl border border-slate-800">
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-slate-800">
                        <thead class="bg-slate-900/90">
                            <tr class="text-left">
                                <th class="px-5 py-4 font-display text-xs uppercase tracking-[0.22em] text-slate-400" data-i18n="alerts_col_date">
                                    DATE
                                </th>
                                <th class="px-5 py-4 font-display text-xs uppercase tracking-[0.22em] text-slate-400" data-i18n="alerts_col_source">
                                    SOURCE
                                </th>
                                <th class="px-5 py-4 font-display text-xs uppercase tracking-[0.22em] text-slate-400" data-i18n="alerts_col_message">
                                    MESSAGE
                                </th>
                                <th class="px-5 py-4 font-display text-xs uppercase tracking-[0.22em] text-slate-400" data-i18n="alerts_col_severity">
                                    SEVERITY
                                </th>
                                <th class="px-5 py-4 font-display text-xs uppercase tracking-[0.22em] text-slate-400" data-i18n="alerts_col_status">
                                    STATUS
                                </th>
                                <th class="px-5 py-4 font-display text-xs uppercase tracking-[0.22em] text-slate-400" data-i18n="alerts_col_actions">
                                    ACTIONS
                                </th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-900 bg-slate-950/80">
                            @if (Model.Items != null && Model.Items.Any())
                            {
                                @foreach (var item in Model.Items)
                                {
                                    <tr class="transition-colors duration-150 hover:bg-slate-900/70">
                                        <td class="px-5 py-4 text-sm text-slate-300">
                                            @item.CreatedAtUtc.UtcDateTime.ToString("yyyy-MM-dd HH:mm:ss 'UTC'")
                                        </td>

                                        <td class="px-5 py-4 text-sm text-cyan-300">
                                            @item.Source
                                        </td>

                                        <td class="px-5 py-4 text-sm text-slate-300">
                                            <div class="max-w-[420px] whitespace-normal break-words">
                                                @item.Message
                                            </div>
                                        </td>

                                        <td class="px-5 py-4">
                                            @switch (item.Severity)
                                            {
                                                case "Fatal":
                                                    <span class="inline-flex items-center gap-2 rounded-full border border-rose-500/30 bg-rose-500/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-rose-400">
                                                        <span class="h-2 w-2 rounded-full bg-rose-400"></span>
                                                        <span data-i18n="alert_severity_fatal">Fatal</span>
                                                    </span>
                                                    break;
                                                case "Critical":
                                                    <span class="inline-flex items-center gap-2 rounded-full border border-orange-500/30 bg-orange-500/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-orange-400">
                                                        <span class="h-2 w-2 rounded-full bg-orange-400"></span>
                                                        <span data-i18n="alert_severity_critical">Critical</span>
                                                    </span>
                                                    break;
                                                case "Warning":
                                                    <span class="inline-flex items-center gap-2 rounded-full border border-amber-500/30 bg-amber-500/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-amber-400">
                                                        <span class="h-2 w-2 rounded-full bg-amber-400"></span>
                                                        <span data-i18n="alert_severity_warning">Warning</span>
                                                    </span>
                                                    break;
                                                default:
                                                    <span class="inline-flex items-center gap-2 rounded-full border border-cyan-500/30 bg-cyan-500/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-cyan-300">
                                                        <span class="h-2 w-2 rounded-full bg-cyan-300"></span>
                                                        <span data-i18n="alert_severity_info">Info</span>
                                                    </span>
                                                    break;
                                            }
                                        </td>

                                        <td class="px-5 py-4">
                                            @if (item.IsResolved)
                                            {
                                                <span class="inline-flex items-center gap-2 rounded-full border border-emerald-500/30 bg-emerald-500/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-emerald-400">
                                                    <span class="h-2 w-2 rounded-full bg-emerald-400"></span>
                                                    <span data-i18n="alerts_status_resolved">Resolved</span>
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="inline-flex items-center gap-2 rounded-full border border-slate-600/30 bg-slate-700/20 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-slate-300">
                                                    <span class="h-2 w-2 rounded-full bg-slate-400"></span>
                                                    <span data-i18n="alerts_status_open">Open</span>
                                                </span>
                                            }
                                        </td>

                                        <td class="px-5 py-4">
                                            @if (!item.IsResolved)
                                            {
                                                <form asp-controller="Alerts"
                                                      asp-action="Resolve"
                                                      method="post"
                                                      class="inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@item.Id" />
                                                    <input type="hidden" name="severity" value="@Model.SeverityFilter" />
                                                    <input type="hidden" name="isResolved" value="@Model.IsResolvedFilter?.ToString()?.ToLowerInvariant()" />
                                                    <input type="hidden" name="pageNumber" value="@Model.PageNumber" />

                                                    <button type="submit"
                                                            class="rounded-lg border border-cyan-400/25 bg-cyan-500/10 px-3 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-cyan-200 transition hover:bg-cyan-500/15"
                                                            data-i18n="alerts_action_resolve">
                                                        Resolve
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <span class="text-sm font-medium text-emerald-400" data-i18n="alerts_status_resolved">
                                                    Resolved
                                                </span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="px-5 py-6 text-center text-sm text-slate-400" data-i18n="alerts_empty_state">
                                        No alerts found.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="mt-5 flex flex-col gap-4 border-t border-slate-800 pt-5 md:flex-row md:items-center md:justify-between">
                <div class="text-sm text-slate-400">
                    <span data-i18n="pagination_page">Page</span>
                    <span class="font-semibold text-cyan-300">@Model.PageNumber</span>
                    <span data-i18n="pagination_of">of</span>
                    <span class="font-semibold text-cyan-300">@Math.Max(Model.TotalPages, 1)</span>
                </div>

                <div class="flex items-center gap-3">
                    @if (Model.HasPreviousPage)
                    {
                        <a asp-controller="Alerts"
                           asp-action="Index"
                           asp-route-severity="@Model.SeverityFilter"
                           asp-route-isResolved="@Model.IsResolvedFilter"
                           asp-route-pageNumber="@(Model.PageNumber - 1)"
                           class="rounded-xl border border-slate-700 bg-slate-900/70 px-4 py-2 text-sm font-semibold uppercase tracking-[0.18em] text-slate-300 transition hover:border-cyan-400/20 hover:text-white"
                           data-i18n="pagination_previous">
                            Previous
                        </a>
                    }
                    else
                    {
                        <span class="rounded-xl border border-slate-800 bg-slate-950/70 px-4 py-2 text-sm font-semibold uppercase tracking-[0.18em] text-slate-600"
                              data-i18n="pagination_previous">
                            Previous
                        </span>
                    }

                    @if (Model.HasNextPage)
                    {
                        <a asp-controller="Alerts"
                           asp-action="Index"
                           asp-route-severity="@Model.SeverityFilter"
                           asp-route-isResolved="@Model.IsResolvedFilter"
                           asp-route-pageNumber="@(Model.PageNumber + 1)"
                           class="rounded-xl border border-cyan-400/25 bg-cyan-500/10 px-4 py-2 text-sm font-semibold uppercase tracking-[0.18em] text-cyan-200 transition hover:bg-cyan-500/15"
                           data-i18n="pagination_next">
                            Next
                        </a>
                    }
                    else
                    {
                        <span class="rounded-xl border border-slate-800 bg-slate-950/70 px-4 py-2 text-sm font-semibold uppercase tracking-[0.18em] text-slate-600"
                              data-i18n="pagination_next">
                            Next
                        </span>
                    }
                </div>
            </div>
        </div>
    </div>
</div>