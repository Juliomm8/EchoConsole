@model EchoConsole.Web.Models.Alerts.AlertsIndexViewModel

@{
    ViewData["Title"] = SharedLocalizer["Alerts_PageTitle"].Value;
    ViewData["TitleResourceKey"] = "Alerts_PageTitle";
}

<div class="min-h-screen bg-[#070B12] text-slate-100">
    <div class="mx-auto max-w-[1600px] px-6 py-6">
        <div class="mb-6 flex flex-col gap-4 rounded-2xl border border-cyan-500/20 bg-slate-950/70 p-6 shadow-[0_0_40px_rgba(0,255,255,0.05)] backdrop-blur md:flex-row md:items-center md:justify-between">
            <div>
                <p class="font-display text-xs uppercase tracking-[0.35em] text-cyan-400">@SharedLocalizer["Alerts_ModuleBadge"]</p>
                <h1 class="mt-2 font-display text-3xl uppercase tracking-[0.18em] text-white md:text-4xl">@SharedLocalizer["Alerts_HeroTitle"]</h1>
                <p class="mt-3 max-w-3xl text-sm text-slate-400 md:text-base">@SharedLocalizer["Alerts_HeroSubtitle"]</p>
            </div>

            <div class="rounded-2xl border border-cyan-500/20 bg-slate-900/80 px-5 py-4">
                <div class="font-display text-xs uppercase tracking-[0.25em] text-slate-500">@SharedLocalizer["Alerts_TotalLabel"]</div>
                <div class="mt-2 font-display text-3xl uppercase tracking-[0.08em] text-cyan-300">
                    @Model.TotalCount.ToString("N0")
                </div>
            </div>
        </div>

        <div class="mb-6 rounded-2xl border border-cyan-500/20 bg-slate-950/70 p-5 shadow-[0_0_30px_rgba(0,255,255,0.04)] backdrop-blur">
            <form method="get" asp-controller="Alerts" asp-action="Index" class="grid gap-4 md:grid-cols-[1fr_1fr_auto_auto]">
                <div>
                    <label for="severity" class="mb-2 block font-display text-xs uppercase tracking-[0.25em] text-slate-400">@SharedLocalizer["Alerts_FilterSeverity"]</label>
                    <select id="severity"
                            name="severity"
                            class="w-full rounded-xl border border-cyan-500/20 bg-slate-900/80 px-4 py-3 text-sm text-slate-100 outline-none transition focus:border-cyan-400/40 focus:ring-2 focus:ring-cyan-400/10">
                        <option value="" selected="@(string.IsNullOrWhiteSpace(Model.SeverityFilter))">@SharedLocalizer["Alerts_AllSeverities"]</option>
                        <option value="Info" selected="@(Model.SeverityFilter == "Info")">@SharedLocalizer["Alerts_SeverityInfo"]</option>
                        <option value="Warning" selected="@(Model.SeverityFilter == "Warning")">@SharedLocalizer["Alerts_SeverityWarning"]</option>
                        <option value="Critical" selected="@(Model.SeverityFilter == "Critical")">@SharedLocalizer["Alerts_SeverityCritical"]</option>
                        <option value="Fatal" selected="@(Model.SeverityFilter == "Fatal")">@SharedLocalizer["Alerts_SeverityFatal"]</option>
                    </select>
                </div>

                <div>
                    <label for="isResolved" class="mb-2 block font-display text-xs uppercase tracking-[0.25em] text-slate-400">@SharedLocalizer["Alerts_FilterStatus"]</label>
                    <select id="isResolved"
                            name="isResolved"
                            class="w-full rounded-xl border border-cyan-500/20 bg-slate-900/80 px-4 py-3 text-sm text-slate-100 outline-none transition focus:border-cyan-400/40 focus:ring-2 focus:ring-cyan-400/10">
                        <option value="" selected="@(Model.IsResolvedFilter is null)">@SharedLocalizer["Alerts_AllStatuses"]</option>
                        <option value="false" selected="@(Model.IsResolvedFilter == false)">@SharedLocalizer["Alerts_StatusOpen"]</option>
                        <option value="true" selected="@(Model.IsResolvedFilter == true)">@SharedLocalizer["Alerts_StatusResolved"]</option>
                    </select>
                </div>

                <div class="flex items-end gap-3">
                    <button type="submit"
                            class="rounded-xl border border-cyan-400/25 bg-cyan-500/10 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-cyan-200 transition hover:bg-cyan-500/15">@SharedLocalizer["Common_Filter"]</button>

                    <a asp-controller="Alerts"
                       asp-action="Index"
                       class="rounded-xl border border-slate-700 bg-slate-900/70 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-slate-300 transition hover:border-cyan-400/20 hover:text-white">@SharedLocalizer["Common_Reset"]</a>
                </div>
            </form>
        </div>

        <div class="rounded-2xl border border-cyan-500/20 bg-slate-950/70 p-6 shadow-[0_0_40px_rgba(0,255,255,0.05)] backdrop-blur">
            <div class="mb-5 flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
                <div>
                    <p class="font-display text-xs uppercase tracking-[0.35em] text-cyan-400">@SharedLocalizer["Alerts_TableBadge"]</p>
                    <h2 class="mt-2 font-display text-2xl uppercase tracking-[0.14em] text-white">@SharedLocalizer["Alerts_TableTitle"]</h2>
                </div>

                <div class="text-sm text-slate-400">
                    <span>@SharedLocalizer["Common_Results"]</span>
                    <span class="font-semibold text-cyan-300">@Model.TotalCount.ToString("N0")</span>
                </div>
            </div>

            <div class="overflow-hidden rounded-2xl border border-slate-800">
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-slate-800">
                        <thead class="bg-slate-900/90">
                            <tr class="text-left">
                                <th class="px-5 py-4 font-display text-xs uppercase tracking-[0.22em] text-slate-400">@SharedLocalizer["Alerts_ColDate"]</th>
                                <th class="px-5 py-4 font-display text-xs uppercase tracking-[0.22em] text-slate-400">@SharedLocalizer["Alerts_ColSource"]</th>
                                <th class="px-5 py-4 font-display text-xs uppercase tracking-[0.22em] text-slate-400">@SharedLocalizer["Alerts_ColMessage"]</th>
                                <th class="px-5 py-4 font-display text-xs uppercase tracking-[0.22em] text-slate-400">@SharedLocalizer["Alerts_ColSeverity"]</th>
                                <th class="px-5 py-4 font-display text-xs uppercase tracking-[0.22em] text-slate-400">@SharedLocalizer["Alerts_ColStatus"]</th>
                                <th class="px-5 py-4 font-display text-xs uppercase tracking-[0.22em] text-slate-400">@SharedLocalizer["Alerts_ColActions"]</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-900 bg-slate-950/80">
                            @if (Model.Items != null && Model.Items.Any())
                            {
                                @foreach (var item in Model.Items)
                                {
                                    <tr class="transition-colors duration-150 hover:bg-slate-900/70">
                                        <td class="px-5 py-4 text-sm text-slate-300">
                                            @item.CreatedAtUtc.UtcDateTime.ToString("yyyy-MM-dd HH:mm:ss 'UTC'")
                                        </td>

                                        <td class="px-5 py-4 text-sm text-cyan-300">
                                            @item.Source
                                        </td>

                                        <td class="px-5 py-4 text-sm text-slate-300">
                                            <div class="max-w-[420px] whitespace-normal break-words">
                                                @item.Message
                                            </div>
                                        </td>

                                        <td class="px-5 py-4">
                                            @switch (item.Severity)
                                            {
                                                case "Fatal":
                                                    <span class="inline-flex items-center gap-2 rounded-full border border-rose-500/30 bg-rose-500/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-rose-400">
                                                        <span class="h-2 w-2 rounded-full bg-rose-400"></span>
                                                        <span>@SharedLocalizer["Alerts_SeverityFatal"]</span>
                                                    </span>
                                                    break;
                                                case "Critical":
                                                    <span class="inline-flex items-center gap-2 rounded-full border border-orange-500/30 bg-orange-500/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-orange-400">
                                                        <span class="h-2 w-2 rounded-full bg-orange-400"></span>
                                                        <span>@SharedLocalizer["Alerts_SeverityCritical"]</span>
                                                    </span>
                                                    break;
                                                case "Warning":
                                                    <span class="inline-flex items-center gap-2 rounded-full border border-amber-500/30 bg-amber-500/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-amber-400">
                                                        <span class="h-2 w-2 rounded-full bg-amber-400"></span>
                                                        <span>@SharedLocalizer["Alerts_SeverityWarning"]</span>
                                                    </span>
                                                    break;
                                                default:
                                                    <span class="inline-flex items-center gap-2 rounded-full border border-cyan-500/30 bg-cyan-500/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-cyan-300">
                                                        <span class="h-2 w-2 rounded-full bg-cyan-300"></span>
                                                        <span>@SharedLocalizer["Alerts_SeverityInfo"]</span>
                                                    </span>
                                                    break;
                                            }
                                        </td>

                                        <td class="px-5 py-4">
                                            @if (item.IsResolved)
                                            {
                                                <span class="inline-flex items-center gap-2 rounded-full border border-emerald-500/30 bg-emerald-500/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-emerald-400">
                                                    <span class="h-2 w-2 rounded-full bg-emerald-400"></span>
                                                    <span>@SharedLocalizer["Alerts_StatusResolved"]</span>
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="inline-flex items-center gap-2 rounded-full border border-slate-600/30 bg-slate-700/20 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-slate-300">
                                                    <span class="h-2 w-2 rounded-full bg-slate-400"></span>
                                                    <span>@SharedLocalizer["Alerts_StatusOpen"]</span>
                                                </span>
                                            }
                                        </td>

                                        <td class="px-5 py-4">
                                            @if (!item.IsResolved)
                                            {
                                                <form asp-controller="Alerts"
                                                      asp-action="Resolve"
                                                      method="post"
                                                      class="inline">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@item.Id" />
                                                    <input type="hidden" name="severity" value="@Model.SeverityFilter" />
                                                    <input type="hidden" name="isResolved" value="@Model.IsResolvedFilter?.ToString()?.ToLowerInvariant()" />
                                                    <input type="hidden" name="pageNumber" value="@Model.PageNumber" />

                                                    <button type="submit"
                                                            class="rounded-lg border border-cyan-400/25 bg-cyan-500/10 px-3 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-cyan-200 transition hover:bg-cyan-500/15">@SharedLocalizer["Alerts_ActionResolve"]</button>
                                                </form>
                                            }
                                            else
                                            {
                                                <span class="text-sm font-medium text-emerald-400">@SharedLocalizer["Alerts_StatusResolved"]</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="px-5 py-6 text-center text-sm text-slate-400">@SharedLocalizer["Alerts_EmptyState"]</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="mt-5 flex flex-col gap-4 border-t border-slate-800 pt-5 md:flex-row md:items-center md:justify-between">
                <div class="text-sm text-slate-400">
                    <span>@SharedLocalizer["Common_Page"]</span>
                    <span class="font-semibold text-cyan-300">@Model.PageNumber</span>
                    <span>@SharedLocalizer["Common_Of"]</span>
                    <span class="font-semibold text-cyan-300">@Math.Max(Model.TotalPages, 1)</span>
                </div>

                <div class="flex items-center gap-3">
                    @if (Model.HasPreviousPage)
                    {
                        <a asp-controller="Alerts"
                           asp-action="Index"
                           asp-route-severity="@Model.SeverityFilter"
                           asp-route-isResolved="@Model.IsResolvedFilter"
                           asp-route-pageNumber="@(Model.PageNumber - 1)"
                           class="rounded-xl border border-slate-700 bg-slate-900/70 px-4 py-2 text-sm font-semibold uppercase tracking-[0.18em] text-slate-300 transition hover:border-cyan-400/20 hover:text-white">@SharedLocalizer["Common_Previous"]</a>
                    }
                    else
                    {
                        <span class="rounded-xl border border-slate-800 bg-slate-950/70 px-4 py-2 text-sm font-semibold uppercase tracking-[0.18em] text-slate-600">@SharedLocalizer["Common_Previous"]</span>
                    }

                    @if (Model.HasNextPage)
                    {
                        <a asp-controller="Alerts"
                           asp-action="Index"
                           asp-route-severity="@Model.SeverityFilter"
                           asp-route-isResolved="@Model.IsResolvedFilter"
                           asp-route-pageNumber="@(Model.PageNumber + 1)"
                           class="rounded-xl border border-cyan-400/25 bg-cyan-500/10 px-4 py-2 text-sm font-semibold uppercase tracking-[0.18em] text-cyan-200 transition hover:bg-cyan-500/15">@SharedLocalizer["Common_Next"]</a>
                    }
                    else
                    {
                        <span class="rounded-xl border border-slate-800 bg-slate-950/70 px-4 py-2 text-sm font-semibold uppercase tracking-[0.18em] text-slate-600">@SharedLocalizer["Common_Next"]</span>
                    }
                </div>
            </div>
        </div>
    </div>
</div>