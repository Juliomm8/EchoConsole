@using System.Globalization
@using EchoConsole.Web.Services.Profile

@{
    var terminalTheme =
        User.Identity?.IsAuthenticated == true
            ? ProfileCatalog.NormalizeStoredTheme(
                User.FindFirst("theme")?.Value)
            : ProfileCatalog.DefaultTheme;
}

<!DOCTYPE html>
<html lang="@CultureInfo.CurrentUICulture.TwoLetterISOLanguageName"
      data-theme="retro-terminal"
      data-terminal-theme="@terminalTheme"
      class="h-full bg-black">
<head>
    <meta charset="utf-8" />
    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Echo Console</title>

    <link rel="stylesheet"
          href="~/css/tailwind.output.css"
          asp-append-version="true" />
</head>

<body data-terminal-theme="@terminalTheme"
      class="h-full bg-black font-mono antialiased">
    <div class="min-h-screen bg-black">
        <div class="grid min-h-screen grid-cols-1 xl:grid-cols-[5.5rem_minmax(0,1fr)]">
            <aside data-sidebar-shell
                   class="group/sidebar z-50 border-b border-green-500/15 bg-black/95 transition-[width,box-shadow] duration-300 xl:sticky xl:top-0 xl:h-screen xl:w-[5.5rem] xl:overflow-visible xl:border-b-0 xl:border-r xl:hover:w-[19rem] xl:hover:shadow-[14px_0_42px_rgba(57,255,20,0.08)]">
                @await Html.PartialAsync("_Sidebar")
            </aside>

            <div class="flex min-h-screen min-w-0 flex-col bg-black">
                @await Html.PartialAsync("_Topbar")

                <main class="min-w-0 flex-1">
                    @RenderBody()
                </main>

                @await Html.PartialAsync("_Footer")
            </div>
        </div>
    </div>

    @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
    {
        @await Html.PartialAsync("_SimulationOrchestrator")
    }

    <script src="~/js/navigation-shell.js"
            asp-append-version="true"></script>

    @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Admin"))
    {
        <script src="~/js/simulation-orchestrator.js"
                asp-append-version="true"
                defer></script>

        <script src="~/js/shell-status.js"
                asp-append-version="true"
                defer></script>
    }

    @await RenderSectionAsync(
        "Scripts",
        required: false)
</body>
</html>
