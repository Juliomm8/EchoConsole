<!DOCTYPE html>
<html lang="en" class="h-100">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EchoConsole.Web</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Orbitron:wght@500;600;700;800&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

    <style>
        html, body {
            height: 100%;
        }

        body {
            font-family: 'Inter', sans-serif;
            background:
                radial-gradient(circle at top left, rgba(34, 211, 238, 0.08), transparent 25%),
                radial-gradient(circle at top right, rgba(232, 121, 249, 0.08), transparent 20%),
                linear-gradient(180deg, #070B12 0%, #04070D 100%);
            color: #E5EEF8;
            margin: 0;
        }

        .auth-page {
            min-height: 100vh;
            position: relative;
            overflow: hidden;
        }

        .auth-page::before {
            content: "";
            position: absolute;
            inset: 0;
            background-image:
                linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
            background-size: 28px 28px;
            pointer-events: none;
        }

        .auth-shell {
            position: relative;
            z-index: 1;
        }

        .auth-brand {
            font-family: 'Orbitron', sans-serif;
            letter-spacing: 0.14em;
            text-transform: uppercase;
            color: #67E8F9;
            text-shadow: 0 0 14px rgba(34, 211, 238, 0.18);
        }

        .auth-subbrand {
            font-family: 'Orbitron', sans-serif;
            letter-spacing: 0.35em;
            text-transform: uppercase;
            color: #F0ABFC;
            font-size: 0.85rem;
        }

        .auth-card {
            background: linear-gradient(180deg, rgba(11,18,32,0.92) 0%, rgba(7,11,18,0.90) 100%);
            border: 1px solid rgba(34, 211, 238, 0.16);
            border-radius: 1.25rem;
            box-shadow:
                0 0 0 1px rgba(34,211,238,0.05),
                0 0 28px rgba(34,211,238,0.06);
            backdrop-filter: blur(10px);
        }

        .auth-title {
            font-family: 'Orbitron', sans-serif;
            text-transform: uppercase;
            letter-spacing: 0.12em;
            color: #F8FAFC;
        }

        .auth-kicker {
            font-family: 'Orbitron', sans-serif;
            text-transform: uppercase;
            letter-spacing: 0.30em;
            font-size: 0.75rem;
            color: #22D3EE;
        }

        .form-label {
            color: #CBD5E1;
            font-weight: 500;
        }

        .form-control {
            background: rgba(15, 23, 42, 0.86);
            border: 1px solid rgba(34, 211, 238, 0.18);
            color: #F8FAFC;
            border-radius: 0.9rem;
            padding: 0.85rem 1rem;
        }

        .form-control:focus {
            background: rgba(15, 23, 42, 0.95);
            color: #F8FAFC;
            border-color: rgba(34, 211, 238, 0.45);
            box-shadow: 0 0 0 0.2rem rgba(34, 211, 238, 0.10);
        }

        .form-control::placeholder {
            color: #64748B;
        }

        .btn-auth-primary {
            background: linear-gradient(90deg, rgba(34,211,238,0.22), rgba(34,211,238,0.12));
            border: 1px solid rgba(34, 211, 238, 0.28);
            color: #CFFAFE;
            border-radius: 0.9rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.12em;
            padding: 0.85rem 1rem;
        }

        .btn-auth-primary:hover {
            background: linear-gradient(90deg, rgba(34,211,238,0.28), rgba(34,211,238,0.16));
            border-color: rgba(34, 211, 238, 0.38);
            color: #ECFEFF;
        }

        .auth-link {
            color: #67E8F9;
            text-decoration: none;
            font-weight: 600;
        }

        .auth-link:hover {
            color: #A5F3FC;
            text-decoration: underline;
        }

        .text-danger {
            color: #FCA5A5 !important;
        }

        .auth-muted {
            color: #94A3B8;
        }

        .auth-side-panel {
            background: linear-gradient(180deg, rgba(7,11,18,0.55) 0%, rgba(7,11,18,0.15) 100%);
            border: 1px solid rgba(232, 121, 249, 0.12);
            border-radius: 1.25rem;
            padding: 1.5rem;
        }

        .auth-side-title {
            font-family: 'Orbitron', sans-serif;
            text-transform: uppercase;
            letter-spacing: 0.12em;
            color: #F0ABFC;
        }

        .auth-divider {
            height: 1px;
            background: linear-gradient(90deg, rgba(34,211,238,0.22), rgba(232,121,249,0.16), transparent);
            border: 0;
        }
    </style>
</head>
<body>
    @RenderBody()

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>