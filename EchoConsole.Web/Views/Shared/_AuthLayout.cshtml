@using System.Globalization

@{
    var currentCulture =
        CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "es"
            ? "es"
            : "en";

    var returnUrl =
        $"{Context.Request.PathBase}{Context.Request.Path}{Context.Request.QueryString}";
}

<!DOCTYPE html>
<html lang="@CultureInfo.CurrentUICulture.TwoLetterISOLanguageName"
      data-theme="retro-terminal"
      class="h-full bg-black">
<head>
    <meta charset="utf-8" />
    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - Echo Console</title>

    <link rel="stylesheet"
          href="~/css/tailwind.output.css"
          asp-append-version="true" />
</head>
<body class="flex min-h-full flex-col bg-black font-mono text-green-100 antialiased">
    <div class="relative flex min-h-screen flex-1 flex-col overflow-hidden bg-black">
        <div class="auth-grid-background pointer-events-none absolute inset-0 opacity-70"></div>
        <div class="pointer-events-none absolute inset-x-0 top-0 h-72 bg-[radial-gradient(circle_at_top,rgba(57,255,20,0.10),transparent_68%)]"></div>

        <div class="absolute right-4 top-4 z-30 flex items-center gap-1 rounded-lg border border-green-500/25 bg-black/90 p-1.5 shadow-phosphor sm:right-6 sm:top-6">
            <form asp-controller="Culture"
                  asp-action="Set"
                  method="post"
                  class="m-0">
                @Html.AntiForgeryToken()
                <input type="hidden" name="culture" value="en" />
                <input type="hidden" name="returnUrl" value="@returnUrl" />

                <button type="submit"
                        class="rounded-md px-3 py-2 text-xs font-bold uppercase tracking-[0.18em] transition @(currentCulture == "en" ? "bg-green-500/20 text-green-200 shadow-phosphor" : "text-slate-500 hover:bg-green-500/10 hover:text-green-200")">
                    EN
                </button>
            </form>

            <form asp-controller="Culture"
                  asp-action="Set"
                  method="post"
                  class="m-0">
                @Html.AntiForgeryToken()
                <input type="hidden" name="culture" value="es" />
                <input type="hidden" name="returnUrl" value="@returnUrl" />

                <button type="submit"
                        class="rounded-md px-3 py-2 text-xs font-bold uppercase tracking-[0.18em] transition @(currentCulture == "es" ? "bg-amber-500/20 text-amber-200 shadow-amber" : "text-slate-500 hover:bg-amber-500/10 hover:text-amber-200")">
                    ES
                </button>
            </form>
        </div>

        <main class="relative z-10 flex-1">
            @RenderBody()
        </main>

        <div class="relative z-10">
            @await Html.PartialAsync("_Footer")
        </div>
    </div>

    <partial name="_ValidationScriptsPartial" />

    @await RenderSectionAsync(
        "Scripts",
        required: false)
</body>
</html>
