@using System.Globalization

@{
    var currentController =
        ViewContext.RouteData.Values["controller"]?.ToString()
        ?? string.Empty;

    var isAuthenticated =
        User.Identity?.IsAuthenticated ?? false;

    var isAdmin = User.IsInRole("Admin");

    var currentCulture =
        CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "es"
            ? "es"
            : "en";

    var currentCultureLabel = currentCulture == "es"
        ? SharedLocalizer["Culture_Spanish"].Value
        : SharedLocalizer["Culture_English"].Value;

    var returnUrl =
        $"{Context.Request.PathBase}{Context.Request.Path}{Context.Request.QueryString}";

    Func<string[], string> navClass = controllers =>
        controllers.Any(controller =>
            string.Equals(
                currentController,
                controller,
                StringComparison.OrdinalIgnoreCase))
            ? "flex h-14 w-full flex-nowrap items-center gap-3 overflow-hidden rounded-md border border-green-400/40 bg-green-500/10 px-2.5 text-green-100 shadow-phosphor transition"
            : "flex h-14 w-full flex-nowrap items-center gap-3 overflow-hidden rounded-md border border-transparent px-2.5 text-slate-500 transition hover:border-green-500/25 hover:bg-green-500/10 hover:text-green-100";

    const string labelClass =
        "min-w-max whitespace-nowrap text-sm font-semibold leading-none transition-all duration-200 xl:max-w-0 xl:overflow-hidden xl:opacity-0 xl:group-hover/sidebar:max-w-[14rem] xl:group-hover/sidebar:opacity-100";

    const string iconClass =
        "inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-md border border-green-500/25 bg-black text-green-300";
}

<div class="flex h-full min-h-0 w-full flex-col overflow-hidden p-3">
    <div class="h-[4.25rem] shrink-0 rounded-lg border border-green-500/25 bg-green-500/5 p-2 shadow-phosphor">
        <div class="flex h-full flex-nowrap items-center gap-3 overflow-hidden">
            <a asp-controller="Home"
               asp-action="Index"
               aria-label="@SharedLocalizer["Sidebar_Home"]"
               title="@SharedLocalizer["Sidebar_Home"]"
               class="flex h-11 w-11 shrink-0 items-center justify-center rounded-md border border-green-400/40 bg-black font-display text-sm uppercase tracking-[0.12em] text-green-200 shadow-phosphor transition hover:border-green-300 hover:text-white hover:shadow-phosphor-strong">
                EC
            </a>

            <div class="min-w-max overflow-hidden whitespace-nowrap transition-all duration-200 xl:max-w-0 xl:opacity-0 xl:group-hover/sidebar:max-w-[14rem] xl:group-hover/sidebar:opacity-100">
                <div class="font-display text-lg uppercase tracking-[0.12em] text-green-200 text-glow-cyan">
                    Echo Console
                </div>
                <div class="mt-0.5 text-[10px] uppercase tracking-[0.28em] text-amber-400">
                    Retro Telemetry OS
                </div>
            </div>
        </div>
    </div>

    <nav class="mt-4 min-h-0 flex-1 space-y-1.5 overflow-y-auto overflow-x-hidden pr-0.5">
        <a asp-controller="Home"
           asp-action="Index"
           title="@SharedLocalizer["Sidebar_Home"]"
           class="@navClass(new[] { "Home" })">
            <span class="@iconClass">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                    <path d="M3 10.5 12 3l9 7.5" />
                    <path d="M5 9.5V21h14V9.5" />
                </svg>
            </span>
            <span class="@labelClass">@SharedLocalizer["Sidebar_Home"]</span>
        </a>

        @if (!isAuthenticated)
        {
            <a asp-controller="Auth"
               asp-action="Login"
               title="@SharedLocalizer["Common_Login"]"
               class="@navClass(new[] { "Auth" })">
                <span class="@iconClass">
                    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                        <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4" />
                        <path d="M10 17l5-5-5-5M15 12H3" />
                    </svg>
                </span>
                <span class="@labelClass">@SharedLocalizer["Common_Login"]</span>
            </a>

            <a asp-controller="Auth"
               asp-action="Register"
               title="@SharedLocalizer["Common_Register"]"
               class="@navClass(new[] { "Auth" })">
                <span class="@iconClass">
                    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                        <path d="M16 21v-2a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v2" />
                        <circle cx="9.5" cy="7" r="4" />
                        <path d="M20 8v6M23 11h-6" />
                    </svg>
                </span>
                <span class="@labelClass">@SharedLocalizer["Common_Register"]</span>
            </a>
        }
        else if (!isAdmin)
        {
            <a asp-controller="Profile"
               asp-action="Index"
               title="@SharedLocalizer["Sidebar_Profile"]"
               class="@navClass(new[] { "Profile", "ProfileSettings" })">
                <span class="@iconClass">
                    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                        <circle cx="12" cy="8" r="4" />
                        <path d="M4 21a8 8 0 0 1 16 0" />
                    </svg>
                </span>
                <span class="@labelClass">@SharedLocalizer["Sidebar_Profile"]</span>
            </a>
        }
        else
        {
            <a asp-controller="Dashboard"
               asp-action="Index"
               title="@SharedLocalizer["Sidebar_LiveMonitoring"]"
               class="@navClass(new[] { "Dashboard" })">
                <span class="@iconClass">
                    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                        <path d="M4 4h7v7H4zM13 4h7v4h-7zM13 10h7v10h-7zM4 13h7v7H4z" />
                    </svg>
                </span>
                <span class="@labelClass">@SharedLocalizer["Sidebar_LiveMonitoring"]</span>
            </a>

            <a asp-controller="Builds"
               asp-action="Index"
               title="@SharedLocalizer["Sidebar_GamesBuilds"]"
               class="@navClass(new[] { "Builds" })">
                <span class="@iconClass">
                    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                        <path d="M8 4h8M8 8h8M4 12h16M7 16h10M9 20h6" />
                    </svg>
                </span>
                <span class="@labelClass">@SharedLocalizer["Sidebar_GamesBuilds"]</span>
            </a>

            <a asp-controller="PatchNotesAdmin"
               asp-action="Index"
               title="@SharedLocalizer["Sidebar_PatchNotesCms"]"
               class="@navClass(new[] { "PatchNotesAdmin" })">
                <span class="@iconClass font-display text-[10px]">PN</span>
                <span class="@labelClass">@SharedLocalizer["Sidebar_PatchNotesCms"]</span>
            </a>

            <a asp-controller="Installations"
               asp-action="Index"
               title="@SharedLocalizer["Sidebar_DevicesInstallations"]"
               class="@navClass(new[] { "Installations" })">
                <span class="@iconClass">
                    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                        <rect x="4" y="5" width="16" height="11" rx="2" />
                        <path d="M8 20h8M10 16v4M14 16v4" />
                    </svg>
                </span>
                <span class="@labelClass">@SharedLocalizer["Sidebar_DevicesInstallations"]</span>
            </a>

            <a asp-controller="Alerts"
               asp-action="Index"
               title="@SharedLocalizer["Sidebar_AlertsReports"]"
               class="@navClass(new[] { "Alerts" })">
                <span class="@iconClass">
                    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                        <path d="M12 9v4M12 17h.01" />
                        <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0Z" />
                    </svg>
                </span>
                <span class="@labelClass">@SharedLocalizer["Sidebar_AlertsReports"]</span>
            </a>

            <a asp-controller="Users"
               asp-action="Index"
               title="@SharedLocalizer["Sidebar_UserManagement"]"
               class="@navClass(new[] { "Users" })">
                <span class="@iconClass">
                    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                        <path d="M16 21v-2a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v2" />
                        <circle cx="9.5" cy="7" r="4" />
                        <path d="M20 8v6M23 11h-6" />
                    </svg>
                </span>
                <span class="@labelClass">@SharedLocalizer["Sidebar_UserManagement"]</span>
            </a>

            <a asp-controller="SessionEvents"
               asp-action="Index"
               title="@SharedLocalizer["Sidebar_RecentEvents"]"
               class="@navClass(new[] { "SessionEvents" })">
                <span class="@iconClass font-display text-[10px]">EV</span>
                <span class="@labelClass">@SharedLocalizer["Sidebar_RecentEvents"]</span>
            </a>

            <a asp-controller="SessionEventAnalytics"
               asp-action="Index"
               title="@SharedLocalizer["Sidebar_EventAnalytics"]"
               class="@navClass(new[] { "SessionEventAnalytics" })">
                <span class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-md border border-amber-500/30 bg-black font-display text-[10px] text-amber-300">AN</span>
                <span class="@labelClass">@SharedLocalizer["Sidebar_EventAnalytics"]</span>
            </a>

            <a asp-controller="LiveOperations"
               asp-action="Index"
               title="@SharedLocalizer["Sidebar_LiveOperations"]"
               class="@navClass(new[] { "LiveOperations" })">
                <span class="@iconClass font-display text-[10px]">OP</span>
                <span class="@labelClass">@SharedLocalizer["Sidebar_LiveOperations"]</span>
            </a>
        }
    </nav>

    <div class="mt-4 shrink-0">
        @if (isAdmin)
        {
            <div data-discord-relay-status
                 data-status-url="@Url.Action("Discord", "SystemStatus")"
                 data-label-operational="@SharedLocalizer["Discord_Operational"]"
                 data-label-disabled="@SharedLocalizer["Discord_Disabled"]"
                 data-label-misconfigured="@SharedLocalizer["Discord_Misconfigured"]"
                 data-label-unavailable="@SharedLocalizer["Discord_Unavailable"]"
                 title="@SharedLocalizer["Discord_RelayLabel"]"
                 class="mb-2 flex h-12 items-center gap-3 overflow-hidden rounded-md border border-green-500/15 bg-green-500/[0.03] px-3">
                <span data-discord-relay-dot
                      class="h-2 w-2 shrink-0 rounded-full bg-slate-600">
                </span>

                <span class="min-w-max whitespace-nowrap text-[9px] font-bold uppercase tracking-[0.14em] text-slate-600 transition-all duration-200 xl:max-w-0 xl:overflow-hidden xl:opacity-0 xl:group-hover/sidebar:max-w-[15rem] xl:group-hover/sidebar:opacity-100">
                    &gt; @SharedLocalizer["Discord_RelayLabel"]:
                    <strong data-discord-relay-label
                            class="text-slate-500">
                        CHECKING
                    </strong>
                </span>
            </div>
        }

        <details data-echo-dropdown
                 class="group relative">
            <summary title="@SharedLocalizer["Topbar_Language"]"
                     class="flex h-14 w-full cursor-pointer flex-nowrap items-center gap-3 overflow-hidden rounded-md border border-green-500/20 bg-green-500/5 px-2.5 text-left transition hover:border-green-400/40 hover:bg-green-500/10">
                <span class="@iconClass">
                    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                        <circle cx="12" cy="12" r="9" />
                        <path d="M3 12h18M12 3a15 15 0 0 1 0 18M12 3a15 15 0 0 0 0 18" />
                    </svg>
                </span>

                <span class="min-w-max overflow-hidden whitespace-nowrap transition-all duration-200 xl:max-w-0 xl:opacity-0 xl:group-hover/sidebar:max-w-[12rem] xl:group-hover/sidebar:opacity-100">
                    <span class="block text-[10px] uppercase tracking-[0.2em] text-slate-600">
                        @SharedLocalizer["Topbar_Language"]
                    </span>
                    <span class="mt-0.5 block truncate text-xs font-bold text-green-200">
                        @currentCultureLabel
                    </span>
                </span>

                <svg class="ml-auto hidden h-4 w-4 shrink-0 text-green-500 transition group-open:rotate-180 xl:group-hover/sidebar:block"
                     viewBox="0 0 24 24"
                     fill="none"
                     stroke="currentColor"
                     stroke-width="1.8"
                     aria-hidden="true">
                    <path d="m6 9 6 6 6-6" />
                </svg>
            </summary>

            <div class="absolute bottom-[calc(100%+0.65rem)] left-0 z-50 w-64 overflow-hidden rounded-lg border border-green-500/30 bg-black p-2 shadow-phosphor-strong">
                <div class="px-3 pb-2 pt-1 text-[10px] font-bold uppercase tracking-[0.22em] text-slate-600">
                    @SharedLocalizer["Sidebar_SelectLanguage"]
                </div>

                <form asp-controller="Culture"
                      asp-action="Set"
                      method="post"
                      class="m-0">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="culture" value="en" />
                    <input type="hidden" name="returnUrl" value="@returnUrl" />

                    <button type="submit"
                            class="flex w-full items-center justify-between rounded-md px-3 py-3 text-left transition @(currentCulture == "en" ? "bg-green-500/10 text-green-100" : "text-slate-400 hover:bg-green-500/10 hover:text-green-100")">
                        <span>
                            <span class="block text-sm font-bold">English</span>
                            <span class="mt-0.5 block text-[10px] text-slate-600">EN</span>
                        </span>

                        @if (currentCulture == "en")
                        {
                            <span class="text-green-400">[OK]</span>
                        }
                    </button>
                </form>

                <form asp-controller="Culture"
                      asp-action="Set"
                      method="post"
                      class="m-0 mt-1">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="culture" value="es" />
                    <input type="hidden" name="returnUrl" value="@returnUrl" />

                    <button type="submit"
                            class="flex w-full items-center justify-between rounded-md px-3 py-3 text-left transition @(currentCulture == "es" ? "bg-amber-500/10 text-amber-100" : "text-slate-400 hover:bg-amber-500/10 hover:text-amber-100")">
                        <span>
                            <span class="block text-sm font-bold">Español</span>
                            <span class="mt-0.5 block text-[10px] text-slate-600">ES</span>
                        </span>

                        @if (currentCulture == "es")
                        {
                            <span class="text-amber-400">[OK]</span>
                        }
                    </button>
                </form>
            </div>
        </details>
    </div>
</div>
