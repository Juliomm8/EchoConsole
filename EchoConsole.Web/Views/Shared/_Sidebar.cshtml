@using System.Globalization

@{
    var currentController =
        ViewContext.RouteData.Values["controller"]?.ToString()
        ?? string.Empty;

    var isAuthenticated =
        User.Identity?.IsAuthenticated ?? false;

    var isAdmin = User.IsInRole("Admin");

    var currentCulture =
        CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "es"
            ? "es"
            : "en";

    var currentCultureLabel = currentCulture == "es"
        ? SharedLocalizer["Culture_Spanish"].Value
        : SharedLocalizer["Culture_English"].Value;

    var returnUrl =
        $"{Context.Request.PathBase}{Context.Request.Path}{Context.Request.QueryString}";

    Func<string[], string> navClass = controllers =>
        controllers.Any(controller =>
            string.Equals(
                currentController,
                controller,
                StringComparison.OrdinalIgnoreCase))
            ? "group flex items-center gap-3 rounded-xl border border-cyan-400/25 bg-cyan-500/10 px-4 py-3 text-cyan-200 shadow-neon transition"
            : "group flex items-center gap-3 rounded-xl border border-transparent px-4 py-3 text-slate-400 transition hover:border-cyan-400/15 hover:bg-slate-900/70 hover:text-slate-100";

    var accessLabel = isAdmin
        ? SharedLocalizer["Sidebar_RoleAdmin"].Value
        : isAuthenticated
            ? SharedLocalizer["Sidebar_RoleUser"].Value
            : SharedLocalizer["Sidebar_RoleGuest"].Value;
}

<div class="flex h-full min-h-0 flex-col p-5">
    <div class="glass-panel neon-border shrink-0 rounded-2xl px-5 py-6">
        <div class="font-display text-4xl uppercase tracking-[0.16em] text-cyan-300 text-glow-cyan">
            Echo
        </div>
        <div class="font-display text-3xl uppercase tracking-[0.16em] text-cyan-300 text-glow-cyan">
            Console
        </div>
        <div class="mt-2 font-display text-sm uppercase tracking-[0.42em] text-fuchsia-300 text-glow-magenta">
            .Web
        </div>

        <div class="mt-5 h-px bg-gradient-to-r from-cyan-400/40 via-fuchsia-400/20 to-transparent"></div>

        <div class="mt-5">
            <div class="font-display text-xs uppercase tracking-[0.36em] text-slate-500">
                @SharedLocalizer["Sidebar_Navigation"]
            </div>
            <div class="mt-2 text-sm text-slate-400">
                @SharedLocalizer["Sidebar_Description"]
            </div>
        </div>
    </div>

    <nav class="mt-6 min-h-0 flex-1 space-y-2 overflow-y-auto pr-1">
        <a asp-controller="Home"
           asp-action="Index"
           class="@navClass(new[] { "Home" })">
            <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-cyan-400/20 bg-slate-900/90 text-cyan-300">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                    <path d="M3 10.5 12 3l9 7.5" />
                    <path d="M5 9.5V21h14V9.5" />
                </svg>
            </span>
            <span class="font-medium">@SharedLocalizer["Sidebar_Home"]</span>
        </a>

        @if (!isAuthenticated)
        {
            <a asp-controller="Auth"
               asp-action="Login"
               class="@navClass(new[] { "Auth" })">
                <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-cyan-400/20 bg-slate-900/90 text-cyan-300">
                    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4" />
                        <path d="M10 17l5-5-5-5" />
                        <path d="M15 12H3" />
                    </svg>
                </span>
                <span class="font-medium">@SharedLocalizer["Common_Login"]</span>
            </a>

            <a asp-controller="Auth"
               asp-action="Register"
               class="@navClass(new[] { "Auth" })">
                <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-fuchsia-400/20 bg-slate-900/90 text-fuchsia-300">
                    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M16 21v-2a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v2" />
                        <circle cx="9.5" cy="7" r="4" />
                        <path d="M20 8v6M23 11h-6" />
                    </svg>
                </span>
                <span class="font-medium">@SharedLocalizer["Common_Register"]</span>
            </a>
        }
        else if (!isAdmin)
        {
            <a asp-controller="Profile"
               asp-action="Index"
               class="@navClass(new[] { "Profile" })">
                <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-fuchsia-400/20 bg-slate-900/90 text-fuchsia-300">
                    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <circle cx="12" cy="8" r="4" />
                        <path d="M4 21a8 8 0 0 1 16 0" />
                    </svg>
                </span>
                <span class="font-medium">@SharedLocalizer["Sidebar_Profile"]</span>
            </a>
        }
        else
        {
            <a asp-controller="Dashboard"
               asp-action="Index"
               class="@navClass(new[] { "Dashboard" })">
                <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-cyan-400/20 bg-slate-900/90 text-cyan-300">
                    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M4 4h7v7H4zM13 4h7v4h-7zM13 10h7v10h-7zM4 13h7v7H4z" />
                    </svg>
                </span>
                <span class="font-medium">@SharedLocalizer["Sidebar_LiveMonitoring"]</span>
            </a>

            <a asp-controller="Builds"
               asp-action="Index"
               class="@navClass(new[] { "Builds" })">
                <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-cyan-400/20 bg-slate-900/90 text-cyan-300">
                    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M8 4h8M8 8h8M4 12h16M7 16h10M9 20h6" />
                    </svg>
                </span>
                <span class="font-medium">@SharedLocalizer["Sidebar_GamesBuilds"]</span>
            </a>

            <a asp-controller="Installations"
               asp-action="Index"
               class="@navClass(new[] { "Installations" })">
                <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-cyan-400/20 bg-slate-900/90 text-cyan-300">
                    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <rect x="4" y="5" width="16" height="11" rx="2" />
                        <path d="M8 20h8M10 16v4M14 16v4" />
                    </svg>
                </span>
                <span class="font-medium">@SharedLocalizer["Sidebar_DevicesInstallations"]</span>
            </a>

            <a asp-controller="Alerts"
               asp-action="Index"
               class="@navClass(new[] { "Alerts" })">
                <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-cyan-400/20 bg-slate-900/90 text-cyan-300">
                    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M12 9v4M12 17h.01" />
                        <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0Z" />
                    </svg>
                </span>
                <span class="font-medium">@SharedLocalizer["Sidebar_AlertsReports"]</span>
            </a>

            <a asp-controller="Users"
               asp-action="Index"
               class="@navClass(new[] { "Users" })">
                <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-cyan-400/20 bg-slate-900/90 text-cyan-300">
                    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M16 21v-2a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v2" />
                        <circle cx="9.5" cy="7" r="4" />
                        <path d="M20 8v6M23 11h-6" />
                    </svg>
                </span>
                <span class="font-medium">@SharedLocalizer["Sidebar_UserManagement"]</span>
            </a>

            <a asp-controller="SessionEvents"
               asp-action="Index"
               class="@navClass(new[] { "SessionEvents" })">
                <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-fuchsia-400/20 bg-slate-900/90 font-display text-[10px] text-fuchsia-300">
                    EV
                </span>
                <span class="font-medium">@SharedLocalizer["Sidebar_RecentEvents"]</span>
            </a>

            <a asp-controller="SessionEventAnalytics"
               asp-action="Index"
               class="@navClass(new[] { "SessionEventAnalytics" })">
                <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-amber-400/20 bg-slate-900/90 font-display text-[10px] text-amber-300">
                    AN
                </span>
                <span class="font-medium">@SharedLocalizer["Sidebar_EventAnalytics"]</span>
            </a>

            <a asp-controller="LiveOperations"
               asp-action="Index"
               class="@navClass(new[] { "LiveOperations" })">
                <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-emerald-400/20 bg-slate-900/90 font-display text-[10px] text-emerald-300">
                    OP
                </span>
                <span class="font-medium">@SharedLocalizer["Sidebar_LiveOperations"]</span>
            </a>
        }
    </nav>

    <div class="mt-6 shrink-0 space-y-3">
        <div class="glass-panel neon-border-magenta rounded-2xl p-5">
            <div class="font-display text-2xl uppercase tracking-[0.12em] text-fuchsia-300 text-glow-magenta">
                Cosmic Diner
            </div>

            @if (!isAuthenticated)
            {
                <p class="mt-2 text-sm text-slate-400">
                    @SharedLocalizer["Sidebar_GuestDescription"]
                </p>
            }
            else if (!isAdmin)
            {
                <p class="mt-2 text-sm text-slate-400">
                    @SharedLocalizer["Sidebar_UserDescription"]
                </p>
            }
            else
            {
                <p class="mt-2 text-sm text-slate-400">
                    @SharedLocalizer["Sidebar_AdminDescription"]
                </p>
            }

            <div class="mt-4 grid grid-cols-2 gap-3">
                <div class="rounded-xl border border-cyan-400/15 bg-slate-900/80 p-3">
                    <div class="font-display text-xs uppercase tracking-[0.24em] text-slate-500">
                        @SharedLocalizer["Sidebar_Access"]
                    </div>
                    <div class="mt-1 text-sm font-semibold text-cyan-200">
                        @accessLabel
                    </div>
                </div>

                <div class="rounded-xl border border-cyan-400/15 bg-slate-900/80 p-3">
                    <div class="font-display text-xs uppercase tracking-[0.24em] text-slate-500">
                        @SharedLocalizer["Sidebar_Mode"]
                    </div>
                    <div class="mt-1 text-sm font-semibold text-cyan-200">
                        @SharedLocalizer["Sidebar_Product"]
                    </div>
                </div>
            </div>
        </div>

        <details class="group relative">
            <summary class="flex cursor-pointer list-none items-center justify-between rounded-2xl border border-cyan-500/15 bg-slate-950/90 px-4 py-3 text-left transition hover:border-cyan-400/30 hover:bg-slate-900/90 [&::-webkit-details-marker]:hidden">
                <div class="flex min-w-0 items-center gap-3">
                    <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-cyan-400/20 bg-cyan-500/10 text-cyan-300">
                        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                            <circle cx="12" cy="12" r="9" />
                            <path d="M3 12h18M12 3a15 15 0 0 1 0 18M12 3a15 15 0 0 0 0 18" />
                        </svg>
                    </span>

                    <span class="min-w-0">
                        <span class="block font-display text-[10px] uppercase tracking-[0.24em] text-slate-500">
                            @SharedLocalizer["Topbar_Language"]
                        </span>
                        <span class="mt-1 block truncate text-sm font-semibold text-slate-200">
                            @currentCultureLabel
                        </span>
                    </span>
                </div>

                <svg class="h-4 w-4 shrink-0 text-slate-500 transition group-open:rotate-180"
                     viewBox="0 0 24 24"
                     fill="none"
                     stroke="currentColor"
                     stroke-width="1.8">
                    <path d="m6 9 6 6 6-6" />
                </svg>
            </summary>

            <div class="absolute bottom-[calc(100%+0.75rem)] left-0 right-0 z-50 overflow-hidden rounded-2xl border border-cyan-400/20 bg-slate-950/95 p-2 shadow-[0_0_40px_rgba(34,211,238,0.12)] backdrop-blur-xl">
                <div class="px-3 pb-2 pt-1 font-display text-[10px] uppercase tracking-[0.24em] text-slate-500">
                    @SharedLocalizer["Sidebar_SelectLanguage"]
                </div>

                <form asp-controller="Culture"
                      asp-action="Set"
                      method="post"
                      class="m-0">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="culture" value="en" />
                    <input type="hidden" name="returnUrl" value="@returnUrl" />

                    <button type="submit"
                            class="flex w-full items-center justify-between rounded-xl px-3 py-3 text-left transition @(currentCulture == "en" ? "bg-cyan-500/10 text-cyan-200" : "text-slate-300 hover:bg-slate-900")">
                        <span>
                            <span class="block text-sm font-semibold">English</span>
                            <span class="mt-0.5 block text-xs text-slate-500">EN</span>
                        </span>

                        @if (currentCulture == "en")
                        {
                            <span class="flex h-6 w-6 items-center justify-center rounded-full bg-cyan-400 text-xs font-bold text-slate-950">✓</span>
                        }
                    </button>
                </form>

                <form asp-controller="Culture"
                      asp-action="Set"
                      method="post"
                      class="m-0 mt-1">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="culture" value="es" />
                    <input type="hidden" name="returnUrl" value="@returnUrl" />

                    <button type="submit"
                            class="flex w-full items-center justify-between rounded-xl px-3 py-3 text-left transition @(currentCulture == "es" ? "bg-fuchsia-500/10 text-fuchsia-200" : "text-slate-300 hover:bg-slate-900")">
                        <span>
                            <span class="block text-sm font-semibold">Español</span>
                            <span class="mt-0.5 block text-xs text-slate-500">ES</span>
                        </span>

                        @if (currentCulture == "es")
                        {
                            <span class="flex h-6 w-6 items-center justify-center rounded-full bg-fuchsia-400 text-xs font-bold text-slate-950">✓</span>
                        }
                    </button>
                </form>
            </div>
        </details>
    </div>
</div>
