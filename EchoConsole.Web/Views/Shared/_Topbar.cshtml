@using System.Security.Claims
@using EchoConsole.Web.Services.Profile

@{
    var fallbackTitle =
        ViewData["Title"]?.ToString()
        ?? SharedLocalizer["Home_PageTitle"].Value;

    var titleResourceKey =
        ViewData["TitleResourceKey"]?.ToString();

    var currentTitle = fallbackTitle;

    if (!string.IsNullOrWhiteSpace(titleResourceKey))
    {
        var localizedTitle = SharedLocalizer[titleResourceKey];

        if (!localizedTitle.IsResourceNotFound)
        {
            currentTitle = localizedTitle.Value;
        }
    }

    var isAuthenticated =
        User.Identity?.IsAuthenticated ?? false;

    var alias =
        User.FindFirst("alias")?.Value
        ?? User.Identity?.Name
        ?? SharedLocalizer["Common_User"].Value;

    var role =
        User.FindFirst(ClaimTypes.Role)?.Value
        ?? "User";

    var roleLabel = role switch
    {
        "Admin" => SharedLocalizer["Role_Admin"].Value,
        "Moderator" => SharedLocalizer["Role_Moderator"].Value,
        "Viewer" => SharedLocalizer["Role_Viewer"].Value,
        _ => SharedLocalizer["Role_User"].Value
    };

    var avatarKey = isAuthenticated
        ? ProfileCatalog.NormalizeStoredAvatarKey(
            User.FindFirst("avatar")?.Value)
        : ProfileCatalog.DefaultAvatarKey;

    var avatarUrl =
        Url.Content(
            $"~/images/avatars/{avatarKey}.png");

    var fallbackAvatarUrl =
        Url.Content(
            "~/images/avatars/avatar_01.png");
}

<header class="sticky top-0 z-40 border-b border-green-500/15 bg-black/90 backdrop-blur-xl">
    <div class="px-4 py-3 sm:px-6 xl:px-8">
        <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
            <div class="min-w-0">
                <div class="font-display text-[10px] uppercase tracking-[0.32em] text-green-500">
                    @SharedLocalizer["Topbar_Station"]
                </div>

                <div class="mt-1 truncate font-display text-xl uppercase tracking-[0.12em] text-green-100 text-glow-cyan sm:text-2xl">
                    &gt; @currentTitle
                </div>
            </div>

            <div class="flex flex-wrap items-center gap-3">
                <div class="inline-flex items-center gap-3 rounded-lg border border-green-500/25 bg-green-500/5 px-3 py-2.5">
                    <span class="h-2.5 w-2.5 rounded-full bg-green-400 shadow-phosphor animate-signal-pulse"></span>

                    <div>
                        <div class="font-display text-[10px] uppercase tracking-[0.24em] text-green-300">
                            @SharedLocalizer["Topbar_Live"]
                        </div>

                        <div id="topbar-server-time"
                             class="text-[10px] text-slate-500">
                            @SharedLocalizer["Topbar_PlatformOnline"]
                        </div>
                    </div>
                </div>

                @if (!isAuthenticated)
                {
                    <a asp-controller="Auth"
                       asp-action="Login"
                       class="terminal-button py-2.5">
                        @SharedLocalizer["Common_Login"]
                    </a>

                    <a asp-controller="Auth"
                       asp-action="Register"
                       class="terminal-button-secondary py-2.5">
                        @SharedLocalizer["Common_Register"]
                    </a>
                }
                else
                {
                    <details data-echo-dropdown
                             class="group relative">
                        <summary class="flex cursor-pointer items-center gap-3 rounded-lg border border-green-500/20 bg-green-500/5 px-3 py-2 transition hover:border-green-400/40 hover:bg-green-500/10">
                            <span class="h-10 w-10 shrink-0 overflow-hidden rounded-md border border-green-400/30 bg-black shadow-phosphor">
                                <img src="@avatarUrl"
                                     alt="@alias"
                                     data-user-avatar-image
                                     class="h-full w-full object-cover"
                                     width="40"
                                     height="40"
                                     onerror="this.onerror=null;this.src='@fallbackAvatarUrl';" />
                            </span>

                            <span class="hidden min-w-0 sm:block">
                                <span class="block max-w-40 truncate font-display text-xs uppercase tracking-[0.16em] text-green-100">
                                    @alias
                                </span>
                                <span class="mt-0.5 block text-[10px] uppercase tracking-[0.16em] text-slate-500">
                                    @roleLabel
                                </span>
                            </span>

                            <svg class="h-4 w-4 text-green-500 transition group-open:rotate-180"
                                 viewBox="0 0 24 24"
                                 fill="none"
                                 stroke="currentColor"
                                 stroke-width="1.8"
                                 aria-hidden="true">
                                <path d="m6 9 6 6 6-6" />
                            </svg>
                        </summary>

                        <div class="absolute right-0 top-[calc(100%+0.75rem)] z-50 w-72 overflow-hidden rounded-lg border border-green-400/40 bg-black p-2 shadow-[0_0_34px_rgba(57,255,20,0.22)] ring-1 ring-green-500/10 isolate">
                            <div class="border-b border-green-500/15 px-3 pb-3 pt-2">
                                <div class="text-[10px] uppercase tracking-[0.24em] text-slate-600">
                                    @SharedLocalizer["Topbar_UserMenu"]
                                </div>
                                <div class="mt-1 truncate text-sm font-bold text-green-200">
                                    @alias
                                </div>
                            </div>

                            <a asp-controller="Profile"
                               asp-action="Index"
                               class="mt-2 flex items-center gap-3 rounded-md px-3 py-3 text-sm text-slate-300 transition hover:bg-green-500/10 hover:text-green-100">
                                <svg class="h-4 w-4 text-green-400"
                                     viewBox="0 0 24 24"
                                     fill="none"
                                     stroke="currentColor"
                                     stroke-width="1.8"
                                     aria-hidden="true">
                                    <circle cx="12" cy="8" r="4" />
                                    <path d="M4 21a8 8 0 0 1 16 0" />
                                </svg>
                                <span>@SharedLocalizer["Topbar_MyProfile"]</span>
                            </a>

                            <a asp-controller="ProfileSettings"
                               asp-action="Index"
                               class="flex items-center gap-3 rounded-md px-3 py-3 text-sm text-slate-300 transition hover:bg-amber-500/10 hover:text-amber-100">
                                <svg class="h-4 w-4 text-amber-400"
                                     viewBox="0 0 24 24"
                                     fill="none"
                                     stroke="currentColor"
                                     stroke-width="1.8"
                                     aria-hidden="true">
                                    <circle cx="12" cy="12" r="3" />
                                    <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06-2.12 2.12-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V20h-3v-.09a1.65 1.65 0 0 0-1-1.51 1.65 1.65 0 0 0-1.82.33l-.06.06-2.12-2.12.06-.06A1.65 1.65 0 0 0 7.2 15a1.65 1.65 0 0 0-1.51-1H5.6v-3h.09A1.65 1.65 0 0 0 7.2 10a1.65 1.65 0 0 0-.33-1.82l-.06-.06L8.93 6l.06.06a1.65 1.65 0 0 0 1.82.33h.01a1.65 1.65 0 0 0 1-1.51V4.8h3v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06 2.12 2.12-.06.06a1.65 1.65 0 0 0-.33 1.82v.01a1.65 1.65 0 0 0 1.51 1h.09v3h-.09A1.65 1.65 0 0 0 19.4 15Z" />
                                </svg>
                                <span>@SharedLocalizer["Topbar_Settings"]</span>
                            </a>

                            <div class="my-2 h-px bg-green-500/10"></div>

                            <form asp-controller="Auth"
                                  asp-action="LogoutPost"
                                  method="post"
                                  class="m-0">
                                @Html.AntiForgeryToken()

                                <button type="submit"
                                        class="flex w-full items-center gap-3 rounded-md px-3 py-3 text-left text-sm text-rose-300 transition hover:bg-rose-500/10 hover:text-rose-200">
                                    <svg class="h-4 w-4"
                                         viewBox="0 0 24 24"
                                         fill="none"
                                         stroke="currentColor"
                                         stroke-width="1.8"
                                         aria-hidden="true">
                                        <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4" />
                                        <path d="m10 17 5-5-5-5M15 12H3" />
                                    </svg>
                                    <span>@SharedLocalizer["Common_Logout"]</span>
                                </button>
                            </form>
                        </div>
                    </details>
                }
            </div>
        </div>
    </div>
</header>
