@{
    var currentTitle = ViewData["Title"]?.ToString() ?? "Dashboard";
}

<header class="sticky top-0 z-40 border-b border-cyan-500/10 bg-slate-950/80 backdrop-blur-xl">
    <div class="px-4 py-4 sm:px-6 xl:px-8">
        <div class="flex flex-col gap-4 xl:flex-row xl:items-center xl:justify-between">
            <div class="flex items-center gap-4">
                <button type="button" class="inline-flex h-12 w-12 items-center justify-center rounded-xl border border-cyan-400/20 bg-slate-900/80 text-cyan-300 xl:hidden">
                    <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M4 7h16M4 12h16M4 17h16" />
                    </svg>
                </button>

                <div>
                    <div class="font-display text-xs uppercase tracking-[0.34em] text-cyan-400" data-i18n="topbar_station">
                        Telemetry Control Station
                    </div>
                    <div class="mt-1 font-display text-2xl uppercase tracking-[0.14em] text-white">
                        @currentTitle
                    </div>
                </div>
            </div>

            <div class="flex flex-wrap items-center gap-3">
                <div class="inline-flex items-center gap-3 rounded-2xl border border-emerald-500/25 bg-emerald-500/10 px-4 py-3">
                    <span class="h-2.5 w-2.5 rounded-full bg-emerald-400"></span>
                    <div>
                        <div class="font-display text-xs uppercase tracking-[0.28em] text-emerald-300" data-i18n="topbar_live">
                            Live
                        </div>
                        <div class="text-xs text-slate-400" data-i18n="topbar_stream_label">
                            Telemetry stream active
                        </div>
                    </div>
                </div>

                <div class="rounded-2xl border border-cyan-400/15 bg-slate-900/80 px-4 py-3">
                    <div class="font-display text-xs uppercase tracking-[0.28em] text-slate-500" data-i18n="topbar_server_time">
                        Server Time
                    </div>
                    <div id="topbar-server-time-value" class="mt-1 font-display text-sm uppercase tracking-[0.08em] text-cyan-200">
                        --:--:--
                    </div>
                </div>

                <div class="rounded-2xl border border-cyan-400/15 bg-slate-900/80 p-1">
                    <div class="flex items-center gap-1">
                        <span class="px-3 text-xs font-semibold uppercase tracking-[0.24em] text-slate-500" data-i18n="topbar_language">
                            Language
                        </span>

                        <button id="lang-toggle-en"
                                type="button"
                                data-lang="en"
                                class="rounded-xl border border-cyan-400/40 bg-cyan-500/15 px-3 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-cyan-200 transition">
                            EN
                        </button>

                        <button id="lang-toggle-es"
                                type="button"
                                data-lang="es"
                                class="rounded-xl border border-slate-700 bg-transparent px-3 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-400 transition hover:text-slate-200">
                            ES
                        </button>
                    </div>
                </div>

                <div class="inline-flex items-center gap-3 rounded-2xl border border-fuchsia-400/15 bg-slate-900/80 px-4 py-3">
                    <div class="flex h-11 w-11 items-center justify-center rounded-full border border-fuchsia-400/25 bg-fuchsia-500/10 font-display text-sm uppercase tracking-[0.2em] text-fuchsia-200">
                        SA
                    </div>
                    <div>
                        <div class="font-display text-xs uppercase tracking-[0.24em] text-white">SysAdmin</div>
                        <div class="text-xs text-slate-400" data-i18n="topbar_admin_role">Administrator</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</header>