@{
    var socialLinks = new[]
    {
        new
        {
            Name = "Instagram",
            Url = "https://www.instagram.com/dark.sky.studios.dev?utm_source=ig_web_button_share_sheet&igsh=ZDNlZDc0MzIxNw=="
        },
        new
        {
            Name = "TikTok",
            Url = "https://www.tiktok.com/@team_darksky_dev?is_from_webapp=1&sender_device=pc"
        },
        new
        {
            Name = "YouTube",
            Url = "https://youtube.com/@darkskystudios-x5k?si=0oiN4atoGiwFtC-r"
        },
        new
        {
            Name = "X",
            Url = "https://x.com/teamdarkskydev?s=20"
        }
    };
}

<footer class="border-t border-green-500/15 bg-black px-5 py-6 sm:px-8">
    <div class="mx-auto flex max-w-[1700px] flex-col gap-5 lg:flex-row lg:items-center lg:justify-between">
        <div>
            <div class="font-display text-xs uppercase tracking-[0.28em] text-green-400">
                @SharedLocalizer["Footer_Transmission"]
            </div>
            <p class="mt-2 max-w-2xl text-xs leading-6 text-slate-500">
                @SharedLocalizer["Footer_Description"]
            </p>
        </div>

        <div class="flex flex-col gap-3 lg:items-end">
            <div class="text-[10px] font-bold uppercase tracking-[0.24em] text-slate-600">
                @SharedLocalizer["Footer_Follow"]
            </div>

            <nav class="flex flex-wrap gap-x-5 gap-y-3"
                 aria-label="@SharedLocalizer["Footer_Follow"]">
                @foreach (var social in socialLinks)
                {
                    <a href="@social.Url"
                       target="_blank"
                       rel="noopener noreferrer"
                       aria-label="@social.Name"
                       title="@social.Name"
                       class="footer-link group">
                        <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center text-green-400 transition-all duration-200 group-hover:text-green-200 group-hover:drop-shadow-[0_0_8px_rgba(57,255,20,0.9)]">
                            @if (social.Name == "Instagram")
                            {
                                <svg class="h-5 w-5"
                                     viewBox="0 0 24 24"
                                     fill="none"
                                     stroke="currentColor"
                                     stroke-width="1.8"
                                     stroke-linecap="round"
                                     stroke-linejoin="round"
                                     aria-hidden="true">
                                    <rect x="3" y="3" width="18" height="18" rx="5" />
                                    <circle cx="12" cy="12" r="4" />
                                    <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
                                </svg>
                            }
                            else if (social.Name == "TikTok")
                            {
                                <svg class="h-5 w-5"
                                     viewBox="0 0 24 24"
                                     fill="none"
                                     stroke="currentColor"
                                     stroke-width="1.8"
                                     stroke-linecap="round"
                                     stroke-linejoin="round"
                                     aria-hidden="true">
                                    <path d="M14 4v10.25a4.25 4.25 0 1 1-3.2-4.12" />
                                    <path d="M14 4c.55 2.9 2.25 4.5 5 5" />
                                </svg>
                            }
                            else if (social.Name == "YouTube")
                            {
                                <svg class="h-5 w-5"
                                     viewBox="0 0 24 24"
                                     fill="none"
                                     stroke="currentColor"
                                     stroke-width="1.8"
                                     stroke-linecap="round"
                                     stroke-linejoin="round"
                                     aria-hidden="true">
                                    <path d="M21 12c0-2.4-.3-4.4-.7-5.3a2.5 2.5 0 0 0-1.5-1.5C17.9 4.8 15.3 4.5 12 4.5s-5.9.3-6.8.7a2.5 2.5 0 0 0-1.5 1.5C3.3 7.6 3 9.6 3 12s.3 4.4.7 5.3a2.5 2.5 0 0 0 1.5 1.5c.9.4 3.5.7 6.8.7s5.9-.3 6.8-.7a2.5 2.5 0 0 0 1.5-1.5c.4-.9.7-2.9.7-5.3Z" />
                                    <path d="m10 9 5 3-5 3Z" fill="currentColor" stroke="none" />
                                </svg>
                            }
                            else
                            {
                                <svg class="h-5 w-5"
                                     viewBox="0 0 24 24"
                                     fill="none"
                                     stroke="currentColor"
                                     stroke-width="1.8"
                                     stroke-linecap="round"
                                     stroke-linejoin="round"
                                     aria-hidden="true">
                                    <path d="M5 4 19 20" />
                                    <path d="M19 4 5 20" />
                                </svg>
                            }
                        </span>

                        <span>@social.Name</span>
                    </a>
                }
            </nav>
        </div>
    </div>

    <div class="mx-auto mt-5 flex max-w-[1700px] flex-col gap-2 border-t border-green-500/10 pt-4 text-[10px] uppercase tracking-[0.16em] text-slate-700 sm:flex-row sm:items-center sm:justify-between">
        <span>@SharedLocalizer["Footer_Rights", DateTime.UtcNow.Year]</span>
        <span>ECHOCONSOLE // COSMIC DINER // SIGNAL LOCKED</span>
    </div>
</footer>
