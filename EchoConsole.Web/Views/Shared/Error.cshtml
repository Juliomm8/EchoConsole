@model ErrorViewModel
@{
    ViewData["Title"] = SharedLocalizer["Error_PageTitle"].Value;
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="flex min-h-screen items-center justify-center px-4 py-20 sm:px-6">
    <div class="w-full max-w-3xl rounded-3xl border border-amber-400/25 bg-slate-950/85 p-8 text-center shadow-[0_0_50px_rgba(251,191,36,0.07)] backdrop-blur-xl sm:p-12">
        <p class="font-display text-xs uppercase tracking-[0.32em] text-amber-300">
            @SharedLocalizer["Error_Badge"]
        </p>
        <h1 class="mt-3 font-display text-3xl uppercase tracking-[0.14em] text-white">
            @SharedLocalizer["Error_Title"]
        </h1>
        <p class="mx-auto mt-5 max-w-2xl text-sm leading-7 text-slate-400">
            @SharedLocalizer["Error_Description"]
        </p>

        @if (Model.ShowRequestId)
        {
            <div class="mx-auto mt-6 max-w-xl rounded-2xl border border-slate-800 bg-slate-900/70 px-4 py-3 text-left text-xs text-slate-400">
                <span class="font-semibold text-slate-200">@SharedLocalizer["Error_RequestId"]:</span>
                <code class="ml-2 break-all text-cyan-300">@Model.RequestId</code>
            </div>
        }

        <div class="mt-8 flex flex-wrap justify-center gap-3">
            <button type="button" onclick="window.location.reload()"
                    class="rounded-xl border border-amber-400/30 bg-amber-500/15 px-5 py-3 text-sm font-bold uppercase tracking-[0.16em] text-amber-100 transition hover:bg-amber-500/25">
                @SharedLocalizer["Common_Retry"]
            </button>
            <a asp-controller="Home" asp-action="Index"
               class="rounded-xl border border-cyan-400/25 bg-cyan-500/10 px-5 py-3 text-sm font-bold uppercase tracking-[0.16em] text-cyan-100 transition hover:bg-cyan-500/20">
                @SharedLocalizer["Common_BackHome"]
            </a>
        </div>
    </div>
</div>
