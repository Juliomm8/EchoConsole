@{
    ViewData["Title"] = SharedLocalizer["Auth_AccessDeniedPageTitle"].Value;
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="flex min-h-screen items-center justify-center px-4 py-20 sm:px-6">
    <div class="w-full max-w-3xl rounded-3xl border border-rose-400/25 bg-slate-950/85 p-8 text-center shadow-[0_0_50px_rgba(251,113,133,0.08)] backdrop-blur-xl sm:p-12">
        <div class="mx-auto flex h-20 w-20 items-center justify-center rounded-full border border-rose-400/30 bg-rose-500/10 text-rose-300">
            <svg class="h-10 w-10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                <path d="M12 9v4M12 17h.01" />
                <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0Z" />
            </svg>
        </div>

        <p class="mt-8 font-display text-xs uppercase tracking-[0.32em] text-rose-300">
            @SharedLocalizer["Auth_SecurityGate"]
        </p>
        <h1 class="mt-3 font-display text-3xl uppercase tracking-[0.14em] text-white">
            @SharedLocalizer["Auth_RestrictedAccess"]
        </h1>
        <p class="mx-auto mt-5 max-w-2xl text-sm leading-7 text-slate-400">
            @SharedLocalizer["Auth_AccessDeniedDescription"]
        </p>

        <div class="mt-8 flex flex-wrap justify-center gap-3">
            <a asp-controller="Home" asp-action="Index"
               class="rounded-xl border border-cyan-400/30 bg-cyan-500/15 px-5 py-3 text-sm font-bold uppercase tracking-[0.16em] text-cyan-100 transition hover:bg-cyan-500/25">
                @SharedLocalizer["Common_BackHome"]
            </a>
            <a asp-controller="Auth" asp-action="Login"
               class="rounded-xl border border-slate-700 bg-slate-900/80 px-5 py-3 text-sm font-bold uppercase tracking-[0.16em] text-slate-300 transition hover:border-fuchsia-400/30 hover:text-white">
                @SharedLocalizer["Common_Login"]
            </a>
        </div>
    </div>
</div>
