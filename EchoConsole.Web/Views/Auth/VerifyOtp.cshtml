@model EchoConsole.Web.Models.Auth.VerifyOtpViewModel

@{
    ViewData["Title"] = "VERIFY TERMINAL";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="flex min-h-[calc(100vh-8rem)] items-center justify-center px-4 py-20 sm:px-6">
    <div class="w-full max-w-3xl">
        <a asp-controller="Auth"
           asp-action="Login"
           class="mb-5 inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.18em] text-green-400 transition hover:text-green-200">
            <svg class="h-4 w-4"
                 viewBox="0 0 24 24"
                 fill="none"
                 stroke="currentColor"
                 stroke-width="1.8"
                 aria-hidden="true">
                <path d="m15 18-6-6 6-6" />
            </svg>
            RETURN TO ACCESS NODE
        </a>

        <section class="terminal-panel relative overflow-hidden rounded-lg p-8 sm:p-10 lg:p-12">
            <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-green-300/70"></div>
            <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(rgba(57,255,20,0.025)_1px,transparent_1px),linear-gradient(90deg,rgba(57,255,20,0.025)_1px,transparent_1px)] bg-[size:28px_28px]"></div>

            <div class="relative">
                <div class="mx-auto flex h-20 w-20 items-center justify-center rounded-full border border-green-500/35 bg-green-500/10 shadow-phosphor">
                    <svg class="h-9 w-9 text-green-300"
                         viewBox="0 0 24 24"
                         fill="none"
                         stroke="currentColor"
                         stroke-width="1.6"
                         aria-hidden="true">
                        <rect x="5" y="10" width="14" height="10" rx="2" />
                        <path d="M8 10V7a4 4 0 0 1 8 0v3" />
                        <path d="M12 14v2" />
                    </svg>
                </div>

                <div class="mt-7 text-center">
                    <p class="terminal-kicker">
                        SECURE ENROLLMENT CHANNEL
                    </p>

                    <h1 class="mt-3 font-display text-3xl uppercase tracking-[0.12em] text-green-100 text-glow-cyan sm:text-4xl">
                        VERIFY TERMINAL
                    </h1>

                    <p class="mx-auto mt-4 max-w-xl text-sm leading-7 text-slate-400">
                        Enter the six-digit authorization sequence assigned to
                        <span class="font-bold text-green-300">@Model.Email</span>.
                    </p>
                </div>

                <div class="mx-auto mt-8 max-w-xl rounded border border-green-500/15 bg-black/70 p-4 text-xs leading-6 text-slate-500">
                    <span class="text-green-400">&gt;</span>
                    OTP_CHANNEL READY<br />
                    <span class="text-green-400">&gt;</span>
                    AWAITING SIX-DIGIT SEQUENCE
                </div>

                <form asp-controller="Auth"
                      asp-action="VerifyOtp"
                      method="post"
                      novalidate
                      class="mx-auto mt-8 max-w-xl space-y-6">
                    <input asp-for="Email" type="hidden" />

                    <div asp-validation-summary="ModelOnly"
                         class="rounded border border-rose-500/25 bg-rose-500/10 px-4 py-3 text-center text-sm text-rose-200"></div>

                    <div>
                        <label asp-for="Code"
                               class="mb-3 block text-center text-[10px] font-bold uppercase tracking-[0.24em] text-green-300">
                            AUTHORIZATION CODE
                        </label>

                        <input asp-for="Code"
                               type="text"
                               inputmode="numeric"
                               autocomplete="one-time-code"
                               pattern="[0-9]{6}"
                               minlength="6"
                               maxlength="6"
                               autofocus
                               class="w-full rounded border border-slate-800 bg-black px-4 py-4 text-center font-mono text-3xl font-bold leading-normal tracking-[0.55em] text-green-300 outline-none transition placeholder:text-slate-800 focus:border-green-500/60 focus:ring-2 focus:ring-green-500/10 sm:text-4xl"
                               placeholder="000000" />

                        <span asp-validation-for="Code"
                              class="mt-3 block text-center text-xs font-bold uppercase tracking-[0.14em] text-rose-300"></span>
                    </div>

                    <button type="submit"
                            class="terminal-button flex w-full items-center justify-center gap-3 py-4">
                        <span>&gt;</span>
                        VALIDAR TERMINAL
                    </button>
                </form>

                <div class="mx-auto mt-8 max-w-xl border-t border-slate-800 pt-5 text-center text-[9px] uppercase tracking-[0.18em] text-slate-600">
                    DEVELOPMENT AUTHORIZATION PROTOCOL // ECHO CONSOLE
                </div>
            </div>
        </section>
    </div>
</div>
