@model EchoConsole.Web.Models.Auth.ResetPasswordViewModel

@{
    ViewData["Title"] =
        SharedLocalizer["Auth_ResetPasswordPageTitle"].Value;

    Layout =
        "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="flex min-h-[calc(100vh-8rem)] items-center justify-center px-4 py-20 sm:px-6">
    <div class="w-full max-w-3xl">
        <a asp-controller="Auth"
           asp-action="Login"
           class="mb-5 inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.18em] text-green-400 transition hover:text-green-200">
            <svg class="h-4 w-4"
                 viewBox="0 0 24 24"
                 fill="none"
                 stroke="currentColor"
                 stroke-width="1.8"
                 aria-hidden="true">
                <path d="m15 18-6-6 6-6" />
            </svg>

            @SharedLocalizer["Auth_ReturnToLogin"]
        </a>

        <section class="terminal-panel relative overflow-hidden rounded-lg p-8 sm:p-10 lg:p-12">
            <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-green-300/70"></div>

            <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(rgba(57,255,20,0.025)_1px,transparent_1px),linear-gradient(90deg,rgba(57,255,20,0.025)_1px,transparent_1px)] bg-[size:28px_28px]"></div>

            <div class="relative">
                <div class="mx-auto flex h-20 w-20 items-center justify-center rounded-full border border-green-500/35 bg-green-500/10 shadow-phosphor">
                    <svg class="h-9 w-9 text-green-300"
                         viewBox="0 0 24 24"
                         fill="none"
                         stroke="currentColor"
                         stroke-width="1.6"
                         aria-hidden="true">
                        <rect x="5"
                              y="10"
                              width="14"
                              height="10"
                              rx="2" />
                        <path d="M8 10V7a4 4 0 0 1 8 0v3" />
                        <path d="M12 14v2" />
                    </svg>
                </div>

                <div class="mt-7 text-center">
                    <p class="terminal-kicker">
                        @SharedLocalizer["Auth_CredentialRecoveryChannel"]
                    </p>

                    <h1 class="mt-3 font-display text-3xl uppercase tracking-[0.12em] text-green-100 text-glow-cyan sm:text-4xl">
                        @SharedLocalizer["Auth_ResetPasswordTitle"]
                    </h1>

                    <p class="mx-auto mt-4 max-w-xl text-sm leading-7 text-slate-400">
                        @SharedLocalizer["Auth_ResetPasswordDescription"]
                    </p>
                </div>

                <div class="mx-auto mt-8 max-w-xl rounded border border-green-500/15 bg-black/70 p-4 text-xs leading-6 text-slate-500">
                    @SharedLocalizer["Auth_ResetChannelReady"]<br />
                    @SharedLocalizer["Auth_AwaitingNewCredential"]
                </div>

                <form asp-controller="Auth"
                      asp-action="ResetPassword"
                      method="post"
                      novalidate
                      class="mx-auto mt-8 max-w-xl space-y-6">
                    <input asp-for="Email"
                           type="hidden" />

                    <input asp-for="Token"
                           type="hidden" />

                    <div asp-validation-summary="ModelOnly"
                         class="rounded border border-rose-500/25 bg-rose-500/10 px-4 py-3 text-sm">
                    </div>

                    <div>
                        <label asp-for="NewPassword"
                               class="mb-2 block text-xs font-bold uppercase tracking-[0.16em] text-green-200">
                            @SharedLocalizer["Auth_NewPasswordLabel"]
                        </label>

                        <div class="relative">
                            <input asp-for="NewPassword"
                                   id="resetNewPassword"
                                   autocomplete="new-password"
                                   class="auth-field pr-24"
                                   placeholder="@SharedLocalizer["Auth_NewPasswordPlaceholder"]" />

                            <button type="button"
                                    data-password-toggle
                                    data-show-label="@SharedLocalizer["Auth_ShowPassword"]"
                                    data-hide-label="@SharedLocalizer["Auth_HidePassword"]"
                                    aria-controls="resetNewPassword"
                                    aria-pressed="false"
                                    aria-label="@SharedLocalizer["Auth_ShowPassword"]"
                                    class="absolute inset-y-0 right-3 flex items-center text-[9px] font-bold uppercase tracking-[0.16em] text-green-400 transition hover:text-green-200">
                                <span data-password-toggle-label>
                                    @SharedLocalizer["Auth_ShowPassword"]
                                </span>
                            </button>
                        </div>

                        <span asp-validation-for="NewPassword"
                              class="mt-2 block text-sm">
                        </span>
                    </div>

                    <div>
                        <label asp-for="ConfirmPassword"
                               class="mb-2 block text-xs font-bold uppercase tracking-[0.16em] text-green-200">
                            @SharedLocalizer["Auth_ConfirmPasswordLabel"]
                        </label>

                        <div class="relative">
                            <input asp-for="ConfirmPassword"
                                   id="resetConfirmPassword"
                                   autocomplete="new-password"
                                   class="auth-field pr-24"
                                   placeholder="@SharedLocalizer["Auth_ConfirmPasswordPlaceholder"]" />

                            <button type="button"
                                    data-password-toggle
                                    data-show-label="@SharedLocalizer["Auth_ShowPassword"]"
                                    data-hide-label="@SharedLocalizer["Auth_HidePassword"]"
                                    aria-controls="resetConfirmPassword"
                                    aria-pressed="false"
                                    aria-label="@SharedLocalizer["Auth_ShowPassword"]"
                                    class="absolute inset-y-0 right-3 flex items-center text-[9px] font-bold uppercase tracking-[0.16em] text-green-400 transition hover:text-green-200">
                                <span data-password-toggle-label>
                                    @SharedLocalizer["Auth_ShowPassword"]
                                </span>
                            </button>
                        </div>

                        <span asp-validation-for="ConfirmPassword"
                              class="mt-2 block text-sm">
                        </span>
                    </div>

                    <button type="submit"
                            class="terminal-button flex w-full items-center justify-center gap-3 py-4">
                        <span>&gt;</span>
                        @SharedLocalizer["Auth_ResetPasswordButton"]
                    </button>
                </form>

                <div class="mx-auto mt-8 max-w-xl border-t border-slate-800 pt-5 text-center text-[9px] uppercase tracking-[0.18em] text-slate-600">
                    @SharedLocalizer["Auth_ResetProtocol"]
                </div>
            </div>
        </section>
    </div>
</div>

@section Scripts {
    <script src="~/js/password-visibility.js"
            asp-append-version="true"
            defer>
    </script>
}
