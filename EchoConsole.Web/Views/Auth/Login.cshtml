@model EchoConsole.Web.Models.Auth.LoginViewModel

@{
    ViewData["Title"] = SharedLocalizer["Auth_LoginPageTitle"].Value;
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="flex min-h-[calc(100vh-8rem)] items-center justify-center px-4 py-20 sm:px-6">
    <div class="w-full max-w-6xl">
        <a asp-controller="Home"
           asp-action="Index"
           class="mb-5 inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.18em] text-green-400 transition hover:text-green-200">
            <svg class="h-4 w-4"
                 viewBox="0 0 24 24"
                 fill="none"
                 stroke="currentColor"
                 stroke-width="1.8"
                 aria-hidden="true">
                <path d="m15 18-6-6 6-6" />
            </svg>
            @SharedLocalizer["Common_BackHome"]
        </a>

        <div class="grid gap-6 lg:grid-cols-[0.82fr_1.18fr]">
            <aside class="terminal-panel-amber rounded-lg p-8 lg:p-10">
                <div class="font-display text-3xl uppercase tracking-[0.12em] text-green-200 text-glow-cyan">
                    Echo Console
                </div>
                <div class="mt-2 text-xs uppercase tracking-[0.34em] text-amber-400">
                    SECURE ACCESS NODE
                </div>

                <div class="my-8 terminal-divider"></div>

                <p class="terminal-kicker">
                    @SharedLocalizer["Auth_AccessNode"]
                </p>
                <h2 class="mt-3 font-display text-2xl uppercase tracking-[0.08em] text-amber-100">
                    @SharedLocalizer["Auth_OperatorLogin"]
                </h2>
                <p class="mt-4 max-w-md text-sm leading-7 text-slate-400">
                    @SharedLocalizer["Auth_LoginDescription"]
                </p>

                <div class="mt-8 rounded border border-green-500/15 bg-black/70 p-4 text-xs leading-6 text-slate-500">
                    <span class="text-green-400">&gt;</span>
                    AUTH_CHANNEL READY<br />
                    <span class="text-green-400">&gt;</span>
                    ENCRYPTED SESSION REQUIRED
                </div>
            </aside>

            <section class="terminal-panel rounded-lg p-8 sm:p-10 lg:p-12">
                <p class="terminal-kicker">
                    @SharedLocalizer["Topbar_Station"]
                </p>
                <h1 class="mt-3 font-display text-3xl uppercase tracking-[0.1em] text-green-100 text-glow-cyan">
                    @SharedLocalizer["Common_Login"]
                </h1>

                <form asp-controller="Auth"
                      asp-action="Login"
                      method="post"
                      novalidate
                      class="mt-8 space-y-6">
                    <input type="hidden"
                           name="returnUrl"
                           value="@ViewData["ReturnUrl"]" />

                    <div asp-validation-summary="ModelOnly"
                         class="rounded border border-rose-500/25 bg-rose-500/10 px-4 py-3 text-sm"></div>

                    <div>
                        <label asp-for="Email"
                               class="mb-2 block text-xs font-bold uppercase tracking-[0.16em] text-green-200">
                            @SharedLocalizer["Auth_EmailLabel"]
                        </label>
                        <input asp-for="Email"
                               autocomplete="email"
                               class="auth-field"
                               placeholder="operator@echoconsole.local" />
                        <span asp-validation-for="Email"
                              class="mt-2 block text-sm"></span>
                    </div>

                    <div>
                        <label asp-for="Password"
                               class="mb-2 block text-xs font-bold uppercase tracking-[0.16em] text-green-200">
                            @SharedLocalizer["Auth_PasswordLabel"]
                        </label>
                        <input asp-for="Password"
                               autocomplete="current-password"
                               class="auth-field"
                               placeholder="@SharedLocalizer["Auth_PasswordPlaceholder"]" />
                        <span asp-validation-for="Password"
                              class="mt-2 block text-sm"></span>
                    </div>

                    <button type="submit"
                            class="terminal-button w-full py-4">
                        <span>&gt;</span>
                        @SharedLocalizer["Common_Login"]
                    </button>
                </form>

                <div class="my-8 terminal-divider opacity-50"></div>

                <p class="text-center text-sm text-slate-500">
                    @SharedLocalizer["Auth_NoAccount"]
                    <a asp-controller="Auth"
                       asp-action="Register"
                       class="font-bold text-green-300 transition hover:text-green-100 hover:underline">
                        @SharedLocalizer["Auth_RegisterHere"]
                    </a>
                </p>
            </section>
        </div>
    </div>
</div>
