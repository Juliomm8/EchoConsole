@model EchoConsole.Web.Models.Auth.LoginViewModel

@{
    ViewData["Title"] = SharedLocalizer["Auth_LoginPageTitle"].Value;
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="flex min-h-screen items-center justify-center px-4 py-20 sm:px-6">
    <div class="grid w-full max-w-6xl gap-6 lg:grid-cols-[0.85fr_1.15fr]">
        <aside class="rounded-3xl border border-fuchsia-400/15 bg-slate-950/55 p-8 backdrop-blur-xl lg:p-10">
            <div class="font-display text-4xl uppercase tracking-[0.16em] text-cyan-300 text-glow-cyan">
                Echo Console
            </div>
            <div class="mt-2 font-display text-sm uppercase tracking-[0.42em] text-fuchsia-300">
                .Web
            </div>

            <div class="my-8 h-px bg-gradient-to-r from-cyan-400/35 via-fuchsia-400/25 to-transparent"></div>

            <p class="font-display text-xs uppercase tracking-[0.3em] text-cyan-300">
                @SharedLocalizer["Auth_AccessNode"]
            </p>
            <h2 class="mt-3 font-display text-2xl uppercase tracking-[0.12em] text-fuchsia-200">
                @SharedLocalizer["Auth_OperatorLogin"]
            </h2>
            <p class="mt-4 max-w-md text-sm leading-7 text-slate-400">
                @SharedLocalizer["Auth_LoginDescription"]
            </p>
        </aside>

        <section class="rounded-3xl border border-cyan-400/20 bg-slate-950/85 p-8 shadow-[0_0_45px_rgba(34,211,238,0.07)] backdrop-blur-xl sm:p-10 lg:p-12">
            <p class="font-display text-xs uppercase tracking-[0.3em] text-cyan-300">
                @SharedLocalizer["Topbar_Station"]
            </p>
            <h1 class="mt-3 font-display text-3xl uppercase tracking-[0.14em] text-white">
                @SharedLocalizer["Common_Login"]
            </h1>

            <form asp-controller="Auth"
                  asp-action="Login"
                  method="post"
                  novalidate
                  class="mt-8 space-y-6">
                <input type="hidden"
                       name="returnUrl"
                       value="@ViewData["ReturnUrl"]" />

                <div asp-validation-summary="ModelOnly"
                     class="rounded-2xl border border-rose-500/20 bg-rose-500/10 px-4 py-3 text-sm"></div>

                <div>
                    <label asp-for="Email"
                           class="mb-2 block text-sm font-semibold text-slate-200">
                        @SharedLocalizer["Auth_EmailLabel"]
                    </label>
                    <input asp-for="Email"
                           autocomplete="email"
                           class="auth-field"
                           placeholder="operator@echoconsole.local" />
                    <span asp-validation-for="Email"
                          class="mt-2 block text-sm"></span>
                </div>

                <div>
                    <label asp-for="Password"
                           class="mb-2 block text-sm font-semibold text-slate-200">
                        @SharedLocalizer["Auth_PasswordLabel"]
                    </label>
                    <input asp-for="Password"
                           autocomplete="current-password"
                           class="auth-field"
                           placeholder="@SharedLocalizer["Auth_PasswordPlaceholder"]" />
                    <span asp-validation-for="Password"
                          class="mt-2 block text-sm"></span>
                </div>

                <button type="submit"
                        class="w-full rounded-xl border border-cyan-400/30 bg-cyan-500/15 px-5 py-4 text-sm font-bold uppercase tracking-[0.18em] text-cyan-100 transition hover:bg-cyan-500/25">
                    @SharedLocalizer["Common_Login"]
                </button>
            </form>

            <div class="my-8 h-px bg-gradient-to-r from-cyan-400/25 via-fuchsia-400/20 to-transparent"></div>

            <p class="text-center text-sm text-slate-400">
                @SharedLocalizer["Auth_NoAccount"]
                <a asp-controller="Auth"
                   asp-action="Register"
                   class="font-semibold text-cyan-300 transition hover:text-cyan-200 hover:underline">
                    @SharedLocalizer["Auth_RegisterHere"]
                </a>
            </p>
        </section>
    </div>
</div>
