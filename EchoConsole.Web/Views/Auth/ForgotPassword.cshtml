@model EchoConsole.Web.Models.Auth.ForgotPasswordViewModel

@{
    ViewData["Title"] =
        SharedLocalizer["Auth_ForgotPasswordPageTitle"].Value;

    Layout =
        "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="flex min-h-[calc(100vh-8rem)] items-center justify-center px-4 py-20 sm:px-6">
    <div class="w-full max-w-3xl">
        <a asp-controller="Auth"
           asp-action="Login"
           class="mb-5 inline-flex items-center gap-2 text-xs font-bold uppercase tracking-[0.18em] text-green-400 transition hover:text-green-200">
            <svg class="h-4 w-4"
                 viewBox="0 0 24 24"
                 fill="none"
                 stroke="currentColor"
                 stroke-width="1.8"
                 aria-hidden="true">
                <path d="m15 18-6-6 6-6" />
            </svg>

            @SharedLocalizer["Auth_ReturnToLogin"]
        </a>

        <section class="terminal-panel relative overflow-hidden rounded-lg p-8 sm:p-10 lg:p-12">
            <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-green-300/70"></div>

            <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(rgba(57,255,20,0.025)_1px,transparent_1px),linear-gradient(90deg,rgba(57,255,20,0.025)_1px,transparent_1px)] bg-[size:28px_28px]"></div>

            <div class="relative">
                <div class="mx-auto flex h-20 w-20 items-center justify-center rounded-full border border-amber-500/35 bg-amber-500/10 shadow-amber">
                    <svg class="h-9 w-9 text-amber-300"
                         viewBox="0 0 24 24"
                         fill="none"
                         stroke="currentColor"
                         stroke-width="1.6"
                         aria-hidden="true">
                        <path d="M4 6h16v12H4z" />
                        <path d="m4 7 8 6 8-6" />
                    </svg>
                </div>

                <div class="mt-7 text-center">
                    <p class="terminal-kicker">
                        @SharedLocalizer["Auth_CredentialRecoveryChannel"]
                    </p>

                    <h1 class="mt-3 font-display text-3xl uppercase tracking-[0.12em] text-green-100 text-glow-cyan sm:text-4xl">
                        @SharedLocalizer["Auth_ForgotPasswordTitle"]
                    </h1>

                    <p class="mx-auto mt-4 max-w-xl text-sm leading-7 text-slate-400">
                        @SharedLocalizer["Auth_ForgotPasswordDescription"]
                    </p>
                </div>

                @{
                    var authStatusType =
                        TempData["AuthStatusType"]
                            ?.ToString();

                    var authStatusMessage =
                        TempData["AuthStatusMessage"]
                            ?.ToString();

                    var authStatusSuccess =
                        string.Equals(
                            authStatusType,
                            "success",
                            StringComparison.OrdinalIgnoreCase);
                }

                @if (!string.IsNullOrWhiteSpace(
                    authStatusMessage))
                {
                    <div class="mx-auto mt-7 max-w-xl border px-4 py-4 text-center text-sm @(authStatusSuccess
                        ? "border-green-500/30 bg-green-500/10 text-green-200"
                        : "border-rose-500/30 bg-rose-500/10 text-rose-200")">
                        @authStatusMessage
                    </div>
                }

                <div class="mx-auto mt-8 max-w-xl rounded border border-green-500/15 bg-black/70 p-4 text-xs leading-6 text-slate-500">
                    @SharedLocalizer["Auth_RecoveryChannelReady"]<br />
                    @SharedLocalizer["Auth_AwaitingRecoveryEmail"]
                </div>

                <form asp-controller="Auth"
                      asp-action="ForgotPassword"
                      method="post"
                      novalidate
                      class="mx-auto mt-8 max-w-xl space-y-6">
                    <div asp-validation-summary="ModelOnly"
                         class="rounded border border-rose-500/25 bg-rose-500/10 px-4 py-3 text-sm">
                    </div>

                    <div>
                        <label asp-for="Email"
                               class="mb-2 block text-xs font-bold uppercase tracking-[0.16em] text-green-200">
                            @SharedLocalizer["Auth_EmailLabel"]
                        </label>

                        <input asp-for="Email"
                               autocomplete="email"
                               autofocus
                               class="auth-field"
                               placeholder="operator@echoconsole.local" />

                        <span asp-validation-for="Email"
                              class="mt-2 block text-sm">
                        </span>
                    </div>

                    <button type="submit"
                            class="terminal-button flex w-full items-center justify-center gap-3 py-4">
                        <span>&gt;</span>
                        @SharedLocalizer["Auth_SendResetSequence"]
                    </button>
                </form>

                <div class="mx-auto mt-8 max-w-xl border-t border-slate-800 pt-5 text-center text-[9px] uppercase tracking-[0.18em] text-slate-600">
                    @SharedLocalizer["Auth_RecoveryProtocol"]
                </div>
            </div>
        </section>
    </div>
</div>
