@{
    ViewData["Title"] = SharedLocalizer["Privacy_PageTitle"].Value;
    ViewData["TitleResourceKey"] = "Privacy_PageTitle";
}

<div class="min-h-screen bg-[#070B12] px-6 py-8 text-slate-100">
    <section class="mx-auto max-w-4xl rounded-3xl border border-cyan-500/20 bg-slate-950/75 p-8 shadow-[0_0_45px_rgba(34,211,238,0.05)] sm:p-10">
        <p class="font-display text-xs uppercase tracking-[0.34em] text-cyan-300">@SharedLocalizer["Privacy_Badge"]</p>
        <h1 class="mt-3 font-display text-3xl uppercase tracking-[0.14em] text-white">@SharedLocalizer["Privacy_Title"]</h1>
        <p class="mt-5 text-sm leading-7 text-slate-400">@SharedLocalizer["Privacy_Description"]</p>

        <div class="mt-8 grid gap-4 md:grid-cols-2">
            <article class="rounded-2xl border border-fuchsia-400/15 bg-fuchsia-500/5 p-5">
                <h2 class="font-display text-sm uppercase tracking-[0.18em] text-fuchsia-200">@SharedLocalizer["Privacy_TelemetryTitle"]</h2>
                <p class="mt-3 text-sm leading-6 text-slate-400">@SharedLocalizer["Privacy_TelemetryDescription"]</p>
            </article>
            <article class="rounded-2xl border border-amber-400/15 bg-amber-500/5 p-5">
                <h2 class="font-display text-sm uppercase tracking-[0.18em] text-amber-200">@SharedLocalizer["Privacy_SecurityTitle"]</h2>
                <p class="mt-3 text-sm leading-6 text-slate-400">@SharedLocalizer["Privacy_SecurityDescription"]</p>
            </article>
        </div>
    </section>
</div>
