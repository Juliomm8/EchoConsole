@model EchoConsole.Web.Models.Home.HomeIndexViewModel
@{
    ViewData["Title"] =
        SharedLocalizer["Home_PageTitle"].Value;

    ViewData["TitleResourceKey"] =
        "Home_PageTitle";

}

<style>
    @@keyframes home-radar-sweep {
        from {
            transform: rotate(0deg);
        }

        to {
            transform: rotate(360deg);
        }
    }

    @@keyframes home-frequency-pulse {
        0%,
        100% {
            transform: scaleY(0.2);
            opacity: 0.3;
        }

        45% {
            transform: scaleY(1);
            opacity: 1;
        }
    }

    .home-radar-sweep {
        animation: home-radar-sweep 3.8s linear infinite;
    }

    .home-frequency-bar {
        transform-origin: bottom;
        animation: home-frequency-pulse 1.1s ease-in-out infinite;
    }

    @@media (prefers-reduced-motion: reduce) {
        .home-radar-sweep,
        .home-frequency-bar {
            animation: none;
        }
    }
</style>

<div class="bg-black text-green-100">
    <section class="relative isolate overflow-hidden border-b border-green-500/20">
        <img src="~/images/cosmic-diner/showcase-hero.png"
             alt="@SharedLocalizer["Home_HeroImageAlt"]"
             loading="eager"
             fetchpriority="high"
             decoding="async"
             class="absolute inset-0 -z-20 h-full w-full object-cover opacity-40" />

        <div class="absolute inset-0 -z-10 bg-[linear-gradient(90deg,#000_0%,rgba(0,0,0,0.90)_42%,rgba(0,0,0,0.52)_72%,#000_100%)]"></div>
        <div class="crt-grid-background pointer-events-none absolute inset-0 -z-10 opacity-30"></div>

        <div class="mx-auto grid min-h-[680px] max-w-[1700px] items-center gap-10 px-6 py-20 lg:grid-cols-[1.15fr_0.85fr] lg:px-10">
            <div class="max-w-4xl">
                <div class="inline-flex items-center gap-3 rounded border border-green-500/30 bg-black/70 px-3 py-2 text-[10px] font-bold uppercase tracking-[0.28em] text-green-300 shadow-phosphor">
                    <span class="h-2 w-2 rounded-full bg-green-400 animate-signal-pulse"></span>
                    @SharedLocalizer["Home_HeroSignal"]
                </div>

                <p class="mt-8 terminal-kicker">
                    @SharedLocalizer["Home_Badge"]
                </p>

                <h1 class="mt-4 font-display text-5xl uppercase leading-[0.94] tracking-[-0.04em] text-green-100 text-glow-cyan sm:text-6xl xl:text-8xl">
                    Cosmic<br />Diner
                </h1>

                <p class="mt-7 max-w-3xl text-base leading-8 text-slate-300 sm:text-lg">
                    @SharedLocalizer["Home_CommercialHeroDescription"]
                </p>

                <div class="mt-9 flex items-center">
                    <a href="https://store.steampowered.com/"
                       target="_blank"
                       rel="noopener noreferrer"
                       title="@SharedLocalizer["Home_WishlistButton"]"
                       class="steam-store-button">
                        <svg class="h-8 w-8"
                             viewBox="0 0 32 32"
                             fill="none"
                             aria-hidden="true">
                            <circle cx="16"
                                    cy="16"
                                    r="14"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    opacity="0.35" />

                            <circle cx="21.5"
                                    cy="10.5"
                                    r="4.5"
                                    stroke="currentColor"
                                    stroke-width="2.2" />

                            <circle cx="10"
                                    cy="22"
                                    r="3.5"
                                    stroke="currentColor"
                                    stroke-width="2.2" />

                            <path d="m13 20 5.2-7.2M13.1 22.1l5.2 2.2a4.2 4.2 0 0 0 5.4-2.4l1.2-3.1"
                                  stroke="currentColor"
                                  stroke-width="2.2"
                                  stroke-linecap="round" />
                        </svg>

                        <span>
                            <span class="block text-[10px] font-medium tracking-[0.16em] text-slate-300">
                                @SharedLocalizer["Home_WishlistEyebrow"]
                            </span>

                            <span class="mt-1 block text-sm">
                                @SharedLocalizer["Home_WishlistButton"]
                            </span>
                        </span>
                    </a>
                </div>
            </div>

            <aside class="terminal-panel rounded-lg p-5 lg:justify-self-end lg:p-7">
                <div class="flex items-center justify-between border-b border-green-500/15 pb-4">
                    <span class="terminal-kicker">
                        @SharedLocalizer["Home_LiveReadout"]
                    </span>

                    <span class="inline-flex items-center gap-2 text-[10px] uppercase tracking-[0.22em] text-green-400">
                        <span class="h-1.5 w-1.5 rounded-full bg-green-400 animate-signal-pulse"></span>
                        ONLINE
                    </span>
                </div>

                <dl class="mt-5 grid grid-cols-1 gap-3 sm:grid-cols-2">
                    <div class="rounded border border-green-500/20 bg-black p-5 shadow-[inset_0_0_24px_rgba(34,197,94,0.04)]">
                        <dt class="text-[10px] uppercase tracking-[0.18em] text-green-600">
                            @SharedLocalizer["Home_InterceptedSignals"]
                        </dt>

                        <dd class="mt-3 font-display text-4xl text-green-300 text-glow-cyan">
                            @Model.TotalSessions.ToString("N0")
                        </dd>
                    </div>

                    <div class="rounded border border-green-500/20 bg-black p-5 shadow-[inset_0_0_24px_rgba(34,197,94,0.04)]">
                        <dt class="text-[10px] uppercase tracking-[0.18em] text-green-600">
                            @SharedLocalizer["Home_ActiveInvestigators"]
                        </dt>

                        <dd class="mt-3 font-display text-4xl text-green-300 text-glow-cyan">
                            @Model.ActivePlayersNow.ToString("N0")
                        </dd>
                    </div>
                </dl>

                <div class="mt-3 grid gap-5 rounded border border-green-500/20 bg-black p-5 sm:grid-cols-[9rem_minmax(0,1fr)] sm:items-center">
                    <div class="relative mx-auto h-32 w-32 overflow-hidden rounded-full border border-green-500/35 bg-[radial-gradient(circle,rgba(34,197,94,0.12)_0%,rgba(0,0,0,0.95)_68%)] shadow-[0_0_26px_rgba(34,197,94,0.12)]">
                        <div class="absolute inset-[18%] rounded-full border border-green-500/15"></div>
                        <div class="absolute inset-[36%] rounded-full border border-green-500/20"></div>
                        <div class="absolute left-1/2 top-0 h-full w-px -translate-x-1/2 bg-green-500/10"></div>
                        <div class="absolute left-0 top-1/2 h-px w-full -translate-y-1/2 bg-green-500/10"></div>

                        <div class="home-radar-sweep absolute left-1/2 top-1/2 h-px w-[46%] origin-left bg-gradient-to-r from-green-300 via-green-400/70 to-transparent shadow-[0_0_10px_rgba(34,197,94,0.8)]"></div>

                        <span class="absolute left-[66%] top-[34%] h-2 w-2 rounded-full bg-green-300 shadow-[0_0_12px_rgba(34,197,94,0.95)]"></span>
                        <span class="absolute left-[66%] top-[34%] h-2 w-2 rounded-full bg-green-300 animate-ping"></span>

                        <span class="absolute bottom-3 left-1/2 -translate-x-1/2 text-[8px] uppercase tracking-[0.2em] text-green-700">
                            BAND_07
                        </span>
                    </div>

                    <div class="min-w-0">
                        <div class="flex items-center justify-between gap-4">
                            <span class="text-[10px] uppercase tracking-[0.2em] text-green-500">
                                @SharedLocalizer["Home_LiveFrequencyScan"]
                            </span>

                            <span class="text-[9px] uppercase tracking-[0.18em] text-green-700">
                                @SharedLocalizer["Home_ScanLocked"]
                            </span>
                        </div>

                        <div class="mt-5 flex h-24 items-end gap-1.5 overflow-hidden border-b border-green-500/20 pb-1">
                            <span class="home-frequency-bar w-full bg-green-800/70" style="height: 24%; animation-delay: -0.10s;"></span>
                            <span class="home-frequency-bar w-full bg-green-700/80" style="height: 52%; animation-delay: -0.45s;"></span>
                            <span class="home-frequency-bar w-full bg-green-500/80" style="height: 82%; animation-delay: -0.70s;"></span>
                            <span class="home-frequency-bar w-full bg-green-600/80" style="height: 38%; animation-delay: -0.25s;"></span>
                            <span class="home-frequency-bar w-full bg-green-400/90" style="height: 94%; animation-delay: -0.85s;"></span>
                            <span class="home-frequency-bar w-full bg-green-700/80" style="height: 61%; animation-delay: -0.35s;"></span>
                            <span class="home-frequency-bar w-full bg-green-500/90" style="height: 76%; animation-delay: -0.95s;"></span>
                            <span class="home-frequency-bar w-full bg-green-800/70" style="height: 29%; animation-delay: -0.18s;"></span>
                            <span class="home-frequency-bar w-full bg-green-500/80" style="height: 67%; animation-delay: -0.58s;"></span>
                            <span class="home-frequency-bar w-full bg-green-400/90" style="height: 88%; animation-delay: -0.78s;"></span>
                            <span class="home-frequency-bar w-full bg-green-700/80" style="height: 46%; animation-delay: -0.30s;"></span>
                            <span class="home-frequency-bar w-full bg-green-600/90" style="height: 72%; animation-delay: -0.64s;"></span>
                            <span class="home-frequency-bar w-full bg-green-800/70" style="height: 34%; animation-delay: -0.22s;"></span>
                            <span class="home-frequency-bar w-full bg-green-500/90" style="height: 91%; animation-delay: -0.88s;"></span>
                            <span class="home-frequency-bar w-full bg-green-700/80" style="height: 58%; animation-delay: -0.40s;"></span>
                            <span class="home-frequency-bar w-full bg-green-400/90" style="height: 79%; animation-delay: -0.74s;"></span>
                        </div>
                    </div>
                </div>

                <div class="mt-5 rounded border border-green-500/15 bg-green-500/5 p-4 text-xs leading-6 text-slate-400">
                    <span class="text-green-400">&gt;</span>
                    @SharedLocalizer["Home_LiveReadoutDescription"]
                </div>
            </aside>
        </div>
    </section>

    <section class="mx-auto max-w-[1600px] px-6 py-20 lg:px-10">
        <div class="max-w-3xl">
            <p class="terminal-kicker">@SharedLocalizer["Home_ShowcaseEyebrow"]</p>
            <h2 class="mt-4 font-display text-3xl uppercase tracking-[0.06em] text-green-100 sm:text-5xl">
                @SharedLocalizer["Home_ShowcaseTitle"]
            </h2>
            <p class="mt-5 text-sm leading-7 text-slate-400 sm:text-base">
                @SharedLocalizer["Home_ShowcaseIntro"]
            </p>
        </div>

        <div class="mt-14 space-y-12 lg:space-y-20">
            <article class="grid items-center gap-8 lg:grid-cols-2">
                <div class="overflow-hidden rounded-lg border border-green-500/25 bg-green-500/5 shadow-phosphor">
                    <img src="~/images/cosmic-diner/showcase-01.png"
                         alt="@SharedLocalizer["Home_ShowcaseOneAlt"]"
                         loading="lazy"
                         decoding="async"
                         class="aspect-video h-full w-full object-cover transition duration-500 hover:scale-[1.02]" />
                </div>

                <div class="lg:pl-8">
                    <p class="terminal-kicker">LOG_01 // ARRIVAL</p>
                    <h3 class="mt-3 font-display text-2xl uppercase tracking-[0.06em] text-green-100 sm:text-3xl">
                        @SharedLocalizer["Home_ShowcaseOneTitle"]
                    </h3>
                    <p class="mt-5 text-sm leading-8 text-slate-400 sm:text-base">
                        @SharedLocalizer["Home_ShowcaseOneDescription"]
                    </p>
                </div>
            </article>

            <article class="grid items-center gap-8 lg:grid-cols-2">
                <div class="overflow-hidden rounded-lg border border-amber-500/25 bg-amber-500/5 shadow-amber lg:order-2">
                    <img src="~/images/cosmic-diner/showcase-02.png"
                         alt="@SharedLocalizer["Home_ShowcaseTwoAlt"]"
                         loading="lazy"
                         decoding="async"
                         class="aspect-video h-full w-full object-cover transition duration-500 hover:scale-[1.02]" />
                </div>

                <div class="lg:order-1 lg:pr-8">
                    <p class="terminal-kicker text-amber-400">LOG_02 // BLACKOUT</p>
                    <h3 class="mt-3 font-display text-2xl uppercase tracking-[0.06em] text-amber-100 sm:text-3xl">
                        @SharedLocalizer["Home_ShowcaseTwoTitle"]
                    </h3>
                    <p class="mt-5 text-sm leading-8 text-slate-400 sm:text-base">
                        @SharedLocalizer["Home_ShowcaseTwoDescription"]
                    </p>
                </div>
            </article>

            <article class="grid items-center gap-8 lg:grid-cols-2">
                <div class="overflow-hidden rounded-lg border border-green-500/25 bg-green-500/5 shadow-phosphor">
                    <img src="~/images/cosmic-diner/showcase-03.png"
                         alt="@SharedLocalizer["Home_ShowcaseThreeAlt"]"
                         loading="lazy"
                         decoding="async"
                         class="aspect-video h-full w-full object-cover transition duration-500 hover:scale-[1.02]" />
                </div>

                <div class="lg:pl-8">
                    <p class="terminal-kicker">LOG_03 // CONTACT</p>
                    <h3 class="mt-3 font-display text-2xl uppercase tracking-[0.06em] text-green-100 sm:text-3xl">
                        @SharedLocalizer["Home_ShowcaseThreeTitle"]
                    </h3>
                    <p class="mt-5 text-sm leading-8 text-slate-400 sm:text-base">
                        @SharedLocalizer["Home_ShowcaseThreeDescription"]
                    </p>
                </div>
            </article>
        </div>
    </section>
    <style>
        .patch-carousel-scroll {
            scrollbar-width: thin;
            scrollbar-color: #22c55e #000000;
            overscroll-behavior-x: contain;
        }

        .patch-carousel-scroll::-webkit-scrollbar {
            height: 8px;
        }

        .patch-carousel-scroll::-webkit-scrollbar-track {
            background: #000000;
            border-top: 1px solid rgba(34, 197, 94, 0.10);
        }

        .patch-carousel-scroll::-webkit-scrollbar-thumb {
            background: #22c55e;
            border: 2px solid #000000;
            border-radius: 999px;
            box-shadow: 0 0 10px rgba(34, 197, 94, 0.55);
        }

        .patch-carousel-scroll::-webkit-scrollbar-thumb:hover {
            background: #4ade80;
            box-shadow: 0 0 14px rgba(74, 222, 128, 0.75);
        }
    </style>

    <section class="border-y border-green-500/15 bg-[#020502]">
        <div class="mx-auto max-w-[1600px] px-6 py-20 lg:px-10">
            <div class="flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between">
                <header class="max-w-3xl">
                    <p class="terminal-kicker">
                        @SharedLocalizer["Home_ChangelogEyebrow"]
                    </p>

                    <h2 class="mt-4 font-display text-3xl uppercase tracking-[0.06em] text-green-100 sm:text-5xl">
                        @SharedLocalizer["Home_ChangelogTitle"]
                    </h2>

                    <p class="mt-5 max-w-2xl text-sm leading-7 text-slate-500">
                        @SharedLocalizer["Home_ChangelogDescription"]
                    </p>
                </header>

                <div class="shrink-0 border-l border-green-500/20 pl-4 text-[10px] uppercase tracking-[0.20em] text-green-700">
                    <div>ARCHIVE_MODE: HORIZONTAL</div>
                    <div class="mt-2">SOURCE_TARGET: SQLITE_CMS</div>
                    <div class="mt-2">INPUT: SHIFT + WHEEL / DRAG</div>
                </div>
            </div>

            <div class="terminal-panel mt-10 overflow-hidden rounded-lg">
                <div class="flex flex-wrap items-center justify-between gap-3 border-b border-green-500/15 bg-green-500/5 px-5 py-3 text-[10px] uppercase tracking-[0.22em] text-green-400">
                    <span>cosmic_diner_changelog.log</span>
                    <span>SCROLL_X // READ_ONLY</span>
                </div>

                <div class="relative">
                    <div class="pointer-events-none absolute inset-y-0 left-0 z-10 w-10 bg-gradient-to-r from-black via-black/65 to-transparent"></div>
                    <div class="pointer-events-none absolute inset-y-0 right-0 z-10 w-10 bg-gradient-to-l from-black via-black/65 to-transparent"></div>

                    <div class="patch-carousel-scroll flex snap-x snap-mandatory gap-5 overflow-x-auto px-6 py-7 pb-8">
                        @*
                            Patch notes are loaded from EchoConsole.Api.
                            Keep the article markup unchanged so every database
                            record renders with the same card structure.
                        *@

                        @foreach (var patch in Model.PatchNotes)
                        {
                            var borderClass = "border-green-500/30";
                            var badgeClass = "border-green-500/35 bg-green-500/10 text-green-300";
                            var titleClass = "text-green-100";
                            var glowClass = "hover:shadow-[0_0_28px_rgba(34,197,94,0.12)]";
                            var statusClass = "text-green-700";

                            if (patch.Tone == "amber")
                            {
                                borderClass = "border-amber-500/30";
                                badgeClass = "border-amber-500/35 bg-amber-500/10 text-amber-300";
                                titleClass = "text-amber-100";
                                glowClass = "hover:shadow-[0_0_28px_rgba(251,191,36,0.12)]";
                                statusClass = "text-amber-700";
                            }
                            else if (patch.Tone == "rose")
                            {
                                borderClass = "border-rose-500/30";
                                badgeClass = "border-rose-500/35 bg-rose-500/10 text-rose-300";
                                titleClass = "text-rose-100";
                                glowClass = "hover:shadow-[0_0_28px_rgba(251,113,133,0.12)]";
                                statusClass = "text-rose-700";
                            }

                            <article class="group flex min-h-[320px] w-80 shrink-0 snap-start flex-col rounded border @borderClass bg-black p-6 shadow-[inset_0_0_32px_rgba(34,197,94,0.025)] transition duration-300 hover:-translate-y-1 @glowClass sm:w-96">
                                <div class="flex items-start justify-between gap-4">
                                    <span class="inline-flex rounded border px-3 py-1.5 text-xs font-bold @badgeClass">
                                        @patch.Version
                                    </span>

                                    <span class="pt-1 text-[9px] uppercase tracking-[0.20em] @statusClass">
                                        ARCHIVED
                                    </span>
                                </div>

                                <div class="mt-6 text-[10px] uppercase tracking-[0.22em] text-slate-600">
                                    @patch.Category
                                </div>

                                <h3 class="mt-4 font-display text-xl uppercase leading-snug tracking-[0.06em] @titleClass">
                                    @patch.Title
                                </h3>

                                <p class="mt-5 flex-1 text-sm leading-7 text-slate-400">
                                    @patch.Description
                                </p>

                                <div class="mt-8 border-t border-current/10 pt-4 text-[9px] uppercase tracking-[0.18em] text-slate-700">
                                    RECORD_STATUS: VERIFIED
                                </div>
                            </article>
                        }

                        <aside class="flex min-h-[320px] w-72 shrink-0 snap-start flex-col items-center justify-center rounded border border-dashed border-green-500/20 bg-green-500/[0.025] px-6 text-center sm:w-80">
                            <span class="h-2.5 w-2.5 rounded-full bg-green-400 shadow-[0_0_14px_rgba(34,197,94,0.80)] animate-pulse"></span>

                            <p class="mt-5 font-mono text-xs uppercase tracking-[0.16em] text-green-600">
                                &gt; AWAITING SQLITE TRANSMISSION...
                            </p>

                            <p class="mt-3 text-[9px] uppercase tracking-[0.18em] text-green-900">
                                NEXT_RECORD_SLOT_READY
                            </p>
                        </aside>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <section class="relative isolate overflow-hidden border-t border-green-500/15 bg-black">
        <div class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(circle_at_center,rgba(34,197,94,0.09),transparent_58%)]"></div>
        <div class="crt-grid-background pointer-events-none absolute inset-0 -z-10 opacity-20"></div>

        <div class="mx-auto flex max-w-[1200px] flex-col items-center px-6 py-24 text-center lg:px-10">
            <h2 class="font-display text-3xl uppercase tracking-[0.08em] text-green-100 text-glow-cyan sm:text-5xl">
                @SharedLocalizer["Home_SurviveShiftTitle"]
            </h2>

            <p class="mt-5 cursor-help select-none text-[9px] uppercase tracking-[0.24em] text-[#071007] transition-all duration-500 hover:text-green-500/70 hover:drop-shadow-[0_0_8px_rgba(34,197,94,0.65)]">
                @SharedLocalizer["Home_CorruptedData"]
            </p>

            <a href="https://store.steampowered.com/"
               target="_blank"
               rel="noopener noreferrer"
               title="@SharedLocalizer["Home_WishlistButton"]"
               class="steam-store-button mt-10">
                <svg class="h-8 w-8"
                     viewBox="0 0 32 32"
                     fill="none"
                     aria-hidden="true">
                    <circle cx="16"
                            cy="16"
                            r="14"
                            stroke="currentColor"
                            stroke-width="2"
                            opacity="0.35" />

                    <circle cx="21.5"
                            cy="10.5"
                            r="4.5"
                            stroke="currentColor"
                            stroke-width="2.2" />

                    <circle cx="10"
                            cy="22"
                            r="3.5"
                            stroke="currentColor"
                            stroke-width="2.2" />

                    <path d="m13 20 5.2-7.2M13.1 22.1l5.2 2.2a4.2 4.2 0 0 0 5.4-2.4l1.2-3.1"
                          stroke="currentColor"
                          stroke-width="2.2"
                          stroke-linecap="round" />
                </svg>

                <span>
                    <span class="block text-[10px] font-medium tracking-[0.16em] text-slate-300">
                        @SharedLocalizer["Home_WishlistEyebrow"]
                    </span>

                    <span class="mt-1 block text-sm">
                        @SharedLocalizer["Home_WishlistButton"]
                    </span>
                </span>
            </a>
        </div>
    </section>

</div>
