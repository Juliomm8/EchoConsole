@model EchoConsole.Web.Models.Home.HomeIndexViewModel

@{
    ViewData["Title"] = SharedLocalizer["HomePortal_PageTitle"].Value;
    ViewData["TitleResourceKey"] = "HomePortal_PageTitle";

    var isAuthenticated = User.Identity?.IsAuthenticated == true;

    var goldenPanelClass = isAuthenticated
        ? "terminal-panel border-green-500/30 shadow-neon hover:border-green-400/50"
        : "terminal-panel-amber border-amber-500/30 hover:border-amber-400/60 hover:shadow-amber";

    var goldenGlowClass = isAuthenticated
        ? "bg-green-500/10"
        : "bg-amber-500/10";

    var goldenAccentTextClass = isAuthenticated
        ? "text-green-300 text-glow-cyan"
        : "text-amber-300 text-glow-magenta";

    var goldenMutedTextClass = isAuthenticated
        ? "text-green-500"
        : "text-amber-500";

    var goldenBadgeClass = isAuthenticated
        ? "border-green-500/30 bg-green-500/10 text-green-300"
        : "border-amber-500/35 bg-amber-500/10 text-amber-300";

    var goldenIconClass = isAuthenticated
        ? "border-green-400/35 bg-green-500/10 text-green-300 shadow-neon"
        : "border-amber-400/40 bg-amber-500/10 text-amber-300 shadow-amber";

    var goldenFeatureClass = isAuthenticated
        ? "border-green-500/20 bg-green-500/5 text-green-200"
        : "border-amber-500/20 bg-amber-500/5 text-amber-100";

    var goldenDotClass = isAuthenticated
        ? "bg-[rgb(var(--terminal-accent-rgb))] shadow-neon"
        : "bg-amber-400 shadow-[0_0_10px_rgba(251,191,36,0.75)]";

    var goldenDividerClass = isAuthenticated
        ? "terminal-divider"
        : "h-px bg-gradient-to-r from-amber-400/80 via-amber-500/20 to-transparent";

    var goldenButtonClass = isAuthenticated
        ? "terminal-button"
        : "inline-flex items-center justify-center gap-3 rounded-lg border border-amber-400/55 bg-amber-500/10 px-5 py-3.5 text-xs font-extrabold uppercase tracking-[0.16em] text-amber-200 shadow-amber transition group-hover:border-amber-300 group-hover:bg-amber-500/20 group-hover:text-amber-100";
}

<div class="relative isolate min-h-[calc(100vh-8rem)] overflow-hidden bg-black text-green-100">
    <div class="crt-grid-background pointer-events-none absolute inset-0 -z-30 opacity-35"></div>
    <div class="pointer-events-none absolute inset-0 -z-20 bg-[radial-gradient(circle_at_18%_24%,rgba(57,255,20,0.10),transparent_28rem),radial-gradient(circle_at_82%_24%,rgba(245,158,11,0.10),transparent_28rem),linear-gradient(180deg,#000_0%,#020402_48%,#000_100%)]"></div>
    <div class="pointer-events-none absolute inset-0 -z-10 opacity-45 [background-image:repeating-linear-gradient(0deg,transparent_0,transparent_3px,rgba(255,255,255,0.018)_4px)]"></div>

    <section class="mx-auto flex w-full max-w-[1780px] flex-col px-5 py-8 sm:px-7 lg:px-10 lg:py-12">
        <header class="relative overflow-hidden rounded-xl border border-green-500/20 bg-black/90 px-5 py-5 shadow-neon sm:px-7 lg:px-8">
            <div class="pointer-events-none absolute inset-y-0 left-0 w-1 bg-[rgb(var(--terminal-accent-rgb))] shadow-[0_0_16px_rgb(var(--terminal-accent-rgb)/0.8)]"></div>
            <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(90deg,rgba(57,255,20,0.05),transparent_42%,rgba(245,158,11,0.04))]"></div>

            <div class="relative flex flex-col gap-6 xl:flex-row xl:items-end xl:justify-between">
                <div class="max-w-5xl">
                    <div class="flex flex-wrap items-center gap-3 text-[10px] font-bold uppercase tracking-[0.24em] text-green-500">
                        <span class="inline-flex items-center gap-2 rounded border border-green-500/25 bg-green-500/5 px-3 py-1.5">
                            <span class="h-1.5 w-1.5 rounded-full bg-[rgb(var(--terminal-accent-rgb))] animate-signal-pulse"></span>
                            @SharedLocalizer["HomePortal_SystemEyebrow"]
                        </span>
                        <span class="text-slate-700">//</span>
                        <span class="text-slate-500">@SharedLocalizer["HomePortal_SelectDestination"]</span>
                    </div>

                    <h1 class="mt-5 font-display text-3xl uppercase leading-tight tracking-[0.04em] text-green-100 text-glow-cyan sm:text-4xl lg:text-5xl">
                        @SharedLocalizer["HomePortal_StudioName"]
                    </h1>

                    <p class="mt-4 max-w-4xl text-sm leading-7 text-slate-400 sm:text-base">
                        @SharedLocalizer["HomePortal_WelcomeDescription"]
                    </p>
                </div>

                <div class="shrink-0 rounded-lg border border-green-500/20 bg-green-500/5 px-4 py-3 text-[10px] uppercase tracking-[0.18em] text-green-500">
                    <div class="flex items-center gap-2">
                        <span class="h-2 w-2 rounded-full bg-[rgb(var(--terminal-accent-rgb))] animate-signal-pulse"></span>
                        <span>
                            @(isAuthenticated
                                ? SharedLocalizer["HomePortal_ProfileThemeStatus"]
                                : SharedLocalizer["HomePortal_GuestThemeStatus"])
                        </span>
                    </div>
                </div>
            </div>
        </header>

        <div class="relative mt-6 grid flex-1 gap-5 lg:grid-cols-2 lg:gap-6">
            <div class="pointer-events-none absolute left-1/2 top-8 z-20 hidden h-[calc(100%-4rem)] w-px -translate-x-1/2 bg-gradient-to-b from-transparent via-slate-700/70 to-transparent lg:block"></div>
            <div class="pointer-events-none absolute left-1/2 top-1/2 z-30 hidden h-12 w-12 -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-full border border-slate-700 bg-black text-[10px] font-bold uppercase tracking-[0.18em] text-slate-500 lg:flex">
                @SharedLocalizer["HomePortal_Or"]
            </div>

            <a asp-controller="Dashboard"
               asp-action="Index"
               aria-label="@SharedLocalizer["HomePortal_CosmicButton"]"
               class="group terminal-panel relative flex min-h-[34rem] overflow-hidden rounded-xl border-green-500/30 p-6 transition duration-300 hover:-translate-y-1 shadow-neon hover:border-green-400/50 focus-visible:-translate-y-1 sm:p-8 lg:min-h-[38rem] xl:p-10">
                <div class="pointer-events-none absolute inset-0 opacity-55 [background-image:repeating-linear-gradient(0deg,transparent_0,transparent_3px,rgba(255,255,255,0.020)_4px)]"></div>
                <div class="pointer-events-none absolute -left-32 -top-32 h-96 w-96 rounded-full bg-green-500/10 blur-3xl transition duration-500 group-hover:bg-green-500/15"></div>
                <div class="pointer-events-none absolute bottom-0 right-0 h-64 w-64 rounded-full bg-green-500/10 opacity-50 blur-3xl"></div>

                <div class="relative z-10 flex w-full flex-col">
                    <div class="flex items-start justify-between gap-5">
                        <div class="inline-flex items-center gap-3 rounded-md border border-green-500/30 bg-green-500/10 px-3 py-2 text-[10px] font-bold uppercase tracking-[0.22em] text-green-300">
                            <span class="font-display text-sm">A</span>
                            @SharedLocalizer["HomePortal_PathLabelA"]
                        </div>

                        <div class="flex h-16 w-16 items-center justify-center rounded-xl border border-green-400/35 bg-green-500/10 text-green-300 shadow-neon transition duration-300 group-hover:scale-105 group-hover:border-green-300 sm:h-20 sm:w-20">
                            <svg class="h-9 w-9 sm:h-11 sm:w-11"
                                 viewBox="0 0 48 48"
                                 fill="none"
                                 stroke="currentColor"
                                 stroke-width="1.5"
                                 aria-hidden="true">
                                <circle cx="24" cy="24" r="17" />
                                <circle cx="24" cy="24" r="10" opacity=".55" />
                                <path d="M24 3v7M24 38v7M3 24h7M38 24h7" />
                                <path d="m11 11 5 5M32 32l5 5M37 11l-5 5M16 32l-5 5" opacity=".7" />
                                <path d="M24 24 35 17" />
                                <circle cx="35" cy="17" r="2" fill="currentColor" stroke="none" />
                            </svg>
                        </div>
                    </div>

                    <div class="mt-10">
                        <p class="text-[10px] font-bold uppercase tracking-[0.28em] text-green-500">
                            @SharedLocalizer["HomePortal_CosmicEyebrow"]
                        </p>
                        <h2 class="mt-4 font-display text-3xl uppercase leading-tight tracking-[0.02em] text-green-100 text-glow-cyan sm:text-4xl xl:text-5xl">
                            @SharedLocalizer["HomePortal_CosmicTitle"]
                        </h2>
                        <p class="mt-5 max-w-2xl text-sm leading-7 text-slate-400 sm:text-base">
                            @SharedLocalizer["HomePortal_CosmicDescription"]
                        </p>
                    </div>

                    <div class="mt-8 grid gap-3 sm:grid-cols-3 lg:grid-cols-1 xl:grid-cols-3">
                        <div class="rounded-lg border border-green-500/20 bg-green-500/5 p-4 text-green-200">
                            <span class="block h-1.5 w-1.5 rounded-full bg-[rgb(var(--terminal-accent-rgb))] shadow-neon"></span>
                            <span class="mt-3 block text-[10px] font-bold uppercase leading-5 tracking-[0.16em]">@SharedLocalizer["HomePortal_CosmicTelemetry"]</span>
                        </div>
                        <div class="rounded-lg border border-green-500/20 bg-green-500/5 p-4 text-green-200">
                            <span class="block h-1.5 w-1.5 rounded-full bg-[rgb(var(--terminal-accent-rgb))] shadow-neon"></span>
                            <span class="mt-3 block text-[10px] font-bold uppercase leading-5 tracking-[0.16em]">@SharedLocalizer["HomePortal_CosmicThreads"]</span>
                        </div>
                        <div class="rounded-lg border border-green-500/20 bg-green-500/5 p-4 text-green-200">
                            <span class="block h-1.5 w-1.5 rounded-full bg-[rgb(var(--terminal-accent-rgb))] shadow-neon"></span>
                            <span class="mt-3 block text-[10px] font-bold uppercase leading-5 tracking-[0.16em]">@SharedLocalizer["HomePortal_CosmicAlerts"]</span>
                        </div>
                    </div>

                    <div class="mt-auto pt-10">
                        <div class="terminal-divider"></div>
                        <div class="mt-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
                            <span class="terminal-button">
                                @SharedLocalizer["HomePortal_CosmicButton"]
                                <svg class="h-4 w-4 transition-transform group-hover:translate-x-1"
                                     viewBox="0 0 24 24"
                                     fill="none"
                                     stroke="currentColor"
                                     stroke-width="2"
                                     aria-hidden="true">
                                    <path d="M5 12h14M13 6l6 6-6 6" />
                                </svg>
                            </span>
                            <span class="inline-flex items-center gap-2 text-[9px] font-bold uppercase tracking-[0.18em] text-green-500">
                                <span class="h-1.5 w-1.5 rounded-full bg-[rgb(var(--terminal-accent-rgb))] animate-signal-pulse"></span>
                                @SharedLocalizer["HomePortal_CosmicStatus"]
                            </span>
                        </div>
                    </div>
                </div>
            </a>

            <a asp-controller="Ecosystem"
               asp-action="Index"
               aria-label="@SharedLocalizer["HomePortal_GoldenButton"]"
               class="group @goldenPanelClass relative flex min-h-[34rem] overflow-hidden rounded-xl p-6 transition duration-300 hover:-translate-y-1 focus-visible:-translate-y-1 sm:p-8 lg:min-h-[38rem] xl:p-10">
                <div class="pointer-events-none absolute inset-0 opacity-55 [background-image:repeating-linear-gradient(0deg,transparent_0,transparent_3px,rgba(255,255,255,0.020)_4px)]"></div>
                <div class="pointer-events-none absolute -right-32 -top-32 h-96 w-96 rounded-full @goldenGlowClass blur-3xl transition duration-500 group-hover:opacity-100"></div>
                <div class="pointer-events-none absolute bottom-0 left-0 h-64 w-64 @goldenGlowClass opacity-50 blur-3xl"></div>

                <div class="relative z-10 flex w-full flex-col">
                    <div class="flex items-start justify-between gap-5">
                        <div class="inline-flex items-center gap-3 rounded-md border px-3 py-2 text-[10px] font-bold uppercase tracking-[0.22em] @goldenBadgeClass">
                            <span class="font-display text-sm">B</span>
                            @SharedLocalizer["HomePortal_PathLabelB"]
                        </div>

                        <div class="flex h-16 w-16 items-center justify-center rounded-xl border transition duration-300 group-hover:scale-105 sm:h-20 sm:w-20 @goldenIconClass">
                            <svg class="h-10 w-10 sm:h-12 sm:w-12"
                                 viewBox="0 0 48 48"
                                 fill="none"
                                 stroke="currentColor"
                                 stroke-width="1.5"
                                 aria-hidden="true">
                                <path d="M12 18 8 8l11 6h10l11-6-4 10v15a7 7 0 0 1-7 7H19a7 7 0 0 1-7-7V18Z" />
                                <path d="M18 24h3M27 24h3" />
                                <path d="m20 31 4 2 4-2" />
                                <path d="M24 14V8M20 8h8" opacity=".75" />
                                <path d="M8 29H3M45 29h-5M8 34H4M44 34h-4" opacity=".7" />
                            </svg>
                        </div>
                    </div>

                    <div class="mt-10">
                        <p class="text-[10px] font-bold uppercase tracking-[0.28em] @goldenMutedTextClass">
                            @SharedLocalizer["HomePortal_GoldenEyebrow"]
                        </p>
                        <h2 class="mt-4 font-display text-3xl uppercase leading-tight tracking-[0.02em] sm:text-4xl xl:text-5xl @goldenAccentTextClass">
                            @SharedLocalizer["HomePortal_GoldenTitle"]
                        </h2>
                        <p class="mt-5 max-w-2xl text-sm leading-7 text-slate-400 sm:text-base">
                            @SharedLocalizer["HomePortal_GoldenDescription"]
                        </p>
                    </div>

                    <div class="mt-8 grid gap-3 sm:grid-cols-3 lg:grid-cols-1 xl:grid-cols-3">
                        <div class="rounded-lg border p-4 @goldenFeatureClass">
                            <span class="block h-1.5 w-1.5 rounded-full @goldenDotClass"></span>
                            <span class="mt-3 block text-[10px] font-bold uppercase leading-5 tracking-[0.16em]">@SharedLocalizer["HomePortal_GoldenHub"]</span>
                        </div>
                        <div class="rounded-lg border p-4 @goldenFeatureClass">
                            <span class="block h-1.5 w-1.5 rounded-full @goldenDotClass"></span>
                            <span class="mt-3 block text-[10px] font-bold uppercase leading-5 tracking-[0.16em]">@SharedLocalizer["HomePortal_GoldenTools"]</span>
                        </div>
                        <div class="rounded-lg border p-4 @goldenFeatureClass">
                            <span class="block h-1.5 w-1.5 rounded-full @goldenDotClass"></span>
                            <span class="mt-3 block text-[10px] font-bold uppercase leading-5 tracking-[0.16em]">@SharedLocalizer["HomePortal_GoldenUpdates"]</span>
                        </div>
                    </div>

                    <div class="mt-auto pt-10">
                        <div class="@goldenDividerClass"></div>
                        <div class="mt-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
                            <span class="@goldenButtonClass">
                                @SharedLocalizer["HomePortal_GoldenButton"]
                                <svg class="h-4 w-4 transition-transform group-hover:translate-x-1"
                                     viewBox="0 0 24 24"
                                     fill="none"
                                     stroke="currentColor"
                                     stroke-width="2"
                                     aria-hidden="true">
                                    <path d="M5 12h14M13 6l6 6-6 6" />
                                </svg>
                            </span>
                            <span class="inline-flex items-center gap-2 text-[9px] font-bold uppercase tracking-[0.18em] @goldenMutedTextClass">
                                <span class="h-1.5 w-1.5 rounded-full @goldenDotClass animate-signal-pulse"></span>
                                @SharedLocalizer["HomePortal_GoldenStatus"]
                            </span>
                        </div>
                    </div>
                </div>
            </a>
        </div>

        <footer class="mt-6 flex flex-col gap-3 border-t border-slate-900 pt-5 text-[9px] uppercase tracking-[0.18em] text-slate-700 sm:flex-row sm:items-center sm:justify-between">
            <span>@SharedLocalizer["HomePortal_SecurityLine"]</span>
            <span>@SharedLocalizer["HomePortal_KeyboardHint"]</span>
        </footer>
    </section>
</div>
