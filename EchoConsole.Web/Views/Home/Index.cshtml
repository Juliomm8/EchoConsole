@model EchoConsole.Web.Models.Home.HomeIndexViewModel

@{
    ViewData["Title"] = "HOME";
    ViewData["TitleI18nKey"] = "home_page_title";
}

<div class="min-h-screen bg-[#070B12] text-slate-100">
    <div class="mx-auto max-w-[1600px] px-6 py-6">
        <div class="mb-6 rounded-2xl border border-cyan-500/20 bg-slate-950/70 p-8 shadow-[0_0_40px_rgba(0,255,255,0.05)] backdrop-blur">
            <p class="font-display text-xs uppercase tracking-[0.35em] text-cyan-400">
                Cosmic Diner
            </p>

            <h1 class="mt-3 font-display text-4xl uppercase tracking-[0.16em] text-white md:text-5xl">
                Echo Console
            </h1>

            <p class="mt-4 max-w-3xl text-base text-slate-300">
                Official telemetry platform for Cosmic Diner, the retro-futuristic indie horror experience.
                Explore live community activity, global performance insights, and your personal player profile.
            </p>

            <div class="mt-6 flex flex-wrap gap-3">
                @if (!Model.IsAuthenticated)
                {
                    <a asp-controller="Auth"
                       asp-action="Register"
                       class="rounded-xl border border-cyan-400/25 bg-cyan-500/10 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-cyan-200 transition hover:bg-cyan-500/15">
                        Create Account
                    </a>

                    <a asp-controller="Auth"
                       asp-action="Login"
                       class="rounded-xl border border-slate-700 bg-slate-900/70 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-slate-300 transition hover:border-cyan-400/20 hover:text-white">
                        Login
                    </a>
                }
                else
                {
                    <a href="#my-stats"
                       class="rounded-xl border border-cyan-400/25 bg-cyan-500/10 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-cyan-200 transition hover:bg-cyan-500/15">
                        View My Stats
                    </a>
                }
            </div>
        </div>

        <div class="mb-6 grid grid-cols-1 gap-4 md:grid-cols-3 xl:grid-cols-5">
            <div class="rounded-2xl border border-cyan-500/20 bg-slate-950/70 p-5 shadow-[0_0_30px_rgba(0,255,255,0.04)]">
                <div class="font-display text-xs uppercase tracking-[0.25em] text-slate-400">
                    Community Sessions
                </div>
                <div class="mt-3 font-display text-3xl text-cyan-300">
                    @Model.TotalSessions.ToString("N0")
                </div>
                <div class="mt-2 text-sm text-slate-400">
                    Total matches and telemetry sessions recorded.
                </div>
            </div>

            <div class="rounded-2xl border border-cyan-500/20 bg-slate-950/70 p-5 shadow-[0_0_30px_rgba(0,255,255,0.04)]">
                <div class="font-display text-xs uppercase tracking-[0.25em] text-slate-400">
                    Active Now
                </div>
                <div class="mt-3 font-display text-3xl text-emerald-400">
                    @Model.ActivePlayersNow.ToString("N0")
                </div>
                <div class="mt-2 text-sm text-slate-400">
                    Players currently active across monitored builds.
                </div>
            </div>

            <div class="rounded-2xl border border-cyan-500/20 bg-slate-950/70 p-5 shadow-[0_0_30px_rgba(0,255,255,0.04)]">
                <div class="font-display text-xs uppercase tracking-[0.25em] text-slate-400">
                    Monitored Builds
                </div>
                <div class="mt-3 font-display text-3xl text-cyan-300">
                    @Model.MonitoredBuilds.ToString("N0")
                </div>
                <div class="mt-2 text-sm text-slate-400">
                    Total registered game builds tracked by the platform.
                </div>
            </div>
            <div class="rounded-2xl border border-cyan-500/20 bg-slate-950/70 p-5 shadow-[0_0_30px_rgba(0,255,255,0.04)]">
                <div class="font-display text-xs uppercase tracking-[0.25em] text-slate-400">
                    Open Alerts
                </div>
                <div class="mt-3 font-display text-3xl text-rose-400">
                    @Model.OpenAlerts.ToString("N0")
                </div>
                <div class="mt-2 text-sm text-slate-400">
                    Current unresolved anomalies detected by the telemetry platform.
                </div>
            </div>
            <div class="rounded-2xl border border-cyan-500/20 bg-slate-950/70 p-5 shadow-[0_0_30px_rgba(0,255,255,0.04)]">
                <div class="font-display text-xs uppercase tracking-[0.25em] text-slate-400">
                    Featured Build
                </div>
                <div class="mt-3 font-display text-3xl text-fuchsia-300">
                    @Model.FeaturedBuildVersion
                </div>
                <div class="mt-2 text-sm text-slate-400">
                    Current highlighted release tracked by Echo Console.
                </div>
            </div>
        </div>

        @if (Model.IsAuthenticated)
        {
            <div id="my-stats" class="rounded-2xl border border-fuchsia-500/20 bg-slate-950/70 p-6 shadow-[0_0_30px_rgba(232,121,249,0.05)]">
                <p class="font-display text-xs uppercase tracking-[0.35em] text-fuchsia-300">
                    My Operator Profile
                </p>

                <h2 class="mt-2 font-display text-2xl uppercase tracking-[0.14em] text-white">
                    Welcome back, @Model.UserAlias
                </h2>

                <p class="mt-3 text-sm text-slate-400">
                    This section is reserved for your personal gameplay analytics and profile card.
                </p>

                <div class="mt-5 grid grid-cols-1 gap-4 md:grid-cols-3">
                    <div class="rounded-xl border border-fuchsia-400/15 bg-slate-900/70 p-4">
                        <div class="text-xs uppercase tracking-[0.22em] text-slate-500">
                            Your Sessions
                        </div>
                        <div class="mt-2 font-display text-2xl text-fuchsia-300">
                            @Model.UserTotalSessions.ToString("N0")
                        </div>
                    </div>

                    <div class="rounded-xl border border-fuchsia-400/15 bg-slate-900/70 p-4">
                        <div class="text-xs uppercase tracking-[0.22em] text-slate-500">
                            Favorite Build
                        </div>
                        <div class="mt-2 font-display text-2xl text-fuchsia-300">
                            @Model.UserFavoriteBuild
                        </div>
                    </div>

                    <div class="rounded-xl border border-fuchsia-400/15 bg-slate-900/70 p-4">
                        <div class="text-xs uppercase tracking-[0.22em] text-slate-500">
                            Last Activity
                        </div>
                        <div class="mt-2 font-display text-2xl text-fuchsia-300">
                            @Model.UserLastActivity
                        </div>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="rounded-2xl border border-fuchsia-500/20 bg-slate-950/70 p-6 shadow-[0_0_30px_rgba(232,121,249,0.05)]">
                <p class="font-display text-xs uppercase tracking-[0.35em] text-fuchsia-300">
                    Unlock Your Profile
                </p>

                <h2 class="mt-2 font-display text-2xl uppercase tracking-[0.14em] text-white">
                    Create your player identity
                </h2>

                <p class="mt-3 max-w-2xl text-sm text-slate-400">
                    Register to access your future player card, personal telemetry insights, and account customization.
                </p>

                <div class="mt-5 flex flex-wrap gap-3">
                    <a asp-controller="Auth"
                       asp-action="Register"
                       class="inline-flex rounded-xl border border-fuchsia-400/25 bg-fuchsia-500/10 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-fuchsia-200 transition hover:bg-fuchsia-500/15">
                        Register Now
                    </a>

                    <a asp-controller="Auth"
                       asp-action="Login"
                       class="inline-flex rounded-xl border border-slate-700 bg-slate-900/70 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-slate-300 transition hover:border-cyan-400/20 hover:text-white">
                        Login
                    </a>
                </div>
            </div>
        }
    </div>
</div>