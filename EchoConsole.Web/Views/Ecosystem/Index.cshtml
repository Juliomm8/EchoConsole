@using EchoConsole.Web.Controllers

@{
    ViewData["Title"] = SharedLocalizer["GoldenCat_PageTitle"].Value;
    ViewData["TitleResourceKey"] = "GoldenCat_PageTitle";

    var downloadErrorResourceKey =
        ViewData[EcosystemController.DownloadErrorViewDataKey] as string
        ?? TempData[EcosystemController.DownloadErrorTempDataKey] as string;

    var hasDownloadError = string.Equals(
        downloadErrorResourceKey,
        EcosystemController.DownloadUnavailableResourceKey,
        System.StringComparison.Ordinal);
}

<div class="overflow-hidden bg-black text-green-100">
    <section class="relative isolate border-b border-green-500/20">
        <div class="crt-grid-background pointer-events-none absolute inset-0 -z-20 opacity-30"></div>
        <div class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(circle_at_82%_18%,rgba(245,158,11,0.12),transparent_25rem),radial-gradient(circle_at_18%_20%,rgba(57,255,20,0.12),transparent_31rem),linear-gradient(180deg,rgba(0,0,0,0.14),#000_84%)]"></div>

        <div class="mx-auto max-w-[1700px] px-5 py-10 sm:px-7 lg:px-10 lg:py-16">
            @if (hasDownloadError)
            {
                <div role="alert"
                     aria-live="polite"
                     class="mb-8 flex flex-col gap-4 rounded-lg border border-amber-400/45 bg-amber-500/10 p-5 shadow-amber sm:flex-row sm:items-start">
                    <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-md border border-amber-400/45 bg-black text-amber-300">
                        <svg class="h-6 w-6"
                             viewBox="0 0 24 24"
                             fill="none"
                             stroke="currentColor"
                             stroke-width="1.8"
                             aria-hidden="true">
                            <path d="M12 3 2.7 20h18.6L12 3Z" />
                            <path d="M12 9v5" />
                            <circle cx="12" cy="17" r=".8" fill="currentColor" stroke="none" />
                        </svg>
                    </div>

                    <div class="min-w-0">
                        <p class="text-[10px] font-bold uppercase tracking-[0.26em] text-amber-400">
                            @SharedLocalizer["GoldenCat_AlertTitle"]
                        </p>
                        <p class="mt-2 text-sm leading-6 text-amber-100 sm:text-base">
                            @SharedLocalizer["GoldenCatDownloadUnavailable"]
                        </p>
                    </div>
                </div>
            }

            <div class="grid items-center gap-12 xl:grid-cols-[minmax(0,1.08fr)_minmax(31rem,0.92fr)] xl:gap-16">
                <div class="max-w-4xl">
                    <div class="inline-flex items-center gap-3 rounded border border-green-500/30 bg-black/75 px-3 py-2 text-[10px] font-bold uppercase tracking-[0.26em] text-green-300 shadow-phosphor">
                        <span class="h-2 w-2 rounded-full bg-green-400 animate-signal-pulse"></span>
                        @SharedLocalizer["GoldenCat_Signal"]
                    </div>

                    <p class="mt-8 terminal-kicker">
                        @SharedLocalizer["GoldenCat_Eyebrow"]
                    </p>

                    <h1 class="mt-4 font-display text-5xl uppercase leading-[0.92] tracking-[-0.045em] text-green-100 text-glow-cyan sm:text-6xl lg:text-7xl 2xl:text-8xl">
                        GoldenCat<br />Launcher
                    </h1>

                    <p class="mt-7 max-w-3xl text-base leading-8 text-slate-300 sm:text-lg">
                        @SharedLocalizer["GoldenCat_HeroDescription"]
                    </p>

                    <div class="mt-9 flex flex-col gap-4 sm:flex-row sm:items-center">
                        <a asp-route="DownloadGoldenCat"
                           aria-label="@SharedLocalizer["GoldenCat_DownloadAccessibilityLabel"]"
                           class="terminal-button min-h-14 px-6 py-4 text-center shadow-phosphor-strong">
                            <svg class="h-5 w-5"
                                 viewBox="0 0 24 24"
                                 fill="none"
                                 stroke="currentColor"
                                 stroke-width="1.8"
                                 aria-hidden="true">
                                <path d="M12 3v12" />
                                <path d="m7 10 5 5 5-5" />
                                <path d="M4 21h16" />
                            </svg>
                            @SharedLocalizer["GoldenCat_DownloadButton"]
                        </a>

                        <div class="border-l border-green-500/20 pl-4 text-xs leading-5 text-slate-500">
                            <span class="block uppercase tracking-[0.18em] text-green-500">
                                @SharedLocalizer["GoldenCat_DownloadHintLabel"]
                            </span>
                            <span class="mt-1 block">
                                @SharedLocalizer["GoldenCat_DownloadHint"]
                            </span>
                        </div>
                    </div>

                    <div class="mt-8 inline-flex max-w-full items-center gap-3 rounded-md border border-amber-400/35 bg-amber-500/10 px-4 py-3 text-sm text-amber-100 shadow-amber">
                        <svg class="h-5 w-5 shrink-0 text-amber-400"
                             viewBox="0 0 24 24"
                             fill="none"
                             stroke="currentColor"
                             stroke-width="1.8"
                             aria-hidden="true">
                            <rect x="3" y="4" width="18" height="14" rx="1.5" />
                            <path d="M8 21h8M12 18v3" />
                        </svg>
                        <span>
                            <span class="font-bold uppercase tracking-[0.12em] text-amber-300">
                                @SharedLocalizer["GoldenCat_SystemRequirementLabel"]
                            </span>
                            <span class="ml-1 text-amber-100">
                                @SharedLocalizer["GoldenCat_SystemRequirement"]
                            </span>
                        </span>
                    </div>
                </div>

                <aside class="terminal-panel relative overflow-hidden rounded-xl p-5 sm:p-7">
                    <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(135deg,rgba(57,255,20,0.05),transparent_46%,rgba(245,158,11,0.06))]"></div>

                    <div class="relative">
                        <div class="flex items-center justify-between border-b border-green-500/15 pb-4">
                            <span class="terminal-kicker">
                                @SharedLocalizer["GoldenCat_OfficialHub"]
                            </span>
                            <span class="inline-flex items-center gap-2 text-[10px] uppercase tracking-[0.2em] text-green-400">
                                <span class="h-1.5 w-1.5 rounded-full bg-green-400 animate-signal-pulse"></span>
                                @SharedLocalizer["GoldenCat_ChannelValue"]
                            </span>
                        </div>

                        <div class="relative mx-auto mt-8 aspect-square max-w-md">
                            <div class="absolute inset-[8%] rounded-full border border-green-500/15"></div>
                            <div class="absolute inset-[22%] rounded-full border border-green-500/20"></div>
                            <div class="absolute inset-[36%] rounded-full border border-amber-400/25"></div>
                            <div class="absolute left-1/2 top-[8%] h-[84%] w-px -translate-x-1/2 bg-green-500/10"></div>
                            <div class="absolute left-[8%] top-1/2 h-px w-[84%] -translate-y-1/2 bg-green-500/10"></div>

                            <div class="absolute inset-[28%] flex items-center justify-center rounded-2xl border border-amber-400/55 bg-black shadow-[0_0_44px_rgba(245,158,11,0.14)]">
                                <svg class="h-24 w-24 text-amber-300 sm:h-28 sm:w-28"
                                     viewBox="0 0 120 120"
                                     fill="none"
                                     aria-hidden="true">
                                    <path d="M35 46 24 22l25 15M85 46l11-24-25 15"
                                          stroke="currentColor"
                                          stroke-width="4"
                                          stroke-linejoin="round" />
                                    <path d="M32 47c4-17 18-27 28-27s24 10 28 27c4 20-5 45-28 45S28 67 32 47Z"
                                          stroke="currentColor"
                                          stroke-width="4" />
                                    <path d="M43 55c5-5 11-5 16 0M61 55c5-5 11-5 16 0M52 69c5 4 11 4 16 0"
                                          stroke="currentColor"
                                          stroke-width="3"
                                          stroke-linecap="round" />
                                    <path d="M60 61v5"
                                          stroke="currentColor"
                                          stroke-width="3"
                                          stroke-linecap="round" />
                                    <path d="M40 83 23 98M80 83l17 15"
                                          stroke="currentColor"
                                          stroke-width="4"
                                          stroke-linecap="round" />
                                </svg>
                            </div>

                            <div class="absolute left-1/2 top-[2%] -translate-x-1/2 rounded border border-green-500/25 bg-black px-3 py-1 text-[9px] uppercase tracking-[0.2em] text-green-400">
                                WPF
                            </div>
                            <div class="absolute bottom-[8%] left-[4%] rounded border border-green-500/25 bg-black px-3 py-1 text-[9px] uppercase tracking-[0.2em] text-green-400">
                                .NET 10
                            </div>
                            <div class="absolute bottom-[8%] right-[2%] rounded border border-amber-400/30 bg-black px-3 py-1 text-[9px] uppercase tracking-[0.2em] text-amber-300">
                                WIN-X64
                            </div>
                        </div>

                        <dl class="mt-7 grid grid-cols-1 gap-3 sm:grid-cols-3">
                            <div class="rounded border border-green-500/20 bg-black/70 p-4">
                                <dt class="text-[9px] uppercase tracking-[0.2em] text-slate-600">
                                    @SharedLocalizer["GoldenCat_PlatformLabel"]
                                </dt>
                                <dd class="mt-2 text-sm font-bold uppercase text-green-200">
                                    @SharedLocalizer["GoldenCat_PlatformValue"]
                                </dd>
                            </div>
                            <div class="rounded border border-green-500/20 bg-black/70 p-4">
                                <dt class="text-[9px] uppercase tracking-[0.2em] text-slate-600">
                                    @SharedLocalizer["GoldenCat_FrameworkLabel"]
                                </dt>
                                <dd class="mt-2 text-sm font-bold uppercase text-green-200">
                                    @SharedLocalizer["GoldenCat_FrameworkValue"]
                                </dd>
                            </div>
                            <div class="rounded border border-green-500/20 bg-black/70 p-4">
                                <dt class="text-[9px] uppercase tracking-[0.2em] text-slate-600">
                                    @SharedLocalizer["GoldenCat_ChannelLabel"]
                                </dt>
                                <dd class="mt-2 text-sm font-bold uppercase text-amber-300">
                                    @SharedLocalizer["GoldenCat_ChannelValue"]
                                </dd>
                            </div>
                        </dl>
                    </div>
                </aside>
            </div>
        </div>
    </section>

    <section class="relative border-b border-green-500/15">
        <div class="mx-auto max-w-[1700px] px-5 py-16 sm:px-7 lg:px-10 lg:py-24">
            <div class="max-w-4xl">
                <p class="terminal-kicker">
                    @SharedLocalizer["GoldenCat_ModulesEyebrow"]
                </p>
                <h2 class="mt-4 font-display text-3xl uppercase tracking-[0.04em] text-green-100 text-glow-cyan sm:text-5xl">
                    @SharedLocalizer["GoldenCat_ModulesTitle"]
                </h2>
                <p class="mt-5 max-w-3xl text-sm leading-7 text-slate-400 sm:text-base">
                    @SharedLocalizer["GoldenCat_ModulesDescription"]
                </p>
            </div>

            <div class="mt-12 grid gap-5 lg:grid-cols-3">
                <article tabindex="0"
                         class="group terminal-panel relative overflow-hidden rounded-xl p-6 transition duration-300 hover:-translate-y-1 hover:border-green-400/50 hover:shadow-phosphor-strong focus-visible:-translate-y-1 sm:p-7">
                    <div class="pointer-events-none absolute -right-12 -top-12 h-40 w-40 rounded-full bg-green-500/5 blur-2xl transition group-hover:bg-green-500/10"></div>
                    <div class="relative">
                        <div class="flex items-start justify-between gap-5">
                            <div class="flex h-14 w-14 items-center justify-center rounded-lg border border-green-400/35 bg-green-500/10 text-green-300 shadow-phosphor">
                                <svg class="h-7 w-7"
                                     viewBox="0 0 24 24"
                                     fill="none"
                                     stroke="currentColor"
                                     stroke-width="1.6"
                                     aria-hidden="true">
                                    <path d="M3 18 8.5 8l3 5 2.5-4 7 9H3Z" />
                                    <path d="m5 18 4-4 2 2 3-3 5 5" />
                                    <circle cx="17" cy="6" r="2" />
                                </svg>
                            </div>
                            <span class="rounded border border-green-500/25 px-2 py-1 text-[9px] uppercase tracking-[0.2em] text-green-500">
                                @SharedLocalizer["GoldenCat_NormalMapsTag"]
                            </span>
                        </div>
                        <h3 class="mt-7 font-display text-xl uppercase tracking-[0.06em] text-green-100 transition group-hover:text-green-300">
                            @SharedLocalizer["GoldenCat_NormalMapsTitle"]
                        </h3>
                        <p class="mt-4 text-sm leading-7 text-slate-400">
                            @SharedLocalizer["GoldenCat_NormalMapsDescription"]
                        </p>
                        <div class="mt-7 h-px bg-gradient-to-r from-green-400/70 via-green-500/15 to-transparent"></div>
                        <p class="mt-4 text-[10px] uppercase tracking-[0.2em] text-green-600 transition group-hover:text-green-400">
                            @SharedLocalizer["GoldenCat_ModuleReady"]
                        </p>
                    </div>
                </article>

                <article tabindex="0"
                         class="group terminal-panel relative overflow-hidden rounded-xl p-6 transition duration-300 hover:-translate-y-1 hover:border-amber-400/50 hover:shadow-amber focus-visible:-translate-y-1 sm:p-7">
                    <div class="pointer-events-none absolute -right-12 -top-12 h-40 w-40 rounded-full bg-amber-500/5 blur-2xl transition group-hover:bg-amber-500/10"></div>
                    <div class="relative">
                        <div class="flex items-start justify-between gap-5">
                            <div class="flex h-14 w-14 items-center justify-center rounded-lg border border-amber-400/35 bg-amber-500/10 text-amber-300 shadow-amber">
                                <svg class="h-7 w-7"
                                     viewBox="0 0 24 24"
                                     fill="none"
                                     stroke="currentColor"
                                     stroke-width="1.6"
                                     aria-hidden="true">
                                    <path d="m12 3 8 4.5v9L12 21l-8-4.5v-9L12 3Z" />
                                    <path d="m4 7.5 8 4.5 8-4.5M12 12v9" />
                                    <path d="m8.5 5 8 4.5" />
                                </svg>
                            </div>
                            <span class="rounded border border-amber-400/25 px-2 py-1 text-[9px] uppercase tracking-[0.2em] text-amber-400">
                                @SharedLocalizer["GoldenCat_ConverterTag"]
                            </span>
                        </div>
                        <h3 class="mt-7 font-display text-xl uppercase tracking-[0.06em] text-green-100 transition group-hover:text-amber-200">
                            @SharedLocalizer["GoldenCat_ConverterTitle"]
                        </h3>
                        <p class="mt-4 text-sm leading-7 text-slate-400">
                            @SharedLocalizer["GoldenCat_ConverterDescription"]
                        </p>
                        <div class="mt-7 h-px bg-gradient-to-r from-amber-400/70 via-amber-500/15 to-transparent"></div>
                        <p class="mt-4 text-[10px] uppercase tracking-[0.2em] text-amber-600 transition group-hover:text-amber-400">
                            @SharedLocalizer["GoldenCat_ModuleReady"]
                        </p>
                    </div>
                </article>

                <article tabindex="0"
                         class="group terminal-panel relative overflow-hidden rounded-xl p-6 transition duration-300 hover:-translate-y-1 hover:border-green-400/50 hover:shadow-phosphor-strong focus-visible:-translate-y-1 sm:p-7">
                    <div class="pointer-events-none absolute -right-12 -top-12 h-40 w-40 rounded-full bg-green-500/5 blur-2xl transition group-hover:bg-green-500/10"></div>
                    <div class="relative">
                        <div class="flex items-start justify-between gap-5">
                            <div class="flex h-14 w-14 items-center justify-center rounded-lg border border-green-400/35 bg-green-500/10 text-green-300 shadow-phosphor">
                                <svg class="h-7 w-7"
                                     viewBox="0 0 24 24"
                                     fill="none"
                                     stroke="currentColor"
                                     stroke-width="1.6"
                                     aria-hidden="true">
                                    <path d="M12 3v4M12 17v4M3 12h4M17 12h4" />
                                    <path d="m5.6 5.6 2.8 2.8M15.6 15.6l2.8 2.8M18.4 5.6l-2.8 2.8M8.4 15.6l-2.8 2.8" />
                                    <circle cx="12" cy="12" r="4" />
                                    <path d="m10.5 12 1 1 2-2" />
                                </svg>
                            </div>
                            <span class="rounded border border-green-500/25 px-2 py-1 text-[9px] uppercase tracking-[0.2em] text-green-500">
                                @SharedLocalizer["GoldenCat_AutoPatcherTag"]
                            </span>
                        </div>
                        <h3 class="mt-7 font-display text-xl uppercase tracking-[0.06em] text-green-100 transition group-hover:text-green-300">
                            @SharedLocalizer["GoldenCat_AutoPatcherTitle"]
                        </h3>
                        <p class="mt-4 text-sm leading-7 text-slate-400">
                            @SharedLocalizer["GoldenCat_AutoPatcherDescription"]
                        </p>
                        <div class="mt-7 h-px bg-gradient-to-r from-green-400/70 via-green-500/15 to-transparent"></div>
                        <p class="mt-4 text-[10px] uppercase tracking-[0.2em] text-green-600 transition group-hover:text-green-400">
                            @SharedLocalizer["GoldenCat_ModuleReady"]
                        </p>
                    </div>
                </article>
            </div>
        </div>
    </section>

    <section class="relative border-b border-green-500/15">
        <div class="crt-grid-background pointer-events-none absolute inset-0 opacity-15"></div>
        <div class="relative mx-auto max-w-[1700px] px-5 py-16 sm:px-7 lg:px-10 lg:py-24">
            <div class="grid gap-10 xl:grid-cols-[0.78fr_1.22fr] xl:items-start">
                <div class="max-w-xl">
                    <p class="terminal-kicker">
                        @SharedLocalizer["GoldenCat_WorkflowEyebrow"]
                    </p>
                    <h2 class="mt-4 font-display text-3xl uppercase tracking-[0.04em] text-green-100 text-glow-cyan sm:text-5xl">
                        @SharedLocalizer["GoldenCat_WorkflowTitle"]
                    </h2>
                    <p class="mt-5 text-sm leading-7 text-slate-400 sm:text-base">
                        @SharedLocalizer["GoldenCat_WorkflowDescription"]
                    </p>
                </div>

                <ol class="grid gap-4 md:grid-cols-3">
                    <li class="terminal-panel rounded-lg p-5">
                        <span class="font-display text-3xl text-green-400 text-glow-cyan">01</span>
                        <h3 class="mt-5 text-sm font-bold uppercase tracking-[0.12em] text-green-100">
                            @SharedLocalizer["GoldenCat_WorkflowStep1Title"]
                        </h3>
                        <p class="mt-3 text-xs leading-6 text-slate-500">
                            @SharedLocalizer["GoldenCat_WorkflowStep1Description"]
                        </p>
                    </li>
                    <li class="terminal-panel-amber rounded-lg p-5">
                        <span class="font-display text-3xl text-amber-400">02</span>
                        <h3 class="mt-5 text-sm font-bold uppercase tracking-[0.12em] text-amber-100">
                            @SharedLocalizer["GoldenCat_WorkflowStep2Title"]
                        </h3>
                        <p class="mt-3 text-xs leading-6 text-slate-500">
                            @SharedLocalizer["GoldenCat_WorkflowStep2Description"]
                        </p>
                    </li>
                    <li class="terminal-panel rounded-lg p-5">
                        <span class="font-display text-3xl text-green-400 text-glow-cyan">03</span>
                        <h3 class="mt-5 text-sm font-bold uppercase tracking-[0.12em] text-green-100">
                            @SharedLocalizer["GoldenCat_WorkflowStep3Title"]
                        </h3>
                        <p class="mt-3 text-xs leading-6 text-slate-500">
                            @SharedLocalizer["GoldenCat_WorkflowStep3Description"]
                        </p>
                    </li>
                </ol>
            </div>
        </div>
    </section>

    <section class="relative isolate overflow-hidden">
        <div class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(circle_at_center,rgba(57,255,20,0.10),transparent_33rem)]"></div>
        <div class="mx-auto max-w-[1200px] px-5 py-16 text-center sm:px-7 lg:py-24">
            <p class="terminal-kicker">
                @SharedLocalizer["GoldenCat_DownloadPanelEyebrow"]
            </p>
            <h2 class="mt-4 font-display text-3xl uppercase tracking-[0.04em] text-green-100 text-glow-cyan sm:text-5xl">
                @SharedLocalizer["GoldenCat_DownloadPanelTitle"]
            </h2>
            <p class="mx-auto mt-5 max-w-3xl text-sm leading-7 text-slate-400 sm:text-base">
                @SharedLocalizer["GoldenCat_DownloadPanelDescription"]
            </p>

            <a asp-route="DownloadGoldenCat"
               aria-label="@SharedLocalizer["GoldenCat_DownloadAccessibilityLabel"]"
               class="terminal-button mt-9 min-h-14 px-7 py-4 shadow-phosphor-strong">
                <svg class="h-5 w-5"
                     viewBox="0 0 24 24"
                     fill="none"
                     stroke="currentColor"
                     stroke-width="1.8"
                     aria-hidden="true">
                    <path d="M12 3v12" />
                    <path d="m7 10 5 5 5-5" />
                    <path d="M4 21h16" />
                </svg>
                @SharedLocalizer["GoldenCat_DownloadButton"]
            </a>

            <p class="mt-5 text-[10px] uppercase tracking-[0.2em] text-slate-600">
                @SharedLocalizer["GoldenCat_SystemRequirement"]
            </p>
        </div>
    </section>
</div>
