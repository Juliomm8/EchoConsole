@using System.Text.Json
@model EchoConsole.Web.Models.Profile.ProfileIndexViewModel

@{
    ViewData["Title"] = SharedLocalizer["Profile_PageTitle"].Value;
    ViewData["TitleResourceKey"] = "Profile_PageTitle";

    string LocalizedRole(string role) => role switch
    {
        "Admin" => SharedLocalizer["Role_Admin"].Value,
        "Moderator" => SharedLocalizer["Role_Moderator"].Value,
        "Viewer" => SharedLocalizer["Role_Viewer"].Value,
        _ => SharedLocalizer["Role_User"].Value
    };

    string LocalizedStatus(string status) => status switch
    {
        "Active" => SharedLocalizer["Common_Active"].Value,
        "Suspended" => SharedLocalizer["Common_Suspended"].Value,
        "Expired" => SharedLocalizer["Status_Expired"].Value,
        _ => status
    };

    // Device ownership notification state
    var claimStatusType = TempData["ClaimStatusType"]?.ToString();
    var claimStatusMessage = TempData["ClaimStatusMessage"]?.ToString();
    var isClaimSuccess = string.Equals(claimStatusType, "success", StringComparison.OrdinalIgnoreCase);

    // Profile update notification state
    var profileStatusType = TempData["ProfileStatusType"]?.ToString();
    var profileStatusMessage = TempData["ProfileStatusMessage"]?.ToString();
    var isProfileSuccess = string.Equals(profileStatusType, "success", StringComparison.OrdinalIgnoreCase);

    var availableThemes = new[] { "cyan", "fuchsia", "amber" };
    var availableAvatars = new[] { "avatar-01", "avatar-02", "avatar-03", "avatar-04", "avatar-05" };
    var unlinkConfirmJson = JsonSerializer.Serialize(
        SharedLocalizer["Profile_UnlinkConfirm"].Value);
}

<div class="min-h-screen bg-[#070B12] text-slate-100">
    <div class="mx-auto max-w-[1600px] px-6 py-8">
        <div class="grid grid-cols-1 gap-6 xl:grid-cols-[1.2fr_0.8fr]">
            <section class="rounded-2xl border border-fuchsia-500/20 bg-slate-950/70 p-8 shadow-[0_0_30px_rgba(232,121,249,0.05)]">
                <p class="font-display text-xs uppercase tracking-[0.35em] text-fuchsia-300">
                    @SharedLocalizer["Profile_OperatorIdentity"]
                </p>

                <h1 class="mt-3 font-display text-4xl uppercase tracking-[0.16em] text-white">
                    @Model.Alias
                </h1>

                <p class="mt-3 max-w-2xl text-sm text-slate-400">
                    @SharedLocalizer["Profile_HeroSubtitle"]
                </p>

                <div class="mt-6 flex flex-wrap gap-3">
                    <span class="rounded-full border border-cyan-400/20 bg-cyan-500/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-cyan-200">
                        @SharedLocalizer["Profile_ThemeLabel"]: @Model.Theme
                    </span>

                    <span class="rounded-full border border-fuchsia-400/20 bg-fuchsia-500/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-fuchsia-200">
                        @SharedLocalizer["Profile_RoleLabel"]: @LocalizedRole(Model.Role)
                    </span>

                    <span class="rounded-full border border-emerald-400/20 bg-emerald-500/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-emerald-200">
                        @SharedLocalizer["Profile_StatusLabel"]: @LocalizedStatus(Model.Status)
                    </span>
                </div>

                <div class="mt-8 grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-5">
                    <div class="rounded-xl border border-slate-800 bg-slate-900/70 p-4">
                        <div class="text-xs uppercase tracking-[0.22em] text-slate-500">
                            @SharedLocalizer["Profile_Installations"]
                        </div>
                        <div class="mt-2 font-display text-2xl text-fuchsia-300">
                            @Model.TotalInstallations.ToString("N0")
                        </div>
                    </div>

                    <div class="rounded-xl border border-slate-800 bg-slate-900/70 p-4">
                        <div class="text-xs uppercase tracking-[0.22em] text-slate-500">
                            @SharedLocalizer["Profile_Sessions"]
                        </div>
                        <div class="mt-2 font-display text-2xl text-fuchsia-300">
                            @Model.TotalSessions.ToString("N0")
                        </div>
                    </div>

                    <div class="rounded-xl border border-slate-800 bg-slate-900/70 p-4">
                        <div class="text-xs uppercase tracking-[0.22em] text-slate-500">
                            @SharedLocalizer["Profile_PlayTime"]
                        </div>
                        <div class="mt-2 font-display text-2xl text-fuchsia-300">
                            @Model.TotalPlayTimeLabel
                        </div>
                    </div>

                    <div class="rounded-xl border border-slate-800 bg-slate-900/70 p-4">
                        <div class="text-xs uppercase tracking-[0.22em] text-slate-500">
                            @SharedLocalizer["Profile_FavoriteBuild"]
                        </div>
                        <div class="mt-2 font-display text-2xl text-fuchsia-300">
                            @Model.FavoriteBuild
                        </div>
                    </div>

                    <div class="rounded-xl border border-slate-800 bg-slate-900/70 p-4">
                        <div class="text-xs uppercase tracking-[0.22em] text-slate-500">
                            @SharedLocalizer["Profile_LastActivity"]
                        </div>
                        <div class="mt-2 font-display text-2xl text-fuchsia-300">
                            @Model.LastActivityLabel
                        </div>
                    </div>
                </div>
            </section>

            <aside class="rounded-2xl border border-cyan-500/20 bg-slate-950/70 p-8 shadow-[0_0_30px_rgba(0,255,255,0.05)]">
                <p class="font-display text-xs uppercase tracking-[0.35em] text-cyan-300">
                    @SharedLocalizer["Profile_PlayerCard"]
                </p>

                <div class="mt-6 rounded-2xl border border-cyan-400/20 bg-gradient-to-br from-slate-900 to-slate-950 p-6 shadow-[0_0_24px_rgba(0,255,255,0.04)]">
                    <div class="flex items-center gap-4">
                        <div class="flex h-20 w-20 items-center justify-center rounded-2xl border border-cyan-400/20 bg-cyan-500/10 font-display text-2xl uppercase tracking-[0.18em] text-cyan-200">
                            @(Model.Alias.Length >= 2 ? Model.Alias.Substring(0, 2).ToUpperInvariant() : Model.Alias.ToUpperInvariant())
                        </div>

                        <div>
                            <div class="font-display text-2xl uppercase tracking-[0.12em] text-white">
                                @Model.Alias
                            </div>
                            <div class="mt-1 text-sm text-slate-400">
                                @Model.Email
                            </div>
                        </div>
                    </div>

                    <div class="mt-6 grid grid-cols-2 gap-3">
                        <div class="rounded-xl border border-slate-800 bg-slate-900/70 p-3">
                            <div class="text-xs uppercase tracking-[0.18em] text-slate-500">
                                @SharedLocalizer["Profile_Avatar"]
                            </div>
                            <div class="mt-1 text-sm font-semibold text-cyan-200">
                                @Model.AvatarKey
                            </div>
                        </div>

                        <div class="rounded-xl border border-slate-800 bg-slate-900/70 p-3">
                            <div class="text-xs uppercase tracking-[0.18em] text-slate-500">
                                @SharedLocalizer["Profile_ThemeLabel"]
                            </div>
                            <div class="mt-1 text-sm font-semibold text-cyan-200">
                                @Model.Theme
                            </div>
                        </div>

                        <div class="rounded-xl border border-slate-800 bg-slate-900/70 p-3">
                            <div class="text-xs uppercase tracking-[0.18em] text-slate-500">
                                @SharedLocalizer["Profile_Name"]
                            </div>
                            <div class="mt-1 text-sm font-semibold text-cyan-200">
                                @Model.Name
                            </div>
                        </div>

                        <div class="rounded-xl border border-slate-800 bg-slate-900/70 p-3">
                            <div class="text-xs uppercase tracking-[0.18em] text-slate-500">
                                @SharedLocalizer["Profile_Access"]
                            </div>
                            <div class="mt-1 text-sm font-semibold text-cyan-200">
                                @LocalizedRole(Model.Role)
                            </div>
                        </div>
                    </div>
                </div>
            </aside>
        </div>

        <section class="mt-6 rounded-2xl border border-cyan-500/20 bg-slate-950/70 p-8 shadow-[0_0_30px_rgba(0,255,255,0.05)]">
            <div class="grid grid-cols-1 gap-6 xl:grid-cols-[0.8fr_1.2fr]">
                <div>
                    <p class="font-display text-xs uppercase tracking-[0.35em] text-cyan-300">
                        @SharedLocalizer["Profile_SettingsBadge"]
                    </p>

                    <h2 class="mt-2 font-display text-2xl uppercase tracking-[0.14em] text-white">
                        @SharedLocalizer["Profile_SettingsTitle"]
                    </h2>

                    <p class="mt-3 text-sm leading-6 text-slate-400">
                        @SharedLocalizer["Profile_SettingsSubtitle"]
                    </p>
                </div>

                <div class="rounded-2xl border border-slate-800 bg-slate-900/60 p-5">
                    @if (!string.IsNullOrWhiteSpace(profileStatusMessage))
                    {
                        <div class="mb-4 rounded-xl border @(isProfileSuccess ? "border-emerald-500/25 bg-emerald-500/10 text-emerald-200" : "border-rose-500/25 bg-rose-500/10 text-rose-200") px-4 py-3 text-sm">
                            @profileStatusMessage
                        </div>
                    }

                    <form asp-controller="Profile"
                          asp-action="UpdateProfile"
                          method="post"
                          class="space-y-4">
                        @Html.AntiForgeryToken()

                        <div>
                            <label for="alias" class="mb-2 block text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">
                                @SharedLocalizer["Profile_Alias"]
                            </label>

                            <input id="alias"
                                   name="Alias"
                                   type="text"
                                   value="@Model.Alias"
                                   minlength="3"
                                   maxlength="32"
                                   autocomplete="off"
                                   class="w-full rounded-xl border border-cyan-500/20 bg-slate-950/80 px-4 py-3 text-sm text-slate-100 outline-none transition placeholder:text-slate-600 focus:border-cyan-400/40" />
                        </div>

                        <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                            <div>
                                <label for="avatarKey" class="mb-2 block text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">
                                    @SharedLocalizer["Profile_Avatar"]
                                </label>

                                <select id="avatarKey"
                                        name="AvatarKey"
                                        class="w-full rounded-xl border border-cyan-500/20 bg-slate-950/80 px-4 py-3 text-sm text-slate-100 outline-none transition focus:border-cyan-400/40">
                                    @foreach (var avatar in availableAvatars)
                                    {
                                        <option value="@avatar" selected="@(string.Equals(Model.AvatarKey, avatar, StringComparison.OrdinalIgnoreCase))">
                                            @avatar
                                        </option>
                                    }
                                </select>
                            </div>

                            <div>
                                <label for="theme" class="mb-2 block text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">
                                    @SharedLocalizer["Profile_ThemeLabel"]
                                </label>

                                <select id="theme"
                                        name="Theme"
                                        class="w-full rounded-xl border border-cyan-500/20 bg-slate-950/80 px-4 py-3 text-sm text-slate-100 outline-none transition focus:border-cyan-400/40">
                                    @foreach (var theme in availableThemes)
                                    {
                                        <option value="@theme" selected="@(string.Equals(Model.Theme, theme, StringComparison.OrdinalIgnoreCase))">
                                            @theme
                                        </option>
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="flex flex-wrap gap-3 pt-2">
                            <button type="submit"
                                    class="inline-flex rounded-xl border border-cyan-400/25 bg-cyan-500/10 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-cyan-200 transition hover:bg-cyan-500/15">
                                @SharedLocalizer["Profile_SaveProfile"]
                            </button>

                            <div class="rounded-xl border border-slate-800 bg-slate-950/60 px-5 py-3 text-xs uppercase tracking-[0.18em] text-slate-500">
                                @SharedLocalizer["Profile_RoleStatusLocked"]
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </section>

        <section class="mt-6 rounded-2xl border border-fuchsia-500/20 bg-slate-950/70 p-8 shadow-[0_0_30px_rgba(232,121,249,0.05)]">
            <div class="grid grid-cols-1 gap-6 xl:grid-cols-[0.9fr_1.1fr]">
                <div>
                    <p class="font-display text-xs uppercase tracking-[0.35em] text-fuchsia-300">
                        @SharedLocalizer["Profile_OwnershipBadge"]
                    </p>

                    <h2 class="mt-2 font-display text-2xl uppercase tracking-[0.14em] text-white">
                        @SharedLocalizer["Profile_LinkTitle"]
                    </h2>

                    <p class="mt-3 text-sm leading-6 text-slate-400">
                        @SharedLocalizer["Profile_LinkSubtitle"]
                    </p>
                </div>

                <div class="rounded-2xl border border-slate-800 bg-slate-900/60 p-5">
                    @if (!string.IsNullOrWhiteSpace(claimStatusMessage))
                    {
                        <div class="mb-4 rounded-xl border @(isClaimSuccess ? "border-emerald-500/25 bg-emerald-500/10 text-emerald-200" : "border-rose-500/25 bg-rose-500/10 text-rose-200") px-4 py-3 text-sm">
                            @claimStatusMessage
                        </div>
                    }

                    <form asp-controller="Profile"
                          asp-action="ClaimInstallation"
                          method="post"
                          class="space-y-4">
                        @Html.AntiForgeryToken()

                        <div>
                            <label for="installationId" class="mb-2 block text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">
                                @SharedLocalizer["Common_InstallationId"]
                            </label>

                            <input id="installationId"
                                   name="installationId"
                                   type="text"
                                   autocomplete="off"
                                   placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
                                   class="w-full rounded-xl border border-cyan-500/20 bg-slate-950/80 px-4 py-3 text-sm text-slate-100 outline-none transition placeholder:text-slate-600 focus:border-cyan-400/40" />
                        </div>

                        <button type="submit"
                                class="inline-flex rounded-xl border border-cyan-400/25 bg-cyan-500/10 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-cyan-200 transition hover:bg-cyan-500/15">
                            @SharedLocalizer["Profile_LinkDevice"]
                        </button>
                    </form>
                </div>
            </div>
        </section>

        <section class="mt-6 rounded-2xl border border-cyan-500/20 bg-slate-950/70 p-8 shadow-[0_0_30px_rgba(0,255,255,0.05)]">
            <div class="flex flex-col gap-2 md:flex-row md:items-center md:justify-between">
                <div>
                    <p class="font-display text-xs uppercase tracking-[0.35em] text-cyan-300">
                        @SharedLocalizer["Profile_LinkedInstallationsBadge"]
                    </p>
                    <h2 class="mt-2 font-display text-2xl uppercase tracking-[0.14em] text-white">
                        @SharedLocalizer["Profile_OwnedDevices"]
                    </h2>
                    <p class="mt-3 max-w-2xl text-sm text-slate-400">
                        @SharedLocalizer["Profile_OwnedDevicesSubtitle"]
                    </p>
                    <a asp-controller="Profile"
                       asp-action="Sessions"
                       class="inline-flex rounded-xl border border-fuchsia-400/25 bg-fuchsia-500/10 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-fuchsia-200 transition hover:bg-fuchsia-500/15">
                        @SharedLocalizer["Profile_ViewSessionHistory"]
                    </a>
                </div>

                <div class="rounded-xl border border-cyan-400/15 bg-cyan-500/10 px-4 py-3 text-sm text-cyan-200">
                    @SharedLocalizer["Profile_DeviceCount", Model.Installations.Count]
                </div>
            </div>

            @if (Model.Installations.Count == 0)
            {
                <div class="mt-6 rounded-2xl border border-slate-800 bg-slate-900/70 p-8 text-center">
                    <p class="font-display text-sm uppercase tracking-[0.24em] text-slate-400">
                        @SharedLocalizer["Profile_NoLinkedDevices"]
                    </p>

                    <p class="mx-auto mt-3 max-w-xl text-sm leading-6 text-slate-500">
                        @SharedLocalizer["Profile_NoLinkedDevicesDescription"]
                    </p>
                </div>
            }
            else
            {
                <div class="mt-6 overflow-x-auto">
                    <table class="min-w-full divide-y divide-slate-800">
                        <thead>
                            <tr class="text-left text-xs uppercase tracking-[0.18em] text-slate-500">
                                <th class="px-4 py-3">@SharedLocalizer["Common_Device"]</th>
                                <th class="px-4 py-3">@SharedLocalizer["Common_Platform"]</th>
                                <th class="px-4 py-3">@SharedLocalizer["Common_Build"]</th>
                                <th class="px-4 py-3">@SharedLocalizer["Common_Status"]</th>
                                <th class="px-4 py-3">@SharedLocalizer["Profile_FirstSeen"]</th>
                                <th class="px-4 py-3">@SharedLocalizer["Profile_LastUpdate"]</th>
                                <th class="px-4 py-3 text-right">@SharedLocalizer["Common_Actions"]</th>
                            </tr>
                        </thead>

                        <tbody class="divide-y divide-slate-900">
                            @foreach (var installation in Model.Installations)
                            {
                                <tr class="text-sm text-slate-300">
                                    <td class="px-4 py-4">
                                        <div class="font-medium text-white">@installation.DeviceName</div>
                                        <div class="text-xs text-slate-500">@installation.DeviceModel</div>
                                        <div class="mt-1 text-[11px] text-slate-600">@installation.InstallationId</div>
                                    </td>

                                    <td class="px-4 py-4">@installation.Platform</td>

                                    <td class="px-4 py-4">@installation.BuildVersion</td>

                                    <td class="px-4 py-4">
                                        <span class="inline-flex rounded-full border border-emerald-500/25 bg-emerald-500/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-emerald-300">
                                            @LocalizedStatus(installation.Status)
                                        </span>
                                    </td>

                                    <td class="px-4 py-4">@installation.FirstSeenLabel</td>

                                    <td class="px-4 py-4">@installation.LastUpdateLabel</td>

                                    <td class="px-4 py-4 text-right">
                                        <form asp-controller="Profile"
                                              asp-action="UnlinkInstallation"
                                              method="post"
                                              class="inline-flex"
                                              onsubmit='return confirm(@Html.Raw(unlinkConfirmJson));'>
                                            @Html.AntiForgeryToken()

                                            <input type="hidden"
                                                   name="installationId"
                                                   value="@installation.InstallationId" />

                                            <button type="submit"
                                                    class="rounded-xl border border-rose-400/25 bg-rose-500/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-rose-200 transition hover:bg-rose-500/15">
                                                @SharedLocalizer["Profile_Unlink"]
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    </div>
</div>