@model EchoConsole.Web.Models.Profile.ClaimInstallationViewModel

@{
    ViewData["Title"] = "PROFILE";
    ViewData["TitleI18nKey"] = "profile_page_title";
}

<div class="min-h-screen bg-[#070B12] text-slate-100">
    <div class="mx-auto max-w-4xl px-6 py-8">
        <div class="rounded-2xl border border-fuchsia-500/20 bg-slate-950/70 p-8 shadow-[0_0_30px_rgba(232,121,249,0.05)]">
            <p class="font-display text-xs uppercase tracking-[0.35em] text-fuchsia-300">
                Player Ownership
            </p>

            <h1 class="mt-3 font-display text-3xl uppercase tracking-[0.16em] text-white">
                Claim Installation
            </h1>

            <p class="mt-3 text-sm text-slate-400">
                Link a Cosmic Diner installation to your Echo Console account using its Installation ID.
            </p>

            @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
            {
                <div class="mt-6 rounded-xl border @(Model.IsSuccess ? "border-emerald-500/25 bg-emerald-500/10 text-emerald-200" : "border-rose-500/25 bg-rose-500/10 text-rose-200") px-4 py-3 text-sm">
                    @Model.StatusMessage
                </div>
            }

            <form asp-controller="Profile" asp-action="ClaimInstallation" method="post" class="mt-6 space-y-5">
                @Html.AntiForgeryToken()

                <div>
                    <label asp-for="InstallationId" class="mb-2 block text-sm font-medium text-slate-300"></label>
                    <input asp-for="InstallationId"
                           class="w-full rounded-xl border border-cyan-500/20 bg-slate-900/80 px-4 py-3 text-slate-100 outline-none transition focus:border-cyan-400/40"
                           placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx" />
                    <span asp-validation-for="InstallationId" class="mt-2 block text-sm text-rose-400"></span>
                </div>

                <div class="flex flex-wrap gap-3">
                    <button type="submit"
                            class="rounded-xl border border-cyan-400/25 bg-cyan-500/10 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-cyan-200 transition hover:bg-cyan-500/15">
                        Claim
                    </button>

                    <a asp-controller="Home"
                       asp-action="Index"
                       asp-fragment="my-stats"
                       class="rounded-xl border border-slate-700 bg-slate-900/70 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-slate-300 transition hover:border-cyan-400/20 hover:text-white">
                        Back to Home
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}