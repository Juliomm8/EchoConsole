@model EchoConsole.Web.Models.Profile.ProfileSessionDetailViewModel

@{
    ViewData["Title"] = "SESSION DETAIL";
    ViewData["TitleI18nKey"] = "profile_session_detail_page_title";
}

<div class="min-h-screen bg-[#070B12] text-slate-100">
    <div class="mx-auto max-w-[1600px] px-6 py-8">
        <section class="rounded-2xl border border-cyan-500/20 bg-slate-950/70 p-8 shadow-[0_0_30px_rgba(0,255,255,0.05)]">
            <div class="flex flex-col gap-4 xl:flex-row xl:items-start xl:justify-between">
                <div>
                    <p class="font-display text-xs uppercase tracking-[0.35em] text-cyan-300">
                        Terminal Report
                    </p>

                    <h1 class="mt-3 font-display text-3xl uppercase tracking-[0.16em] text-white">
                        Session Detail
                    </h1>

                    <p class="mt-3 max-w-3xl text-sm leading-6 text-slate-400">
                        Technical summary and chronological event timeline for a Cosmic Diner session linked to your owned installation.
                    </p>

                    <div class="mt-4 max-w-[720px] truncate text-xs text-slate-600" title="@Model.SessionId">
                        Session ID: @Model.SessionId
                    </div>
                </div>

                <div class="flex flex-wrap gap-3">
                    <a asp-controller="Profile"
                       asp-action="Sessions"
                       class="rounded-xl border border-slate-700 bg-slate-900/70 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-slate-300 transition hover:border-cyan-400/20 hover:text-white">
                        Back to History
                    </a>

                    @if (Model.IsLive)
                    {
                        <span class="rounded-xl border border-emerald-500/25 bg-emerald-500/10 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-emerald-300">
                            @Model.StatusLabel
                        </span>
                    }
                    else
                    {
                        <span class="rounded-xl border border-fuchsia-500/25 bg-fuchsia-500/10 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-fuchsia-300">
                            @Model.StatusLabel
                        </span>
                    }
                </div>
            </div>
        </section>

        <div class="mt-6 grid grid-cols-1 gap-6 xl:grid-cols-[1.2fr_0.8fr]">
            <section class="rounded-2xl border border-fuchsia-500/20 bg-slate-950/70 p-8 shadow-[0_0_30px_rgba(232,121,249,0.05)]">
                <p class="font-display text-xs uppercase tracking-[0.35em] text-fuchsia-300">
                    Session Timing
                </p>

                <div class="mt-6 grid grid-cols-1 gap-4 md:grid-cols-2">
                    <div class="rounded-xl border border-slate-800 bg-slate-900/70 p-5">
                        <div class="text-xs uppercase tracking-[0.22em] text-slate-500">
                            Started At
                        </div>
                        <div class="mt-2 text-lg font-semibold text-white">
                            @Model.StartedAtLabel
                        </div>
                    </div>

                    <div class="rounded-xl border border-slate-800 bg-slate-900/70 p-5">
                        <div class="text-xs uppercase tracking-[0.22em] text-slate-500">
                            Last Heartbeat
                        </div>
                        <div class="mt-2 text-lg font-semibold text-white">
                            @Model.LastHeartbeatLabel
                        </div>
                    </div>

                    <div class="rounded-xl border border-slate-800 bg-slate-900/70 p-5">
                        <div class="text-xs uppercase tracking-[0.22em] text-slate-500">
                            Ended At
                        </div>
                        <div class="mt-2 text-lg font-semibold text-white">
                            @Model.EndedAtLabel
                        </div>
                    </div>

                    <div class="rounded-xl border border-slate-800 bg-slate-900/70 p-5">
                        <div class="text-xs uppercase tracking-[0.22em] text-slate-500">
                            Duration
                        </div>
                        <div class="mt-2 text-lg font-semibold text-cyan-300">
                            @Model.DurationLabel
                        </div>
                    </div>
                </div>
            </section>

            <aside class="rounded-2xl border border-cyan-500/20 bg-slate-950/70 p-8 shadow-[0_0_30px_rgba(0,255,255,0.05)]">
                <p class="font-display text-xs uppercase tracking-[0.35em] text-cyan-300">
                    Device Card
                </p>

                <div class="mt-6 space-y-4">
                    <div class="rounded-xl border border-slate-800 bg-slate-900/70 p-5">
                        <div class="text-xs uppercase tracking-[0.22em] text-slate-500">
                            Device
                        </div>
                        <div class="mt-2 text-lg font-semibold text-white">
                            @Model.DeviceName
                        </div>
                        <div class="mt-1 text-xs text-slate-500">
                            @Model.DeviceModel
                        </div>
                    </div>

                    <div class="rounded-xl border border-slate-800 bg-slate-900/70 p-5">
                        <div class="text-xs uppercase tracking-[0.22em] text-slate-500">
                            Platform
                        </div>
                        <div class="mt-2 text-lg font-semibold text-cyan-300">
                            @Model.Platform
                        </div>
                    </div>

                    <div class="rounded-xl border border-slate-800 bg-slate-900/70 p-5">
                        <div class="text-xs uppercase tracking-[0.22em] text-slate-500">
                            Installation ID
                        </div>
                        <div class="mt-2 break-all text-xs text-slate-400">
                            @Model.InstallationId
                        </div>
                    </div>
                </div>
            </aside>
        </div>

        <section class="mt-6 rounded-2xl border border-cyan-500/20 bg-slate-950/70 p-8 shadow-[0_0_30px_rgba(0,255,255,0.05)]">
            <p class="font-display text-xs uppercase tracking-[0.35em] text-cyan-300">
                Gameplay State
            </p>

            <div class="mt-6 grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-4">
                <div class="rounded-xl border border-slate-800 bg-slate-900/70 p-5">
                    <div class="text-xs uppercase tracking-[0.22em] text-slate-500">
                        Build
                    </div>
                    <div class="mt-2 text-lg font-semibold text-fuchsia-300">
                        @Model.BuildVersion
                    </div>
                </div>

                <div class="rounded-xl border border-slate-800 bg-slate-900/70 p-5">
                    <div class="text-xs uppercase tracking-[0.22em] text-slate-500">
                        Current / Final Scene
                    </div>
                    <div class="mt-2 text-lg font-semibold text-white">
                        @Model.CurrentScene
                    </div>
                </div>

                <div class="rounded-xl border border-slate-800 bg-slate-900/70 p-5">
                    <div class="text-xs uppercase tracking-[0.22em] text-slate-500">
                        Game State
                    </div>
                    <div class="mt-2 text-lg font-semibold text-white">
                        @Model.CurrentGameState
                    </div>
                </div>

                <div class="rounded-xl border border-slate-800 bg-slate-900/70 p-5">
                    <div class="text-xs uppercase tracking-[0.22em] text-slate-500">
                        Phase
                    </div>
                    <div class="mt-2 text-lg font-semibold text-white">
                        @Model.CurrentPhase
                    </div>
                </div>
            </div>
        </section>

        <section class="mt-6 rounded-2xl border border-fuchsia-500/20 bg-slate-950/70 p-8 shadow-[0_0_30px_rgba(232,121,249,0.05)]">
            <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
                <div>
                    <p class="font-display text-xs uppercase tracking-[0.35em] text-fuchsia-300">
                        Event Timeline
                    </p>

                    <h2 class="mt-2 font-display text-2xl uppercase tracking-[0.14em] text-white">
                        Chronological Session Events
                    </h2>

                    <p class="mt-3 max-w-3xl text-sm leading-6 text-slate-400">
                        Ordered gameplay telemetry events received from the Cosmic Diner Unity client.
                    </p>
                </div>

                <div class="rounded-xl border border-fuchsia-400/20 bg-fuchsia-500/10 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-fuchsia-200">
                    @Model.Events.Count event(s)
                </div>
            </div>

            @if (Model.Events.Count == 0)
            {
                <div class="mt-8 rounded-2xl border border-slate-800 bg-slate-900/70 p-10 text-center">
                    <p class="font-display text-sm uppercase tracking-[0.28em] text-slate-400">
                        No timeline events found
                    </p>

                    <p class="mx-auto mt-3 max-w-xl text-sm leading-6 text-slate-500">
                        This session exists, but the Unity client has not reported gameplay events for it yet.
                    </p>
                </div>
            }
            else
            {
                <div class="mt-8 space-y-4">
                    @foreach (var timelineEvent in Model.Events)
                    {
                        <article class="relative rounded-2xl border border-slate-800 bg-slate-900/70 p-5 transition hover:border-fuchsia-400/20 hover:bg-slate-900/90">
                            <div class="flex flex-col gap-4 xl:flex-row xl:items-start xl:justify-between">
                                <div class="min-w-0">
                                    <div class="flex flex-wrap items-center gap-3">
                                        <span class="inline-flex rounded-full border border-cyan-400/25 bg-cyan-500/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-cyan-200">
                                            @timelineEvent.EventType
                                        </span>

                                        <span class="text-xs uppercase tracking-[0.18em] text-slate-500">
                                            Event #@timelineEvent.Id
                                        </span>
                                    </div>

                                    <div class="mt-4 grid grid-cols-1 gap-3 md:grid-cols-3">
                                        <div>
                                            <div class="text-xs uppercase tracking-[0.20em] text-slate-500">Scene</div>
                                            <div class="mt-1 text-sm font-semibold text-white">@timelineEvent.Scene</div>
                                        </div>

                                        <div>
                                            <div class="text-xs uppercase tracking-[0.20em] text-slate-500">Game State</div>
                                            <div class="mt-1 text-sm font-semibold text-white">@timelineEvent.GameState</div>
                                        </div>

                                        <div>
                                            <div class="text-xs uppercase tracking-[0.20em] text-slate-500">Phase</div>
                                            <div class="mt-1 text-sm font-semibold text-white">@timelineEvent.Phase</div>
                                        </div>
                                    </div>
                                </div>

                                <div class="shrink-0 rounded-xl border border-slate-800 bg-slate-950/60 px-4 py-3 text-xs text-slate-400">
                                    <div>
                                        <span class="text-slate-500">Server:</span>
                                        <span class="text-cyan-300">@timelineEvent.CreatedAtLabel</span>
                                    </div>
                                    <div class="mt-1">
                                        <span class="text-slate-500">Client:</span>
                                        <span class="text-fuchsia-300">@timelineEvent.ClientTimeLabel</span>
                                    </div>
                                </div>
                            </div>

                            @if (timelineEvent.HasPayload)
                            {
                                <div class="mt-5 rounded-xl border border-slate-800 bg-slate-950/80 p-4">
                                    <div class="mb-2 text-xs uppercase tracking-[0.20em] text-slate-500">
                                        Payload JSON
                                    </div>

                                    <pre class="max-h-[240px] overflow-auto whitespace-pre-wrap break-words text-xs leading-5 text-slate-300">@timelineEvent.PayloadJson</pre>
                                </div>
                            }
                        </article>
                    }
                </div>
            }
        </section>
    </div>
</div>