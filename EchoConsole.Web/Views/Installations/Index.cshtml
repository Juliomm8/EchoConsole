@using System.Globalization
@using System.Text.Json
@model EchoConsole.Web.Models.Installations.InstallationsIndexViewModel

@{
    ViewData["Title"] = SharedLocalizer["Installations_PageTitle"].Value;
    ViewData["TitleResourceKey"] = "Installations_PageTitle";

    var realtimeLabels = new
    {
        emptyState = SharedLocalizer["Installations_EmptyState"].Value
    };

    var realtimeLabelsJson = JsonSerializer.Serialize(realtimeLabels);
}

<div class="min-h-screen bg-[#070B12] text-slate-100">
    <div class="mx-auto max-w-[1600px] px-6 py-6">
        <div class="mb-6 flex flex-col gap-4 rounded-2xl border border-cyan-500/20 bg-slate-950/70 p-6 shadow-[0_0_40px_rgba(0,255,255,0.05)] backdrop-blur md:flex-row md:items-center md:justify-between">
            <div>
                <p class="font-display text-xs uppercase tracking-[0.35em] text-cyan-400">@SharedLocalizer["Installations_ModuleBadge"]</p>
                <h1 class="mt-2 font-display text-3xl uppercase tracking-[0.18em] text-white md:text-4xl">@SharedLocalizer["Installations_HeroTitle"]</h1>
                <p class="mt-3 max-w-3xl text-sm text-slate-400 md:text-base">@SharedLocalizer["Installations_HeroSubtitle"]</p>
            </div>

            <div class="rounded-2xl border border-cyan-500/20 bg-slate-900/80 px-5 py-4">
                <div class="font-display text-xs uppercase tracking-[0.25em] text-slate-500">@SharedLocalizer["Installations_TotalLabel"]</div>
                <div id="installations-total-count" class="mt-2 font-display text-3xl uppercase tracking-[0.08em] text-cyan-300">
                    @Model.TotalCount.ToString("N0")
                </div>
            </div>
        </div>

        <div class="mb-6 rounded-2xl border border-cyan-500/20 bg-slate-950/70 p-5 shadow-[0_0_30px_rgba(0,255,255,0.04)] backdrop-blur">
            <form method="get" asp-controller="Installations" asp-action="Index" class="grid gap-4 md:grid-cols-[1fr_auto_auto]">
                <div>
                    <label for="installations-search-term" class="mb-2 block font-display text-xs uppercase tracking-[0.25em] text-slate-400">@SharedLocalizer["Common_Search"]</label>
                    <input id="installations-search-term"
                           name="searchTerm"
                           value="@Model.SearchTerm"
                           type="text"
                           
                           placeholder="@SharedLocalizer["Installations_SearchPlaceholder"]"
                           class="w-full rounded-xl border border-cyan-500/20 bg-slate-900/80 px-4 py-3 text-sm text-slate-100 outline-none transition placeholder:text-slate-500 focus:border-cyan-400/40 focus:ring-2 focus:ring-cyan-400/10" />
                </div>

                <input id="installations-page-size" type="hidden" name="pageSize" value="@Model.PageSize" />

                <div class="flex items-end gap-3">
                    <button type="submit"
                            class="rounded-xl border border-cyan-400/25 bg-cyan-500/10 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-cyan-200 transition hover:bg-cyan-500/15">@SharedLocalizer["Common_Search"]</button>

                    <a asp-controller="Installations"
                       asp-action="Index"
                       class="rounded-xl border border-slate-700 bg-slate-900/70 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-slate-300 transition hover:border-cyan-400/20 hover:text-white">@SharedLocalizer["Common_Reset"]</a>
                </div>
            </form>
        </div>

        <div class="rounded-2xl border border-cyan-500/20 bg-slate-950/70 p-6 shadow-[0_0_40px_rgba(0,255,255,0.05)] backdrop-blur">
            <div class="mb-5 flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
                <div>
                    <p class="font-display text-xs uppercase tracking-[0.35em] text-cyan-400">@SharedLocalizer["Installations_TableBadge"]</p>
                    <h2 class="mt-2 font-display text-2xl uppercase tracking-[0.14em] text-white">@SharedLocalizer["Installations_TableTitle"]</h2>
                </div>

                <div class="text-sm text-slate-400">
                    <span>@SharedLocalizer["Common_Results"]</span>
                    <span id="installations-results-count" class="font-semibold text-cyan-300">@Model.TotalCount.ToString("N0")</span>
                </div>
            </div>

            <span id="installations-empty-text" class="hidden">@SharedLocalizer["Installations_EmptyState"]</span>

            <div class="overflow-hidden rounded-2xl border border-slate-800">
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-slate-800">
                        <thead class="bg-slate-900/90">
                            <tr class="text-left">
                                <th class="px-5 py-4 font-display text-xs uppercase tracking-[0.22em] text-slate-400">@SharedLocalizer["Common_InstallationId"]</th>
                                <th class="px-5 py-4 font-display text-xs uppercase tracking-[0.22em] text-slate-400">@SharedLocalizer["Installations_ColDeviceName"]</th>
                                <th class="px-5 py-4 font-display text-xs uppercase tracking-[0.22em] text-slate-400">@SharedLocalizer["Common_OperatingSystem"]</th>
                                <th class="px-5 py-4 font-display text-xs uppercase tracking-[0.22em] text-slate-400">@SharedLocalizer["Installations_ColProcessor"]</th>
                                <th class="px-5 py-4 font-display text-xs uppercase tracking-[0.22em] text-slate-400">@SharedLocalizer["Installations_ColGpu"]</th>
                                <th class="px-5 py-4 font-display text-xs uppercase tracking-[0.22em] text-slate-400">@SharedLocalizer["Installations_ColRam"]</th>
                                <th class="px-5 py-4 font-display text-xs uppercase tracking-[0.22em] text-slate-400">@SharedLocalizer["Installations_ColLastUpdate"]</th>
                            </tr>
                        </thead>
                        <tbody id="installations-table-body" class="divide-y divide-slate-900 bg-slate-950/80">
                            @if (Model.Items != null && Model.Items.Any())
                            {
                                @foreach (var item in Model.Items)
                                {
                                    <tr class="transition-colors duration-150 hover:bg-slate-900/70">
                                        <td class="px-5 py-4 text-sm text-cyan-300">@item.InstallationId</td>
                                        <td class="px-5 py-4 text-sm text-slate-200">@item.DeviceName</td>
                                        <td class="px-5 py-4 text-sm text-slate-300">@item.OSVersion</td>
                                        <td class="px-5 py-4 text-sm text-slate-300">@item.Processor</td>
                                        <td class="px-5 py-4 text-sm text-slate-300">@item.Gpu</td>
                                        <td class="px-5 py-4 text-sm text-slate-300">@item.RamLabel</td>
                                        <td class="px-5 py-4 text-sm text-slate-400">@item.LastUpdateUtcLabel</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="px-5 py-6 text-center text-sm text-slate-400">@SharedLocalizer["Installations_EmptyState"]</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="mt-5 flex flex-col gap-4 border-t border-slate-800 pt-5 md:flex-row md:items-center md:justify-between">
                <div class="text-sm text-slate-400">
                    <span>@SharedLocalizer["Common_Page"]</span>
                    <span id="installations-page-number" class="font-semibold text-cyan-300">@Model.PageNumber</span>
                    <span>@SharedLocalizer["Common_Of"]</span>
                    <span id="installations-total-pages" class="font-semibold text-cyan-300">@Math.Max(Model.TotalPages, 1)</span>
                </div>

                <div class="flex items-center gap-3">
                    <a id="installations-prev-link"
                       asp-controller="Installations"
                       asp-action="Index"
                       asp-route-searchTerm="@Model.SearchTerm"
                       asp-route-pageNumber="@(Math.Max(1, Model.PageNumber - 1))"
                       asp-route-pageSize="@Model.PageSize"
                       aria-disabled="@(!Model.HasPreviousPage).ToString().ToLowerInvariant()"
                       class="rounded-xl border border-slate-700 bg-slate-900/70 px-4 py-2 text-sm font-semibold uppercase tracking-[0.18em] text-slate-300 transition hover:border-cyan-400/20 hover:text-white @(Model.HasPreviousPage ? "" : "pointer-events-none opacity-40")">@SharedLocalizer["Common_Previous"]</a>

                    <a id="installations-next-link"
                       asp-controller="Installations"
                       asp-action="Index"
                       asp-route-searchTerm="@Model.SearchTerm"
                       asp-route-pageNumber="@(Math.Min(Math.Max(Model.TotalPages, 1), Model.PageNumber + 1))"
                       asp-route-pageSize="@Model.PageSize"
                       aria-disabled="@(!Model.HasNextPage).ToString().ToLowerInvariant()"
                       class="rounded-xl border border-cyan-400/25 bg-cyan-500/10 px-4 py-2 text-sm font-semibold uppercase tracking-[0.18em] text-cyan-200 transition hover:bg-cyan-500/15 @(Model.HasNextPage ? "" : "pointer-events-none opacity-40")">@SharedLocalizer["Common_Next"]</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/signalr/signalr.min.js"></script>
    <script src="~/js/installations-realtime.js" asp-append-version="true"></script>
    <script>
        window.echoConsoleInstallationsRealtime.init({
            webBaseUrl: window.location.origin,
            tableBodyId: "installations-table-body",
            totalCountValueId: "installations-total-count",
            resultsCountValueId: "installations-results-count",
            pageNumberValueId: "installations-page-number",
            totalPagesValueId: "installations-total-pages",
            prevPageLinkId: "installations-prev-link",
            nextPageLinkId: "installations-next-link",
            searchInputId: "installations-search-term",
            pageSizeInputId: "installations-page-size",
            emptyTextElementId: "installations-empty-text",
            culture: @Html.Raw(JsonSerializer.Serialize(CultureInfo.CurrentUICulture.Name)),
            labels: @Html.Raw(realtimeLabelsJson)
        });
    </script>
}