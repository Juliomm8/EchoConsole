@using System.Globalization
@model EchoConsole.Web.Models.SessionEventAnalytics.SessionEventAnalyticsIndexViewModel

@{
    ViewData["Title"] = "EVENT ANALYTICS";
}

<div class="min-h-screen bg-[#070B12] text-slate-100">
    <div class="mx-auto max-w-[1700px] px-6 py-8">
        <section class="rounded-2xl border border-cyan-500/20 bg-slate-950/70 p-8 shadow-[0_0_30px_rgba(0,255,255,0.05)]">
            <div class="flex flex-col gap-4 xl:flex-row xl:items-start xl:justify-between">
                <div>
                    <p class="font-display text-xs uppercase tracking-[0.35em] text-cyan-300">
                        Telemetry Intelligence
                    </p>

                    <h1 class="mt-3 font-display text-3xl uppercase tracking-[0.16em] text-white">
                        Event Type Analytics
                    </h1>

                    <p class="mt-3 max-w-3xl text-sm leading-6 text-slate-400">
                        Aggregated gameplay telemetry metrics calculated directly in SQL Server.
                    </p>
                </div>

                <a asp-controller="SessionEvents"
                   asp-action="Index"
                   class="rounded-xl border border-fuchsia-400/20 bg-fuchsia-500/10 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-fuchsia-200 transition hover:bg-fuchsia-500/15">
                    Open Recent Events
                </a>
            </div>
        </section>

        <section class="mt-6 rounded-2xl border border-cyan-500/20 bg-slate-950/70 p-6">
            <form method="get"
                  asp-controller="SessionEventAnalytics"
                  asp-action="Index"
                  class="grid grid-cols-1 gap-4 lg:grid-cols-4">
                <div>
                    <label for="buildVersion"
                           class="mb-2 block text-xs font-semibold uppercase tracking-[0.20em] text-slate-400">
                        Build
                    </label>

                    <select id="buildVersion"
                            name="buildVersion"
                            class="w-full rounded-xl border border-cyan-500/20 bg-slate-900/80 px-4 py-3 text-sm text-slate-100 outline-none focus:border-cyan-400/40">
                        <option value="">All builds</option>

                        @foreach (var option in Model.AvailableBuildVersions)
                        {
                            if (string.Equals(
                            Model.BuildVersion,
                            option,
                            StringComparison.OrdinalIgnoreCase))
                            {
                                <option value="@option" selected>@option</option>
                            }
                            else
                            {
                                <option value="@option">@option</option>
                            }
                        }
                    </select>
                </div>

                <div>
                    <label for="fromDate"
                           class="mb-2 block text-xs font-semibold uppercase tracking-[0.20em] text-slate-400">
                        From Date UTC
                    </label>

                    <input id="fromDate"
                           name="fromDate"
                           type="date"
                           value="@Model.FromDate?.ToString("yyyy-MM-dd")"
                           class="w-full rounded-xl border border-cyan-500/20 bg-slate-900/80 px-4 py-3 text-sm text-slate-100 outline-none focus:border-cyan-400/40" />
                </div>

                <div>
                    <label for="toDate"
                           class="mb-2 block text-xs font-semibold uppercase tracking-[0.20em] text-slate-400">
                        To Date UTC
                    </label>

                    <input id="toDate"
                           name="toDate"
                           type="date"
                           value="@Model.ToDate?.ToString("yyyy-MM-dd")"
                           class="w-full rounded-xl border border-cyan-500/20 bg-slate-900/80 px-4 py-3 text-sm text-slate-100 outline-none focus:border-cyan-400/40" />
                </div>

                <div class="flex items-end gap-3">
                    <button type="submit"
                            class="rounded-xl border border-cyan-400/25 bg-cyan-500/10 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-cyan-200 transition hover:bg-cyan-500/15">
                        Apply
                    </button>

                    <a asp-controller="SessionEventAnalytics"
                       asp-action="Index"
                       class="rounded-xl border border-slate-700 bg-slate-900/70 px-5 py-3 text-sm font-semibold uppercase tracking-[0.18em] text-slate-300 transition hover:text-white">
                        Reset
                    </a>
                </div>
            </form>

            @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
            {
                <div class="mt-5 rounded-xl border border-rose-500/25 bg-rose-500/10 px-4 py-3 text-sm text-rose-200">
                    @Model.ErrorMessage
                </div>
            }
        </section>

        <section class="mt-6 grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-4">
            <div class="rounded-2xl border border-cyan-500/20 bg-slate-950/70 p-6">
                <div class="text-xs uppercase tracking-[0.22em] text-slate-500">
                    Total Events
                </div>
                <div class="mt-3 font-display text-4xl text-cyan-300">
                    @Model.TotalEvents.ToString("N0")
                </div>
            </div>

            <div class="rounded-2xl border border-fuchsia-500/20 bg-slate-950/70 p-6">
                <div class="text-xs uppercase tracking-[0.22em] text-slate-500">
                    Event Types
                </div>
                <div class="mt-3 font-display text-4xl text-fuchsia-300">
                    @Model.EventTypeCount.ToString("N0")
                </div>
            </div>

            <div class="rounded-2xl border border-amber-500/20 bg-slate-950/70 p-6">
                <div class="text-xs uppercase tracking-[0.22em] text-slate-500">
                    Scenes
                </div>
                <div class="mt-3 font-display text-4xl text-amber-300">
                    @Model.SceneCount.ToString("N0")
                </div>
            </div>

            <div class="rounded-2xl border border-emerald-500/20 bg-slate-950/70 p-6">
                <div class="text-xs uppercase tracking-[0.22em] text-slate-500">
                    Builds
                </div>
                <div class="mt-3 font-display text-4xl text-emerald-300">
                    @Model.BuildCount.ToString("N0")
                </div>
            </div>
        </section>

        @if (Model.TotalEvents == 0)
        {
            <section class="mt-6 rounded-2xl border border-slate-800 bg-slate-950/70 p-12 text-center">
                <p class="font-display text-sm uppercase tracking-[0.28em] text-slate-400">
                    No analytics data found
                </p>

                <p class="mx-auto mt-3 max-w-xl text-sm leading-6 text-slate-500">
                    No session events match the selected build and date range.
                </p>
            </section>
        }
        else
        {
            <div class="mt-6 grid grid-cols-1 gap-6 xl:grid-cols-3">
                <section class="rounded-2xl border border-cyan-500/20 bg-slate-950/70 p-6">
                    <div>
                        <p class="font-display text-xs uppercase tracking-[0.30em] text-cyan-300">
                            Event Distribution
                        </p>

                        <h2 class="mt-2 text-xl font-semibold text-white">
                            By Event Type
                        </h2>
                    </div>

                    <div class="mt-6 max-h-[620px] space-y-5 overflow-y-auto pr-2">
                        @foreach (var item in Model.EventTypes)
                        {
                            <div>
                                <div class="flex items-center justify-between gap-4 text-sm">
                                    <span class="truncate font-medium text-slate-200"
                                          title="@item.Label">
                                        @item.Label
                                    </span>

                                    <span class="shrink-0 text-cyan-300">
                                        @item.Count.ToString("N0")
                                        <span class="text-slate-600">
                                            (@item.Percentage.ToString("0.##")%)
                                        </span>
                                    </span>
                                </div>

                                <div class="mt-2 h-2 overflow-hidden rounded-full bg-slate-900">
                                    <div class="h-full rounded-full bg-cyan-400/70"
                                         style="width: @(item.BarWidthPercentage.ToString("0.##", CultureInfo.InvariantCulture))%">
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </section>

                <section class="rounded-2xl border border-fuchsia-500/20 bg-slate-950/70 p-6">
                    <div>
                        <p class="font-display text-xs uppercase tracking-[0.30em] text-fuchsia-300">
                            Scene Distribution
                        </p>

                        <h2 class="mt-2 text-xl font-semibold text-white">
                            By Scene
                        </h2>
                    </div>

                    <div class="mt-6 max-h-[620px] space-y-5 overflow-y-auto pr-2">
                        @foreach (var item in Model.Scenes)
                        {
                            <div>
                                <div class="flex items-center justify-between gap-4 text-sm">
                                    <span class="truncate font-medium text-slate-200"
                                          title="@item.Label">
                                        @item.Label
                                    </span>

                                    <span class="shrink-0 text-fuchsia-300">
                                        @item.Count.ToString("N0")
                                        <span class="text-slate-600">
                                            (@item.Percentage.ToString("0.##")%)
                                        </span>
                                    </span>
                                </div>

                                <div class="mt-2 h-2 overflow-hidden rounded-full bg-slate-900">
                                    <div class="h-full rounded-full bg-fuchsia-400/70"
                                         style="width: @(item.BarWidthPercentage.ToString("0.##", CultureInfo.InvariantCulture))%">
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </section>

                <section class="rounded-2xl border border-amber-500/20 bg-slate-950/70 p-6">
                    <div>
                        <p class="font-display text-xs uppercase tracking-[0.30em] text-amber-300">
                            Build Distribution
                        </p>

                        <h2 class="mt-2 text-xl font-semibold text-white">
                            By Build Version
                        </h2>
                    </div>

                    <div class="mt-6 max-h-[620px] space-y-5 overflow-y-auto pr-2">
                        @foreach (var item in Model.BuildVersions)
                        {
                            <div>
                                <div class="flex items-center justify-between gap-4 text-sm">
                                    <span class="truncate font-medium text-slate-200"
                                          title="@item.Label">
                                        @item.Label
                                    </span>

                                    <span class="shrink-0 text-amber-300">
                                        @item.Count.ToString("N0")
                                        <span class="text-slate-600">
                                            (@item.Percentage.ToString("0.##")%)
                                        </span>
                                    </span>
                                </div>

                                <div class="mt-2 h-2 overflow-hidden rounded-full bg-slate-900">
                                    <div class="h-full rounded-full bg-amber-400/70"
                                         style="width: @(item.BarWidthPercentage.ToString("0.##", CultureInfo.InvariantCulture))%">
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </section>
            </div>
        }
    </div>
</div>