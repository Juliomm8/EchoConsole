@model EchoConsole.Web.Models.Dashboard.LiveMonitoringDashboardViewModel

<section class="terminal-panel mt-7 overflow-hidden rounded-lg shadow-[0_0_28px_rgba(34,197,94,0.06)]">
    <header class="border-b border-green-500/15 bg-green-500/[0.025] px-5 py-5 sm:px-6 lg:px-8">
        <div class="flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
            <div>
                <p class="terminal-kicker">
                    &gt; _ SESSION_MATRIX // @SharedLocalizer["Dashboard_Module4"]
                </p>

                <h2 class="mt-3 font-display text-2xl uppercase tracking-[0.12em] text-green-100 sm:text-3xl">
                    @SharedLocalizer["Dashboard_LiveSessionsMonitor"]
                </h2>

                <p class="mt-3 text-xs uppercase tracking-[0.16em] text-green-800">
                    ACTIVE CHANNELS // HEARTBEAT STREAM // REALTIME FEED
                </p>
            </div>

            <div class="flex flex-wrap items-center gap-3">
                <span class="inline-flex items-center gap-2 rounded border border-green-400/30 bg-green-500/10 px-4 py-2 text-[10px] font-bold uppercase tracking-[0.18em] text-green-300 shadow-phosphor">
                    <span class="h-2 w-2 rounded-full bg-green-400 animate-signal-pulse"></span>
                    [@SharedLocalizer["Dashboard_SignalRActive"]]
                </span>

                <span class="rounded border border-green-500/20 bg-black px-4 py-2 text-[9px] font-bold uppercase tracking-[0.18em] text-green-800">
                    ROWS: @Model.Sessions.Count
                </span>
            </div>
        </div>
    </header>

    <span id="live-sessions-empty-text"
          class="hidden">
        @SharedLocalizer["Dashboard_NoLiveSessions"]
    </span>

    <div class="overflow-x-auto bg-black">
        <table class="min-w-full border-collapse">
            <thead>
                <tr class="border-b border-green-500/20 bg-green-500/[0.035] text-left">
                    <th class="whitespace-nowrap px-5 py-4 text-[9px] font-bold uppercase tracking-[0.2em] text-green-700">
                        [01] @SharedLocalizer["Dashboard_TableInstallationId"]
                    </th>
                    <th class="whitespace-nowrap px-5 py-4 text-[9px] font-bold uppercase tracking-[0.2em] text-green-700">
                        [02] @SharedLocalizer["Dashboard_TableCurrentScene"]
                    </th>
                    <th class="whitespace-nowrap px-5 py-4 text-[9px] font-bold uppercase tracking-[0.2em] text-green-700">
                        [03] @SharedLocalizer["Dashboard_TableGameState"]
                    </th>
                    <th class="whitespace-nowrap px-5 py-4 text-[9px] font-bold uppercase tracking-[0.2em] text-green-700">
                        [04] @SharedLocalizer["Dashboard_TableCurrentPhase"]
                    </th>
                    <th class="whitespace-nowrap px-5 py-4 text-[9px] font-bold uppercase tracking-[0.2em] text-green-700">
                        [05] @SharedLocalizer["Dashboard_TableLastHeartbeat"]
                    </th>
                    <th class="whitespace-nowrap px-5 py-4 text-[9px] font-bold uppercase tracking-[0.2em] text-green-700">
                        [06] @SharedLocalizer["Dashboard_TableStatus"]
                    </th>
                </tr>
            </thead>

            <tbody id="live-sessions-body"
                   class="divide-y divide-green-500/10">
                @if (Model.Sessions.Any())
                {
                    @foreach (var session in Model.Sessions)
                    {
                        var statusLabel = session.Status switch
                        {
                            1 => SharedLocalizer["Status_Active"].Value,
                            2 => SharedLocalizer["Status_Ended"].Value,
                            3 => SharedLocalizer["Status_Expired"].Value,
                            _ => SharedLocalizer["Status_Unknown"].Value
                        };

                        var statusClasses = session.Status switch
                        {
                            1 => "border-green-500/35 bg-green-500/10 text-green-300",
                            2 => "border-amber-500/35 bg-amber-500/10 text-amber-300",
                            3 => "border-rose-500/35 bg-rose-500/10 text-rose-300",
                            _ => "border-slate-500/25 bg-slate-500/5 text-slate-400"
                        };

                        var statusDot = session.Status switch
                        {
                            1 => "bg-green-400",
                            2 => "bg-amber-400",
                            3 => "bg-rose-400",
                            _ => "bg-slate-500"
                        };

                        <tr data-session-id="@session.SessionId"
                            class="border-b border-green-500/10 bg-black transition-colors duration-150 hover:bg-green-500/[0.035]">
                            <td class="whitespace-nowrap px-5 py-4 text-xs font-bold uppercase tracking-[0.08em] text-green-300"
                                title="@session.SessionId">
                                @session.InstallationId
                            </td>
                            <td class="whitespace-nowrap px-5 py-4 text-xs text-green-600">
                                @session.CurrentScene
                            </td>
                            <td class="whitespace-nowrap px-5 py-4 text-xs text-green-600">
                                @session.GameState
                            </td>
                            <td class="whitespace-nowrap px-5 py-4 text-xs text-green-700">
                                @session.CurrentPhase
                            </td>
                            <td class="whitespace-nowrap px-5 py-4 text-xs text-green-800">
                                <time datetime="@session.LastHeartbeatUtc.ToString("O")">
                                    @session.LastHeartbeatUtc.ToString("yyyy-MM-dd HH:mm:ss 'UTC'")
                                </time>
                            </td>
                            <td class="whitespace-nowrap px-5 py-4">
                                <span class="inline-flex items-center gap-2 rounded border px-3 py-1.5 text-[9px] font-bold uppercase tracking-[0.16em] @statusClasses">
                                    <span class="h-1.5 w-1.5 rounded-full @statusDot"></span>
                                    [@statusLabel]
                                </span>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6"
                            class="px-5 py-14 text-center">
                            <div class="mx-auto max-w-lg">
                                <p class="text-[10px] font-bold uppercase tracking-[0.22em] text-green-800">
                                    &gt; _ NO_ACTIVE_SIGNAL
                                </p>
                                <p class="mt-3 text-sm text-green-900">
                                    @SharedLocalizer["Dashboard_NoLiveSessions"]
                                </p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <footer class="flex flex-col gap-2 border-t border-green-500/15 bg-green-500/[0.02] px-5 py-4 text-[9px] font-bold uppercase tracking-[0.18em] text-green-900 sm:flex-row sm:items-center sm:justify-between sm:px-6 lg:px-8">
        <span>TRANSPORT: SIGNALR // CHANNEL: ADMIN-TELEMETRY</span>
        <span>REFRESH_MODE: EVENT_DRIVEN</span>
    </footer>
</section>
