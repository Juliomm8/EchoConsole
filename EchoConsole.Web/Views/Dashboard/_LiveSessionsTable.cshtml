@model EchoConsole.Web.Models.Dashboard.LiveMonitoringDashboardViewModel

<div class="rounded-2xl border border-cyan-500/20 bg-slate-950/70 p-6 shadow-[0_0_40px_rgba(0,255,255,0.05)] backdrop-blur">
    <div class="mb-5 flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
        <div>
            <p class="font-display text-xs uppercase tracking-[0.35em] text-cyan-400" data-i18n="dash_mod4">Module 4</p>
            <h2 class="mt-2 font-display text-2xl uppercase tracking-[0.14em] text-white" data-i18n="dash_live_monitor">Live Sessions Monitor</h2>
        </div>

        <div class="inline-flex items-center gap-2 rounded-full border border-emerald-500/30 bg-emerald-500/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-emerald-400">
            <span class="h-2 w-2 rounded-full bg-emerald-400"></span>
            <span data-i18n="dash_signalr_ready">SignalR Ready</span>
        </div>
    </div>

    <div class="overflow-hidden rounded-2xl border border-slate-800">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-800">
                <thead class="bg-slate-900/90">
                    <tr class="text-left">
                        <th class="px-5 py-4 font-display text-xs uppercase tracking-[0.22em] text-slate-400" data-i18n="table_id">Installation ID</th>
                        <th class="px-5 py-4 font-display text-xs uppercase tracking-[0.22em] text-slate-400" data-i18n="table_scene">Current Scene</th>
                        <th class="px-5 py-4 font-display text-xs uppercase tracking-[0.22em] text-slate-400" data-i18n="table_state">Game State</th>
                        <th class="px-5 py-4 font-display text-xs uppercase tracking-[0.22em] text-slate-400" data-i18n="table_phase">Current Phase</th>
                        <th class="px-5 py-4 font-display text-xs uppercase tracking-[0.22em] text-slate-400" data-i18n="table_heartbeat">Last Heartbeat</th>
                        <th class="px-5 py-4 font-display text-xs uppercase tracking-[0.22em] text-slate-400" data-i18n="table_status">Status</th>
                    </tr>
                </thead>
                <tbody id="live-sessions-body" class="divide-y divide-slate-900 bg-slate-950/80">
                    @foreach (var session in Model.Sessions)
                    {
                        <tr data-session-id="@session.SessionId" class="transition-colors duration-150 hover:bg-slate-900/70">
                            <td class="px-5 py-4 text-sm text-cyan-300">@session.InstallationId</td>
                            <td class="px-5 py-4 text-sm text-slate-200 cell-current-scene">@session.CurrentScene</td>
                            <td class="px-5 py-4 text-sm text-slate-200 cell-game-state">@session.GameState</td>
                            <td class="px-5 py-4 text-sm text-slate-300 cell-current-phase">@session.CurrentPhase</td>
                            <td class="px-5 py-4 text-sm text-slate-400 cell-last-heartbeat">@session.LastHeartbeatLabel</td>
                            <td class="px-5 py-4">
                                <span class="inline-flex items-center gap-2 rounded-full border border-emerald-500/30 bg-emerald-500/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-emerald-400 cell-status">
                                    <span class="h-2 w-2 rounded-full bg-emerald-400"></span>
                                    @session.StatusLabel
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>