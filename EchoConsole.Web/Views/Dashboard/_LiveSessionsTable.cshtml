@model EchoConsole.Web.Models.Dashboard.LiveMonitoringDashboardViewModel


<section class="mt-7 overflow-hidden rounded-lg border border-slate-800 bg-[linear-gradient(180deg,rgba(2,6,8,0.96),rgba(0,0,0,0.99))] shadow-[0_0_28px_rgba(15,23,42,0.26)]">
    <header class="border-b border-slate-800 bg-[linear-gradient(90deg,rgba(8,47,73,0.16),rgba(0,0,0,0.72),rgba(69,26,3,0.10))] px-5 py-5 sm:px-6 lg:px-8">
        <div class="flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
            <div>
                <p class="text-[10px] font-bold uppercase tracking-[0.24em] text-[#67e8f9]">
                    &gt; _ SESSION_MATRIX // @SharedLocalizer["Dashboard_Module4"]
                </p>

                <h2 class="mt-3 font-display text-2xl uppercase tracking-[0.12em] text-slate-100 sm:text-3xl">
                    @SharedLocalizer["Dashboard_LiveSessionsMonitor"]
                </h2>

                <p class="mt-3 text-xs uppercase tracking-[0.16em] text-slate-600">
                    ACTIVE CHANNELS // HEARTBEAT STREAM // REALTIME FEED
                </p>
            </div>

            <div class="flex flex-wrap items-center gap-3">
                <span class="inline-flex items-center gap-2 rounded border border-green-400/30 bg-green-500/10 px-4 py-2 text-[10px] font-bold uppercase tracking-[0.18em] text-green-300 shadow-[0_0_15px_rgba(34,197,94,0.1)]">
                    <span class="h-2 w-2 rounded-full bg-green-400 animate-signal-pulse"></span>
                    [@SharedLocalizer["Dashboard_SignalRActive"]]
                </span>

                <span class="rounded border border-slate-700 bg-slate-950/70 px-4 py-2 text-[9px] font-bold uppercase tracking-[0.18em] @(Model.Sessions.Count > 0 ? "text-[#67e8f9]" : "text-amber-500")">
                    ROWS: @Model.Sessions.Count
                </span>
            </div>
        </div>
        <div class="mt-5 min-h-6" aria-hidden="true"></div>
    </header>

    <span id="live-sessions-empty-text"
          class="hidden">
        @SharedLocalizer["Dashboard_NoLiveSessions"]
    </span>

    <div class="overflow-x-auto bg-black">
        <table class="min-w-full border-collapse">
            <thead>
                <tr class="border-b border-slate-800 bg-slate-950/80 text-left">
                    <th class="whitespace-nowrap px-5 py-4 text-[9px] font-bold uppercase tracking-[0.2em] text-[#67e8f9]">
                        [01] @SharedLocalizer["Dashboard_TableInstallationId"]
                    </th>
                    <th class="whitespace-nowrap px-5 py-4 text-[9px] font-bold uppercase tracking-[0.2em] text-slate-500">
                        [02] @SharedLocalizer["Dashboard_TableCurrentScene"]
                    </th>
                    <th class="whitespace-nowrap px-5 py-4 text-[9px] font-bold uppercase tracking-[0.2em] text-slate-500">
                        [03] @SharedLocalizer["Dashboard_TableGameState"]
                    </th>
                    <th class="whitespace-nowrap px-5 py-4 text-[9px] font-bold uppercase tracking-[0.2em] text-slate-500">
                        [04] @SharedLocalizer["Dashboard_TableCurrentPhase"]
                    </th>
                    <th class="whitespace-nowrap px-5 py-4 text-[9px] font-bold uppercase tracking-[0.2em] text-amber-500/80">
                        [05] @SharedLocalizer["Dashboard_TableLastHeartbeat"]
                    </th>
                    <th class="whitespace-nowrap px-5 py-4 text-[9px] font-bold uppercase tracking-[0.2em] text-slate-500">
                        [06] @SharedLocalizer["Dashboard_TableStatus"]
                    </th>
                </tr>
            </thead>

            <tbody id="live-sessions-body"
                   class="divide-y divide-slate-900">
                @if (Model.Sessions.Any())
                {
                    @foreach (var session in Model.Sessions)
                    {
                        var statusLabel =
                            SharedLocalizer["Status_Unknown"].Value;

                        var statusClasses =
                            "border-slate-500/25 bg-slate-500/5 text-slate-400";

                        var statusDot =
                            "bg-slate-500";

                        if (session.Status == 1)
                        {
                            statusLabel =
                                SharedLocalizer["Status_Active"].Value;

                            statusClasses =
                                "border-green-500/35 bg-green-500/10 text-green-300";

                            statusDot =
                                "bg-green-400";
                        }
                        else if (session.Status == 2)
                        {
                            statusLabel =
                                SharedLocalizer["Status_Ended"].Value;

                            statusClasses =
                                "border-amber-500/35 bg-amber-500/10 text-amber-300";

                            statusDot =
                                "bg-amber-400";
                        }
                        else if (session.Status == 3)
                        {
                            statusLabel =
                                SharedLocalizer["Status_Expired"].Value;

                            statusClasses =
                                "border-rose-500/35 bg-rose-500/10 text-rose-300";

                            statusDot =
                                "bg-rose-400";
                        }

                        <tr data-session-id="@session.SessionId"
                            class="border-b border-slate-900 bg-black transition-colors duration-150 hover:bg-slate-950/85">
                            <td class="whitespace-nowrap px-5 py-4 text-xs font-bold uppercase tracking-[0.08em] text-[#67e8f9]"
                                title="@session.SessionId">
                                @session.InstallationId
                            </td>
                            <td class="whitespace-nowrap px-5 py-4 text-xs text-slate-300">
                                @session.CurrentScene
                            </td>
                            <td class="whitespace-nowrap px-5 py-4 text-xs text-slate-400">
                                @session.GameState
                            </td>
                            <td class="whitespace-nowrap px-5 py-4 text-xs text-slate-500">
                                @session.CurrentPhase
                            </td>
                            <td class="whitespace-nowrap px-5 py-4 text-xs text-amber-500/80">
                                <time datetime="@session.LastHeartbeatUtc.ToString("O")">
                                    @session.LastHeartbeatUtc.ToString("yyyy-MM-dd HH:mm:ss 'UTC'")
                                </time>
                            </td>
                            <td class="whitespace-nowrap px-5 py-4">
                                <span class="inline-flex items-center gap-2 rounded border px-3 py-1.5 text-[9px] font-bold uppercase tracking-[0.16em] @statusClasses">
                                    <span class="h-1.5 w-1.5 rounded-full @statusDot"></span>
                                    [@statusLabel]
                                </span>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6"
                            class="px-5 py-16 text-center">
                            <div class="mx-auto max-w-xl rounded border border-amber-500/20 bg-[linear-gradient(135deg,rgba(69,26,3,0.14),rgba(0,0,0,0.78))] px-6 py-8 shadow-[0_0_24px_rgba(245,158,11,0.05)]">
                                <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full border border-amber-500/25 bg-amber-500/5 text-amber-500">
                                    !
                                </div>
                                <p class="mt-5 text-[11px] font-bold uppercase tracking-[0.24em] text-amber-400">
                                    [ NO ACTIVE SIGNALS DETECTED ]
                                </p>
                                <p class="mt-3 text-sm leading-6 text-slate-600">
                                    @SharedLocalizer["Dashboard_NoLiveSessions"]
                                </p>
                                <p class="mt-5 overflow-hidden whitespace-nowrap text-[10px] tracking-[0.08em] text-slate-700">
                                    [░░░░░░░░░░░░] CHANNEL_IDLE
                                </p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <footer class="flex flex-col gap-2 border-t border-slate-800 bg-slate-950/45 px-5 py-4 text-[9px] font-bold uppercase tracking-[0.18em] text-slate-700 sm:flex-row sm:items-center sm:justify-between sm:px-6 lg:px-8">
        <span>TRANSPORT: SIGNALR // CHANNEL: ADMIN-TELEMETRY</span>
        <span class="text-[#67e8f9]/70">REFRESH_MODE: EVENT_DRIVEN</span>
    </footer>
</section>
