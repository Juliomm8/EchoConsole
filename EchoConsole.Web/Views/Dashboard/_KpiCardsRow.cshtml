@model EchoConsole.Web.Models.Dashboard.LiveMonitoringDashboardViewModel

@functions {
    private string GetAccentClasses(string accent)
    {
        return accent switch
        {
            "magenta" => "border-fuchsia-500/20 bg-fuchsia-500/5 shadow-[0_0_25px_rgba(217,70,239,0.08)]",
            _ => "border-cyan-500/20 bg-cyan-500/5 shadow-[0_0_25px_rgba(34,211,238,0.08)]"
        };
    }

    private string GetIconAccent(string accent)
    {
        return accent switch
        {
            "magenta" => "border-fuchsia-400/30 bg-fuchsia-500/10 text-fuchsia-300",
            _ => "border-cyan-400/30 bg-cyan-500/10 text-cyan-300"
        };
    }

    private string GetDeltaClass(bool positive)
    {
        return positive ? "text-emerald-400" : "text-rose-400";
    }
}

<div class="mb-6 grid grid-cols-1 gap-4 xl:grid-cols-4">
    @foreach (var kpi in Model.Kpis)
    {
        var titleKey = kpi.ValueElementId switch
        {
            "kpi-registered-installations" => "Dashboard_KpiRegisteredInstallationsTitle",
            "kpi-active-sessions" => "Dashboard_KpiActiveSessionsTitle",
            "kpi-average-duration" => "Dashboard_KpiAverageDurationTitle",
            "kpi-latest-heartbeat" => "Dashboard_KpiLatestHeartbeatTitle",
            _ => string.Empty
        };

        var subtitleKey = kpi.ValueElementId switch
        {
            "kpi-registered-installations" => "Dashboard_KpiRegisteredInstallationsSubtitle",
            "kpi-active-sessions" => "Dashboard_KpiActiveSessionsSubtitle",
            "kpi-average-duration" => "Dashboard_KpiAverageDurationSubtitle",
            "kpi-latest-heartbeat" => "Dashboard_KpiLatestHeartbeatSubtitle",
            _ => string.Empty
        };

        var deltaKey = kpi.DeltaText switch
        {
            "Real data" => "Dashboard_KpiDeltaRealData",
            "Live now" => "Dashboard_KpiDeltaLiveNow",
            "Unavailable" => "Dashboard_KpiDeltaUnavailable",
            _ => string.Empty
        };

        <div class="rounded-2xl border @GetAccentClasses(kpi.Accent) p-5">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <p class="font-display text-xs uppercase tracking-[0.25em] text-slate-400">
                        @(string.IsNullOrWhiteSpace(titleKey)
                            ? kpi.Title
                            : SharedLocalizer[titleKey].Value)
                    </p>

                    <p id="@kpi.ValueElementId"
                       class="mt-4 font-display text-3xl uppercase tracking-[0.08em] text-white">
                        @kpi.Value
                    </p>

                    <p class="mt-2 text-sm text-slate-400">
                        @(string.IsNullOrWhiteSpace(subtitleKey)
                            ? kpi.Subtitle
                            : SharedLocalizer[subtitleKey].Value)
                    </p>

                    <p class="mt-3 text-sm font-semibold @GetDeltaClass(kpi.IsPositiveDelta)">
                        @(string.IsNullOrWhiteSpace(deltaKey)
                            ? kpi.DeltaText
                            : SharedLocalizer[deltaKey].Value)
                    </p>
                </div>

                <div class="flex h-14 w-14 items-center justify-center rounded-xl border @GetIconAccent(kpi.Accent)">
                    <span class="font-display text-lg">EC</span>
                </div>
            </div>
        </div>
    }
</div>
