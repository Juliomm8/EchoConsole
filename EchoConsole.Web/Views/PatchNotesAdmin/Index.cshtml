@using System.Text.Json
@model EchoConsole.Web.Models.PatchNotes.PatchNotesAdminIndexViewModel

@{
    ViewData["Title"] =
        SharedLocalizer["PatchNotesAdmin_DashboardPageTitle"].Value;

    ViewData["TitleResourceKey"] =
        "PatchNotesAdmin_DashboardPageTitle";

    var deleteConfirmation = JsonSerializer.Serialize(
        SharedLocalizer["PatchNotesAdmin_DeleteConfirm"].Value);
}

<div class="min-h-screen bg-black text-green-100">
    <div class="mx-auto max-w-[1600px] px-6 py-10 lg:px-10">
        <header class="terminal-panel rounded-lg p-6 shadow-phosphor lg:p-8">
            <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
                <div class="max-w-3xl">
                    <p class="terminal-kicker">
                        @SharedLocalizer["PatchNotesAdmin_DashboardEyebrow"]
                    </p>

                    <h1 class="mt-4 font-display text-3xl uppercase tracking-[0.06em] text-green-100 sm:text-5xl">
                        @SharedLocalizer["PatchNotesAdmin_DashboardTitle"]
                    </h1>

                    <p class="mt-5 text-sm leading-7 text-slate-400 sm:text-base">
                        @SharedLocalizer["PatchNotesAdmin_DashboardSubtitle"]
                    </p>
                </div>

                <a asp-controller="PatchNotesAdmin"
                   asp-action="Create"
                   class="inline-flex shrink-0 items-center justify-center rounded border border-green-400/40 bg-green-500/10 px-6 py-3 text-xs font-bold uppercase tracking-[0.16em] text-green-200 shadow-phosphor transition hover:bg-green-500/20 hover:text-green-100">
                    @SharedLocalizer["PatchNotesAdmin_CreateNew"]
                </a>
            </div>
        </header>

        @if (TempData["PatchNotesAdminSuccess"] is string successMessage)
        {
            <div class="mt-6 rounded border border-green-500/35 bg-green-500/10 px-4 py-3 text-sm text-green-200 shadow-phosphor"
                 role="status">
                @successMessage
            </div>
        }

        @if (TempData["PatchNotesAdminError"] is string errorMessage)
        {
            <div class="mt-6 rounded border border-rose-500/35 bg-rose-500/10 px-4 py-3 text-sm text-rose-200"
                 role="alert">
                @errorMessage
            </div>
        }

        <section class="terminal-panel mt-8 overflow-hidden rounded-lg shadow-phosphor">
            <div class="flex flex-col gap-3 border-b border-green-500/15 bg-green-500/5 px-5 py-4 sm:flex-row sm:items-center sm:justify-between">
                <div>
                    <p class="text-[10px] font-bold uppercase tracking-[0.22em] text-green-500">
                        @SharedLocalizer["PatchNotesAdmin_ArchiveBadge"]
                    </p>

                    <h2 class="mt-2 font-display text-xl uppercase tracking-[0.08em] text-green-100">
                        @SharedLocalizer["PatchNotesAdmin_ArchiveTitle"]
                    </h2>
                </div>

                <div class="text-[10px] uppercase tracking-[0.20em] text-green-700">
                    @SharedLocalizer["PatchNotesAdmin_TotalRecords"]:
                    <span class="text-green-300">
                        @Model.Items.Count
                    </span>
                </div>
            </div>

            @if (Model.Items.Count == 0)
            {
                <div class="flex min-h-72 flex-col items-center justify-center px-6 py-16 text-center">
                    <span class="h-3 w-3 rounded-full bg-green-400 shadow-[0_0_14px_rgba(34,197,94,0.80)] animate-pulse"></span>

                    <h3 class="mt-6 font-display text-xl uppercase tracking-[0.08em] text-green-200">
                        @SharedLocalizer["PatchNotesAdmin_EmptyTitle"]
                    </h3>

                    <p class="mt-3 max-w-xl text-sm leading-7 text-slate-500">
                        @SharedLocalizer["PatchNotesAdmin_EmptyDescription"]
                    </p>

                    <a asp-controller="PatchNotesAdmin"
                       asp-action="Create"
                       class="mt-7 rounded border border-green-400/40 bg-green-500/10 px-5 py-3 text-xs font-bold uppercase tracking-[0.16em] text-green-200 transition hover:bg-green-500/20">
                        @SharedLocalizer["PatchNotesAdmin_CreateFirst"]
                    </a>
                </div>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-green-500/10">
                        <thead class="bg-black">
                            <tr class="text-left">
                                <th class="px-5 py-4 text-[10px] font-bold uppercase tracking-[0.20em] text-green-700">
                                    @SharedLocalizer["PatchNotesAdmin_ColVersion"]
                                </th>
                                <th class="px-5 py-4 text-[10px] font-bold uppercase tracking-[0.20em] text-green-700">
                                    @SharedLocalizer["PatchNotesAdmin_ColCategory"]
                                </th>
                                <th class="px-5 py-4 text-[10px] font-bold uppercase tracking-[0.20em] text-green-700">
                                    @SharedLocalizer["PatchNotesAdmin_ColTitle"]
                                </th>
                                <th class="px-5 py-4 text-[10px] font-bold uppercase tracking-[0.20em] text-green-700">
                                    @SharedLocalizer["PatchNotesAdmin_ColStatus"]
                                </th>
                                <th class="px-5 py-4 text-[10px] font-bold uppercase tracking-[0.20em] text-green-700">
                                    @SharedLocalizer["PatchNotesAdmin_ColDate"]
                                </th>
                                <th class="px-5 py-4 text-right text-[10px] font-bold uppercase tracking-[0.20em] text-green-700">
                                    @SharedLocalizer["PatchNotesAdmin_ColActions"]
                                </th>
                            </tr>
                        </thead>

                        <tbody class="divide-y divide-green-500/10 bg-black/70">
                            @foreach (var patch in Model.Items)
                            {
                                var toneClasses = patch.Tone switch
                                {
                                    "amber" => "border-amber-500/35 bg-amber-500/10 text-amber-300",
                                    "rose" => "border-rose-500/35 bg-rose-500/10 text-rose-300",
                                    _ => "border-green-500/35 bg-green-500/10 text-green-300"
                                };

                                var visibilityButtonClasses = patch.IsPublished
                                    ? "border-green-500/40 bg-green-500/10 text-green-300 hover:border-green-400/70 hover:bg-green-500/20 hover:text-green-100"
                                    : "border-slate-600/50 bg-slate-800/40 text-slate-400 hover:border-slate-500/80 hover:bg-slate-800/70 hover:text-slate-200";

                                var visibilityLabel = patch.IsPublished
                                    ? SharedLocalizer["PatchNotesAdmin_Published"]
                                    : SharedLocalizer["PatchNotesAdmin_Hidden"];

                                var visibilityTitle = patch.IsPublished
                                    ? SharedLocalizer["PatchNotesAdmin_ToggleToHidden"]
                                    : SharedLocalizer["PatchNotesAdmin_ToggleToPublished"];

                                <tr class="transition hover:bg-green-500/[0.025]">
                                    <td class="whitespace-nowrap px-5 py-5 align-top">
                                        <span class="inline-flex rounded border px-3 py-1.5 text-xs font-bold @toneClasses">
                                            @patch.Version
                                        </span>
                                    </td>

                                    <td class="whitespace-nowrap px-5 py-5 align-top text-xs uppercase tracking-[0.16em] text-slate-400">
                                        @patch.Category
                                    </td>

                                    <td class="min-w-80 px-5 py-5 align-top">
                                        <div class="font-display text-sm uppercase tracking-[0.06em] text-green-100">
                                            @patch.Title
                                        </div>

                                        <p class="mt-2 line-clamp-2 max-w-2xl text-xs leading-6 text-slate-500">
                                            @patch.Description
                                        </p>
                                    </td>

                                    <td class="whitespace-nowrap px-5 py-5 align-top">
                                        @if (patch.IsPublished)
                                        {
                                            <span class="inline-flex items-center gap-2 rounded border border-green-500/30 bg-green-500/10 px-3 py-1 text-[10px] font-bold uppercase tracking-[0.16em] text-green-300">
                                                <span class="h-1.5 w-1.5 rounded-full bg-green-400 shadow-[0_0_8px_rgba(34,197,94,0.75)]"></span>
                                                @SharedLocalizer["PatchNotesAdmin_Published"]
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="inline-flex items-center gap-2 rounded border border-slate-600/40 bg-slate-800/30 px-3 py-1 text-[10px] font-bold uppercase tracking-[0.16em] text-slate-500">
                                                <span class="h-1.5 w-1.5 rounded-full bg-slate-600"></span>
                                                @SharedLocalizer["PatchNotesAdmin_Hidden"]
                                            </span>
                                        }
                                    </td>

                                    <td class="whitespace-nowrap px-5 py-5 align-top font-mono text-xs text-slate-500">
                                        @patch.CreatedAtUtc.UtcDateTime.ToString("yyyy-MM-dd HH:mm 'UTC'")
                                    </td>

                                    <td class="whitespace-nowrap px-5 py-5 text-right align-top">
                                        <div class="flex items-center justify-end gap-2">
                                            <form asp-controller="PatchNotesAdmin"
                                                  asp-action="TogglePublish"
                                                  method="post">
                                                @Html.AntiForgeryToken()

                                                <input type="hidden"
                                                       name="id"
                                                       value="@patch.Id" />

                                                <button type="submit"
                                                        title="@visibilityTitle"
                                                        aria-pressed="@patch.IsPublished.ToString().ToLowerInvariant()"
                                                        class="inline-flex items-center gap-2 rounded border px-4 py-2 text-[10px] font-bold uppercase tracking-[0.16em] transition @visibilityButtonClasses">
                                                    <span class="h-1.5 w-1.5 rounded-full @(patch.IsPublished ? "bg-green-400" : "bg-slate-600")"></span>
                                                    @visibilityLabel
                                                </button>
                                            </form>

                                            <form asp-controller="PatchNotesAdmin"
                                                  asp-action="Delete"
                                                  method="post"
                                                  onsubmit='return confirm(@Html.Raw(deleteConfirmation));'>
                                                @Html.AntiForgeryToken()

                                                <input type="hidden"
                                                       name="id"
                                                       value="@patch.Id" />

                                                <button type="submit"
                                                        class="rounded border border-rose-500/40 bg-rose-500/10 px-4 py-2 text-[10px] font-bold uppercase tracking-[0.16em] text-rose-300 transition hover:border-rose-400/70 hover:bg-rose-500/20 hover:text-rose-100">
                                                    @SharedLocalizer["PatchNotesAdmin_Delete"]
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    </div>
</div>
