@model EchoConsole.Web.Models.LiveOperations.LiveOperationsIndexViewModel

@{
    ViewData["Title"] = "LIVE OPERATIONS";

    string StateBorder(string state) => state switch
    {
        "Active" => "border-emerald-400/30",
        "Degraded" => "border-amber-400/30",
        _ => "border-slate-700"
    };

    string StateBackground(string state) => state switch
    {
        "Active" => "bg-emerald-500/10",
        "Degraded" => "bg-amber-500/10",
        _ => "bg-slate-900/70"
    };

    string StateText(string state) => state switch
    {
        "Active" => "text-emerald-300",
        "Degraded" => "text-amber-300",
        _ => "text-slate-400"
    };

    string StateDot(string state) => state switch
    {
        "Active" => "bg-emerald-400",
        "Degraded" => "bg-amber-400",
        _ => "bg-slate-500"
    };
}

<div class="min-h-screen bg-[#070B12] text-slate-100">
    <div class="mx-auto max-w-[1750px] px-6 py-8">
        <section class="relative overflow-hidden rounded-3xl border border-cyan-500/20 bg-slate-950/80 p-8 shadow-[0_0_50px_rgba(34,211,238,0.06)]">
            <div class="absolute -right-24 -top-24 h-64 w-64 rounded-full bg-cyan-500/10 blur-3xl"></div>
            <div class="absolute -bottom-24 left-1/3 h-64 w-64 rounded-full bg-fuchsia-500/10 blur-3xl"></div>

            <div class="relative flex flex-col gap-6 xl:flex-row xl:items-start xl:justify-between">
                <div>
                    <p class="font-display text-xs uppercase tracking-[0.38em] text-cyan-300">
                        Echo Console Command Center
                    </p>

                    <h1 class="mt-3 font-display text-3xl uppercase tracking-[0.16em] text-white md:text-4xl">
                        Live Operations
                    </h1>

                    <p class="mt-3 max-w-3xl text-sm leading-6 text-slate-400">
                        Real-time fleet status, active sessions, event volume and operational alerts.
                    </p>
                </div>

                <div class="flex flex-wrap gap-3">
                    <div id="live-ops-connection-badge"
                         class="inline-flex items-center gap-3 rounded-2xl border border-slate-700 bg-slate-900/80 px-5 py-3">
                        <span id="live-ops-connection-dot"
                              class="h-2.5 w-2.5 rounded-full bg-slate-500"></span>

                        <div>
                            <div class="text-xs uppercase tracking-[0.22em] text-slate-500">
                                Realtime Link
                            </div>

                            <div id="live-ops-connection-text"
                                 class="mt-1 text-sm font-semibold text-slate-300">
                                Connecting
                            </div>
                        </div>
                    </div>

                    <div class="rounded-2xl border border-cyan-400/20 bg-cyan-500/10 px-5 py-3">
                        <div class="text-xs uppercase tracking-[0.22em] text-cyan-400">
                            Server UTC
                        </div>

                        <div id="live-ops-server-time"
                             class="mt-1 font-display text-sm text-white">
                            @Model.Snapshot.ServerTimeUtc.ToString("yyyy-MM-dd HH:mm:ss")
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4">
            <article class="rounded-2xl border border-emerald-500/20 bg-slate-950/70 p-6 shadow-[0_0_24px_rgba(52,211,153,0.04)]">
                <div class="text-xs uppercase tracking-[0.22em] text-slate-500">
                    Active Installations
                </div>

                <div id="live-ops-active-installations"
                     class="mt-3 font-display text-4xl text-emerald-300">
                    @Model.Snapshot.ActiveInstallations
                </div>

                <div class="mt-2 text-xs text-slate-500">
                    Receiving telemetry now
                </div>
            </article>

            <article class="rounded-2xl border border-amber-500/20 bg-slate-950/70 p-6">
                <div class="text-xs uppercase tracking-[0.22em] text-slate-500">
                    Degraded Installations
                </div>

                <div id="live-ops-degraded-installations"
                     class="mt-3 font-display text-4xl text-amber-300">
                    @Model.Snapshot.DegradedInstallations
                </div>

                <div class="mt-2 text-xs text-slate-500">
                    Recent but delayed telemetry
                </div>
            </article>

            <article class="rounded-2xl border border-slate-700 bg-slate-950/70 p-6">
                <div class="text-xs uppercase tracking-[0.22em] text-slate-500">
                    Inactive Installations
                </div>

                <div id="live-ops-inactive-installations"
                     class="mt-3 font-display text-4xl text-slate-300">
                    @Model.Snapshot.InactiveInstallations
                </div>

                <div class="mt-2 text-xs text-slate-500">
                    No telemetry for 15 minutes
                </div>
            </article>

            <article class="rounded-2xl border border-cyan-500/20 bg-slate-950/70 p-6">
                <div class="text-xs uppercase tracking-[0.22em] text-slate-500">
                    Active Sessions
                </div>

                <div id="live-ops-active-sessions"
                     class="mt-3 font-display text-4xl text-cyan-300">
                    @Model.Snapshot.ActiveSessions
                </div>

                <div class="mt-2 text-xs text-slate-500">
                    Live Cosmic Diner runs
                </div>
            </article>

            <article class="rounded-2xl border border-fuchsia-500/20 bg-slate-950/70 p-6">
                <div class="text-xs uppercase tracking-[0.22em] text-slate-500">
                    Events Last 5 Minutes
                </div>

                <div id="live-ops-events-5"
                     class="mt-3 font-display text-4xl text-fuchsia-300">
                    @Model.Snapshot.EventsLast5Minutes
                </div>

                <div class="mt-2 text-xs text-slate-500">
                    Immediate telemetry volume
                </div>
            </article>

            <article class="rounded-2xl border border-fuchsia-500/20 bg-slate-950/70 p-6">
                <div class="text-xs uppercase tracking-[0.22em] text-slate-500">
                    Events Last 15 Minutes
                </div>

                <div id="live-ops-events-15"
                     class="mt-3 font-display text-4xl text-fuchsia-200">
                    @Model.Snapshot.EventsLast15Minutes
                </div>

                <div class="mt-2 text-xs text-slate-500">
                    Short-term operational load
                </div>
            </article>

            <article class="rounded-2xl border border-rose-500/20 bg-slate-950/70 p-6">
                <div class="text-xs uppercase tracking-[0.22em] text-slate-500">
                    Alert Rate
                </div>

                <div class="mt-3 flex items-end gap-2">
                    <span id="live-ops-alert-rate"
                          class="font-display text-4xl text-rose-300">
                        @Model.Snapshot.AlertRatePerMinute.ToString("0.00")
                    </span>

                    <span class="pb-1 text-xs uppercase tracking-[0.16em] text-slate-600">
                        per min
                    </span>
                </div>

                <div class="mt-2 text-xs text-slate-500">
                    <span id="live-ops-unresolved-alerts">
                        @Model.Snapshot.UnresolvedAlerts
                    </span>
                    unresolved alerts
                </div>
            </article>

            <article id="live-ops-spike-card"
                     class="rounded-2xl border border-cyan-500/20 bg-slate-950/70 p-6">
                <div class="text-xs uppercase tracking-[0.22em] text-slate-500">
                    Event Peak Indicator
                </div>

                <div id="live-ops-event-spike"
                     class="mt-3 font-display text-3xl uppercase text-cyan-300">
                    @Model.Snapshot.EventSpikeState
                </div>

                <div id="live-ops-event-spike-detail"
                     class="mt-2 text-xs text-slate-500">
                    Current 5m compared with previous 5m
                </div>
            </article>
        </section>

        <section class="mt-6 rounded-3xl border border-cyan-500/20 bg-slate-950/70 p-6 shadow-[0_0_40px_rgba(34,211,238,0.04)]">
            <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
                <div>
                    <p class="font-display text-xs uppercase tracking-[0.34em] text-cyan-300">
                        Fleet Matrix
                    </p>

                    <h2 class="mt-2 text-2xl font-semibold text-white">
                        Installation Status Grid
                    </h2>
                </div>

                <div class="text-sm text-slate-500">
                    Showing
                    <span id="live-ops-visible-installations"
                          class="font-semibold text-cyan-300">
                        @Model.Snapshot.Installations.Count
                    </span>
                    of
                    <span id="live-ops-total-installations"
                          class="font-semibold text-cyan-300">
                        @Model.Snapshot.TotalInstallations
                    </span>
                </div>
            </div>

            <div id="live-ops-empty-state"
                 class="mt-6 rounded-2xl border border-slate-800 bg-slate-900/60 p-10 text-center @(Model.Snapshot.Installations.Count > 0 ? "hidden" : "")">
                <p class="font-display text-sm uppercase tracking-[0.26em] text-slate-400">
                    No installations registered
                </p>

                <p class="mt-3 text-sm text-slate-500">
                    Installation cards will appear when Unity clients connect.
                </p>
            </div>

            <div id="live-ops-installation-grid"
                 class="mt-6 grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-3 2xl:grid-cols-4">
                @foreach (var installation in Model.Snapshot.Installations)
                {
                    <article class="rounded-2xl border @StateBorder(installation.OperationalState) @StateBackground(installation.OperationalState) p-5 transition duration-300 hover:-translate-y-1">
                        <div class="flex items-start justify-between gap-4">
                            <div class="min-w-0">
                                <div class="truncate text-base font-semibold text-white">
                                    @installation.DeviceName
                                </div>

                                <div class="mt-1 text-xs text-slate-500">
                                    @installation.Platform · @installation.BuildVersion
                                </div>
                            </div>

                            <span class="inline-flex shrink-0 items-center gap-2 rounded-full border border-current/20 px-3 py-1 text-xs font-semibold uppercase tracking-[0.14em] @StateText(installation.OperationalState)">
                                <span class="h-2 w-2 rounded-full @StateDot(installation.OperationalState)"></span>
                                @installation.OperationalState
                            </span>
                        </div>

                        <div class="mt-5 grid grid-cols-2 gap-3">
                            <div class="rounded-xl border border-slate-800/80 bg-slate-950/50 p-3">
                                <div class="text-[10px] uppercase tracking-[0.18em] text-slate-600">
                                    Scene
                                </div>

                                <div class="mt-1 truncate text-sm text-slate-200">
                                    @installation.CurrentScene
                                </div>
                            </div>

                            <div class="rounded-xl border border-slate-800/80 bg-slate-950/50 p-3">
                                <div class="text-[10px] uppercase tracking-[0.18em] text-slate-600">
                                    Game State
                                </div>

                                <div class="mt-1 truncate text-sm text-slate-200">
                                    @installation.CurrentGameState
                                </div>
                            </div>
                        </div>

                        <div class="mt-4 truncate text-xs text-slate-600"
                             title="@installation.InstallationId">
                            @installation.InstallationId
                        </div>
                    </article>
                }
            </div>

            <div class="mt-5 text-right text-xs text-slate-600">
                Last refreshed:
                <span id="live-ops-last-refresh">
                    @Model.Snapshot.ServerTimeUtc.ToString("HH:mm:ss 'UTC'")
                </span>
            </div>
        </section>
    </div>
</div>

@section Scripts {
    <script src="~/lib/signalr/signalr.min.js"
            asp-append-version="true"></script>

    <script src="~/js/live-operations.js"
            asp-append-version="true"></script>

    <script>
        window.echoConsoleLiveOperations.init({
            hubUrl: "/hubs/admin-telemetry",
            snapshotUrl: "/Admin/LiveOperations/Snapshot",
            refreshIntervalMilliseconds: 15000
        });
    </script>
}