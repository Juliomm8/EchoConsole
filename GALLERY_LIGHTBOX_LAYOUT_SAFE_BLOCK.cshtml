    <style>
        #cosmic-gallery .gallery-capture {
            position: relative;
            isolation: isolate;
        }

        #cosmic-gallery .gallery-capture::before {
            content: "";
            position: absolute;
            inset: 0;
            z-index: 2;
            pointer-events: none;
            opacity: 0.14;
            background:
                repeating-linear-gradient(
                    0deg,
                    rgba(34, 197, 94, 0.08) 0,
                    rgba(34, 197, 94, 0.08) 1px,
                    transparent 1px,
                    transparent 4px
                );
            mix-blend-mode: screen;
            transition:
                opacity 180ms ease,
                transform 180ms ease;
        }

        #cosmic-gallery .gallery-capture::after {
            content: "";
            position: absolute;
            left: 0;
            right: 0;
            top: -35%;
            z-index: 3;
            height: 30%;
            pointer-events: none;
            opacity: 0;
            background:
                linear-gradient(
                    180deg,
                    transparent,
                    rgba(74, 222, 128, 0.28),
                    rgba(34, 197, 94, 0.08),
                    transparent
                );
            filter: blur(1px);
        }

        #cosmic-gallery .gallery-capture:hover::before,
        #cosmic-gallery .gallery-capture:focus-visible::before {
            opacity: 0.34;
            animation: gallery-interference 180ms steps(2, end) infinite;
        }

        #cosmic-gallery .gallery-capture:hover::after,
        #cosmic-gallery .gallery-capture:focus-visible::after {
            opacity: 1;
            animation: gallery-scan 1.15s linear infinite;
        }

        #cosmic-gallery .gallery-capture:hover img,
        #cosmic-gallery .gallery-capture:focus-visible img {
            transform: scale(1.035);
            filter:
                contrast(1.08)
                saturate(0.85)
                brightness(0.92);
        }

        #gallery-lightbox.gallery-lightbox-root {
            position: fixed;
            inset: 0;
            z-index: 100;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: clamp(0.75rem, 2.5vw, 2rem);
        }

        #gallery-lightbox .gallery-lightbox-panel {
            position: relative;
            z-index: 1;
            display: grid;
            grid-template-columns:
                minmax(0, 7fr)
                minmax(18rem, 3fr);
            width: min(72rem, calc(100vw - 1.5rem));
            height: min(760px, 80vh);
            max-height: 80vh;
            overflow: hidden;
        }

        #gallery-lightbox .gallery-lightbox-image-shell,
        #gallery-lightbox .gallery-lightbox-details {
            min-width: 0;
            min-height: 0;
        }

        #gallery-lightbox .gallery-lightbox-details-scroll {
            scrollbar-width: thin;
            scrollbar-color: #22c55e #000000;
        }

        #gallery-lightbox .gallery-lightbox-details-scroll::-webkit-scrollbar {
            width: 7px;
        }

        #gallery-lightbox .gallery-lightbox-details-scroll::-webkit-scrollbar-track {
            background: #000000;
        }

        #gallery-lightbox .gallery-lightbox-details-scroll::-webkit-scrollbar-thumb {
            background: #22c55e;
            border: 2px solid #000000;
            border-radius: 999px;
        }

        @@keyframes gallery-scan {
            from {
                transform: translateY(0);
            }

            to {
                transform: translateY(450%);
            }
        }

        @@keyframes gallery-interference {
            0% {
                transform: translateX(0);
            }

            33% {
                transform: translateX(1px);
            }

            66% {
                transform: translateX(-1px);
            }

            100% {
                transform: translateX(0);
            }
        }

        @@media (max-width: 1023px) {
            #gallery-lightbox .gallery-lightbox-panel {
                grid-template-columns: minmax(0, 1fr);
                grid-template-rows:
                    minmax(220px, 52%)
                    minmax(0, 48%);
            }
        }

        @@media (max-width: 639px) {
            #gallery-lightbox.gallery-lightbox-root {
                padding: 0.75rem;
            }

            #gallery-lightbox .gallery-lightbox-panel {
                width: calc(100vw - 1.5rem);
                height: 84vh;
                max-height: 84vh;
                grid-template-rows:
                    minmax(190px, 46%)
                    minmax(0, 54%);
            }
        }

        @@media (prefers-reduced-motion: reduce) {
            #cosmic-gallery .gallery-capture::before,
            #cosmic-gallery .gallery-capture::after,
            #cosmic-gallery .gallery-capture img {
                animation: none !important;
                transition: none !important;
            }
        }
    </style>

    <section id="cosmic-gallery"
             class="relative border-y border-green-500/15 bg-black">
        <div class="crt-grid-background pointer-events-none absolute inset-0 opacity-20"></div>

        <div class="relative mx-auto max-w-[1600px] px-6 py-20 lg:px-10">
            <header class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
                <div class="max-w-3xl">
                    <p class="terminal-kicker">
                        VISUAL_ARCHIVE // 10 FILES
                    </p>

                    <h2 class="mt-4 font-display text-3xl uppercase tracking-[0.06em] text-green-100 sm:text-5xl">
                        Screenshot Gallery
                    </h2>

                    <p class="mt-5 max-w-2xl text-sm leading-7 text-slate-500 sm:text-base">
                        Recovered visual records from inside Cosmic Diner.
                        Select a capture to open the full-resolution archive.
                    </p>
                </div>

                <div class="shrink-0 border-l border-green-500/20 pl-4 text-[10px] uppercase tracking-[0.20em] text-green-700">
                    <div>ARCHIVE_STATUS: ACCESSIBLE</div>
                    <div class="mt-2">FORMAT: PNG</div>
                    <div class="mt-2">INTERFACE: CENTERED_POPUP</div>
                </div>
            </header>

            @{
                var galleryTitles = new[]
                {
                    "Sector 4 Anomaly",
                    "Midnight Service Protocol",
                    "Maintenance Corridor Breach",
                    "Dining Hall Blackout",
                    "Signal Relay Chamber",
                    "Staff Access Terminal",
                    "Freezer Unit Distortion",
                    "Exterior Storm Watch",
                    "Emergency Power Cycle",
                    "Final Shift Transmission"
                };

                var galleryDescriptions = new[]
                {
                    "Visual record of unusual activity detected near the main dining hall during the fourth service sector inspection.",
                    "Archived frame from the midnight service protocol shortly before the restaurant communications became unstable.",
                    "Maintenance footage showing a restricted corridor after an unexpected pressure and lighting failure.",
                    "A complete power interruption left the dining area visible only through emergency phosphor lighting.",
                    "Recovered image of the relay chamber responsible for routing internal diner transmissions.",
                    "The staff access console displayed an unauthorized sequence while the facility remained under lockdown.",
                    "Thermal distortion was detected around the freezer units after the environmental systems stopped responding.",
                    "Exterior surveillance recorded severe weather and signal interference surrounding the Cosmic Diner.",
                    "Emergency generators restored partial lighting while several internal systems remained disconnected.",
                    "The final visual transmission recovered from the shift before the archive signal was interrupted."
                };
            }

            <div id="gallery-grid"
                 class="mt-12 grid grid-cols-2 gap-3 md:grid-cols-3 md:gap-5 lg:grid-cols-4">
                @for (var galleryIndex = 1; galleryIndex <= 10; galleryIndex++)
                {
                    var galleryNumber =
                        galleryIndex.ToString("00");

                    var galleryFileName =
                        $"gallery-{galleryNumber}.png";

                    var galleryImagePath =
                        Url.Content(
                            $"~/images/gallery/{galleryFileName}");

                    var galleryTitle =
                        galleryTitles[galleryIndex - 1];

                    var galleryDescription =
                        galleryDescriptions[galleryIndex - 1];

                    var galleryAlt =
                        $"{galleryTitle} - Cosmic Diner screenshot {galleryNumber}";

                    <button type="button"
                            class="gallery-capture group overflow-hidden rounded border border-green-500/20 bg-black text-left shadow-[0_0_20px_rgba(34,197,94,0.04)] outline-none transition duration-300 hover:-translate-y-1 hover:border-green-400/45 hover:shadow-[0_0_28px_rgba(34,197,94,0.15)] focus-visible:border-green-300 focus-visible:ring-2 focus-visible:ring-green-400/30"
                            data-gallery-trigger
                            data-gallery-src="@galleryImagePath"
                            data-gallery-download="@galleryFileName"
                            data-gallery-alt="@galleryAlt"
                            data-gallery-title="@galleryTitle"
                            data-gallery-desc="@galleryDescription"
                            aria-label="Open @galleryTitle">
                        <span class="relative block aspect-video overflow-hidden bg-[#020502]">
                            <img src="@galleryImagePath"
                                 alt="@galleryAlt"
                                 loading="lazy"
                                 decoding="async"
                                 class="h-full w-full object-cover transition duration-500" />

                            <span class="pointer-events-none absolute inset-x-0 bottom-0 z-10 flex items-center justify-between bg-gradient-to-t from-black via-black/75 to-transparent px-3 pb-3 pt-10">
                                <span class="font-mono text-[9px] uppercase tracking-[0.20em] text-green-400">
                                    FILE_@galleryNumber
                                </span>

                                <span class="font-mono text-[8px] uppercase tracking-[0.18em] text-green-800 transition group-hover:text-green-500">
                                    OPEN
                                </span>
                            </span>
                        </span>
                    </button>
                }
            </div>
        </div>
    </section>

    <div id="gallery-lightbox"
         class="gallery-lightbox-root pointer-events-none invisible bg-black/80 opacity-0 backdrop-blur-sm transition duration-300"
         role="dialog"
         aria-modal="true"
         aria-hidden="true"
         aria-labelledby="gallery-lightbox-title"
         aria-describedby="gallery-lightbox-description">
        <button type="button"
                class="absolute inset-0 cursor-default"
                data-gallery-backdrop
                tabindex="-1"
                aria-label="Close screenshot preview">
        </button>

        <div id="gallery-lightbox-panel"
             class="gallery-lightbox-panel terminal-panel rounded-lg border border-green-500/35 bg-black shadow-[0_0_60px_rgba(34,197,94,0.18)]"
             role="document"
             tabindex="-1">
            <figure class="gallery-lightbox-image-shell relative flex items-center justify-center overflow-hidden border-b border-green-500/20 bg-[#010301] lg:border-b-0 lg:border-r">
                <div class="pointer-events-none absolute inset-0 bg-[repeating-linear-gradient(0deg,rgba(34,197,94,0.035)_0,rgba(34,197,94,0.035)_1px,transparent_1px,transparent_4px)]"></div>

                <div class="pointer-events-none absolute inset-x-0 top-0 z-10 flex items-center justify-between border-b border-green-500/10 bg-black/70 px-4 py-2 text-[8px] uppercase tracking-[0.20em] text-green-800">
                    <span>VISUAL_FEED</span>
                    <span>OBJECT_CONTAIN</span>
                </div>

                <img id="gallery-lightbox-image"
                     src=""
                     alt=""
                     class="relative z-[1] h-full w-full object-contain p-4 pt-12 sm:p-6 sm:pt-14" />
            </figure>

            <aside class="gallery-lightbox-details flex min-h-0 flex-col bg-black">
                <header class="flex items-start justify-between gap-4 border-b border-green-500/20 bg-green-500/5 px-5 py-4">
                    <div class="min-w-0">
                        <p class="text-[8px] uppercase tracking-[0.22em] text-green-700">
                            ARCHIVE_METADATA
                        </p>

                        <p id="gallery-lightbox-file"
                           class="mt-2 truncate text-[9px] uppercase tracking-[0.18em] text-green-500">
                            NO_FILE_SELECTED
                        </p>
                    </div>

                    <button type="button"
                            id="gallery-lightbox-close"
                            class="shrink-0 rounded border border-green-500/20 bg-black px-3 py-2 text-[9px] font-bold uppercase tracking-[0.16em] text-green-600 transition hover:border-rose-500/40 hover:bg-rose-500/10 hover:text-rose-300 focus:outline-none focus:ring-2 focus:ring-green-400/30"
                            aria-label="Close gallery lightbox">
                        CLOSE [X]
                    </button>
                </header>

                <div class="gallery-lightbox-details-scroll min-h-0 flex-1 overflow-y-auto px-5 py-6">
                    <div class="border-l-2 border-green-500/30 pl-4">
                        <p class="text-[8px] uppercase tracking-[0.22em] text-green-800">
                            RECORD_TITLE
                        </p>

                        <h2 id="gallery-lightbox-title"
                            class="mt-3 font-display text-xl uppercase leading-snug tracking-[0.08em] text-green-200 sm:text-2xl">
                            Screenshot Preview
                        </h2>
                    </div>

                    <div class="mt-7">
                        <p class="text-[8px] uppercase tracking-[0.22em] text-green-800">
                            FIELD_DESCRIPTION
                        </p>

                        <p id="gallery-lightbox-description"
                           class="mt-3 text-sm leading-7 text-slate-400">
                            Select a gallery record to load its visual description.
                        </p>
                    </div>

                    <dl class="mt-8 grid grid-cols-2 gap-3 text-[8px] uppercase tracking-[0.16em]">
                        <div class="rounded border border-green-500/15 bg-green-500/5 p-3">
                            <dt class="text-green-800">FORMAT</dt>
                            <dd class="mt-2 text-green-400">PNG</dd>
                        </div>

                        <div class="rounded border border-green-500/15 bg-green-500/5 p-3">
                            <dt class="text-green-800">STATUS</dt>
                            <dd class="mt-2 text-green-400">RECOVERED</dd>
                        </div>
                    </dl>
                </div>

                <footer class="grid gap-3 border-t border-green-500/20 bg-[#020502] p-5">
                    <a id="gallery-lightbox-download"
                       href="#"
                       download
                       class="inline-flex items-center justify-center rounded border border-green-400/40 bg-green-500/10 px-5 py-3 text-[10px] font-bold uppercase tracking-[0.18em] text-green-200 shadow-phosphor transition hover:bg-green-500/20 hover:text-green-100 focus:outline-none focus:ring-2 focus:ring-green-400/30">
                        DOWNLOAD FILE
                    </a>

                    <button type="button"
                            id="gallery-lightbox-close-secondary"
                            class="inline-flex items-center justify-center rounded border border-slate-700 bg-black px-5 py-3 text-[9px] font-bold uppercase tracking-[0.16em] text-slate-500 transition hover:border-rose-500/35 hover:text-rose-300 focus:outline-none focus:ring-2 focus:ring-green-400/30">
                        CLOSE PREVIEW
                    </button>
                </footer>
            </aside>
        </div>
    </div>

@section Scripts {
    <script>
        (() => {
            const lightbox =
                document.getElementById(
                    "gallery-lightbox");

            const lightboxPanel =
                document.getElementById(
                    "gallery-lightbox-panel");

            const lightboxImage =
                document.getElementById(
                    "gallery-lightbox-image");

            const lightboxDownload =
                document.getElementById(
                    "gallery-lightbox-download");

            const lightboxFile =
                document.getElementById(
                    "gallery-lightbox-file");

            const lightboxTitle =
                document.getElementById(
                    "gallery-lightbox-title");

            const lightboxDescription =
                document.getElementById(
                    "gallery-lightbox-description");

            const closeButton =
                document.getElementById(
                    "gallery-lightbox-close");

            const secondaryCloseButton =
                document.getElementById(
                    "gallery-lightbox-close-secondary");

            const galleryTriggers =
                document.querySelectorAll(
                    "[data-gallery-trigger]");

            if (
                !lightbox
                || !lightboxPanel
                || !lightboxImage
                || !lightboxDownload
                || !lightboxFile
                || !lightboxTitle
                || !lightboxDescription
                || !closeButton
                || !secondaryCloseButton
            ) {
                return;
            }

            let lastFocusedElement = null;
            let previousBodyOverflow = "";
            let previousBodyPaddingRight = "";

            const lockPageScroll = () => {
                const scrollbarWidth =
                    window.innerWidth
                    - document.documentElement.clientWidth;

                previousBodyOverflow =
                    document.body.style.overflow;

                previousBodyPaddingRight =
                    document.body.style.paddingRight;

                document.body.style.overflow =
                    "hidden";

                if (scrollbarWidth > 0) {
                    document.body.style.paddingRight =
                        `${scrollbarWidth}px`;
                }
            };

            const unlockPageScroll = () => {
                document.body.style.overflow =
                    previousBodyOverflow;

                document.body.style.paddingRight =
                    previousBodyPaddingRight;
            };

            window.addEventListener(
                "pagehide",
                unlockPageScroll);

            const openLightbox = trigger => {
                const imageSource =
                    trigger.dataset.gallerySrc;

                const downloadName =
                    trigger.dataset.galleryDownload
                    ?? "cosmic-diner-screenshot.png";

                const imageAlt =
                    trigger.dataset.galleryAlt
                    ?? "Cosmic Diner screenshot";

                const imageTitle =
                    trigger.dataset.galleryTitle
                    ?? "Recovered Visual Record";

                const imageDescription =
                    trigger.dataset.galleryDesc
                    ?? "No field description is available for this visual record.";

                if (!imageSource) {
                    return;
                }

                lastFocusedElement =
                    document.activeElement;

                lightboxImage.src =
                    imageSource;

                lightboxImage.alt =
                    imageAlt;

                lightboxDownload.href =
                    imageSource;

                lightboxDownload.download =
                    downloadName;

                lightboxFile.textContent =
                    downloadName;

                lightboxTitle.textContent =
                    imageTitle;

                lightboxDescription.textContent =
                    imageDescription;

                lightbox.classList.remove(
                    "pointer-events-none",
                    "invisible",
                    "opacity-0");

                lightbox.classList.add(
                    "visible",
                    "opacity-100");

                lightbox.setAttribute(
                    "aria-hidden",
                    "false");

                lockPageScroll();

                window.requestAnimationFrame(() => {
                    closeButton.focus();
                });
            };

            const closeLightbox = () => {
                if (
                    lightbox.getAttribute(
                        "aria-hidden") === "true"
                ) {
                    return;
                }

                lightbox.classList.add(
                    "pointer-events-none",
                    "invisible",
                    "opacity-0");

                lightbox.classList.remove(
                    "visible",
                    "opacity-100");

                lightbox.setAttribute(
                    "aria-hidden",
                    "true");

                unlockPageScroll();

                window.setTimeout(() => {
                    lightboxImage.src = "";
                    lightboxImage.alt = "";
                    lightboxDownload.href = "#";
                    lightboxDownload.download = "";
                    lightboxFile.textContent =
                        "NO_FILE_SELECTED";
                    lightboxTitle.textContent =
                        "Screenshot Preview";
                    lightboxDescription.textContent =
                        "Select a gallery record to load its visual description.";
                }, 300);

                if (
                    lastFocusedElement
                    instanceof HTMLElement
                ) {
                    lastFocusedElement.focus();
                }
            };

            galleryTriggers.forEach(trigger => {
                trigger.addEventListener(
                    "click",
                    () => openLightbox(trigger));
            });

            closeButton.addEventListener(
                "click",
                closeLightbox);

            secondaryCloseButton.addEventListener(
                "click",
                closeLightbox);

            lightbox.addEventListener(
                "click",
                event => {
                    if (
                        event.target
                        instanceof HTMLElement
                        && event.target.hasAttribute(
                            "data-gallery-backdrop")
                    ) {
                        closeLightbox();
                    }
                });

            document.addEventListener(
                "keydown",
                event => {
                    const isOpen =
                        lightbox.getAttribute(
                            "aria-hidden") === "false";

                    if (!isOpen) {
                        return;
                    }

                    if (event.key === "Escape") {
                        closeLightbox();
                        return;
                    }

                    if (event.key !== "Tab") {
                        return;
                    }

                    const focusableElements = [
                        closeButton,
                        lightboxDownload,
                        secondaryCloseButton
                    ].filter(element => {
                        return !element.hasAttribute(
                            "disabled");
                    });

                    const firstElement =
                        focusableElements[0];

                    const lastElement =
                        focusableElements[
                            focusableElements.length - 1
                        ];

                    if (
                        event.shiftKey
                        && document.activeElement
                            === firstElement
                    ) {
                        event.preventDefault();
                        lastElement.focus();
                    }
                    else if (
                        !event.shiftKey
                        && document.activeElement
                            === lastElement
                    ) {
                        event.preventDefault();
                        firstElement.focus();
                    }
                });
        })();
    </script>
}
